---
// /terms — terms of use (spec §1 + plan T27 step 3).
//
// Phase 1.A scope: healthcare-staffing template adapted boilerplate per
// plan T27. Heavily marked as DRAFT pending Zach legal review (spec §10
// item 5 / SG15 Pre-Launch Checklist). Treat content as draft and out of
// scope for production reliance until Zach signs off.
//
// Sections: services description, no-fee-to-clinicians clause, recruiter-
// relationship language, dispute resolution (Texas governing law), severability,
// modification clause.
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import ScrollReveal from '../components/util/ScrollReveal.astro';

const LAST_UPDATED = '2026-05-07';
const SUPPORT_EMAIL = 'recruiting@iastaffing.com';
---
<MarketingLayout
  title="Terms of Use — Innovative Medical Staffing"
  description="The terms governing your use of this site and Innovative Medical Staffing's services."
>
  <SiteNav slot="nav" />

  <ScrollReveal as="article" id="terms" class="legal" aria-labelledby="terms-heading">
    <div class="legal__inner">
      <p class="eyebrow">TERMS OF USE</p>
      <h1 id="terms-heading" class="headline">Terms of Use</h1>
      <p class="draft-notice" role="note">
        <strong>Draft:</strong> these terms are currently under legal review.
        The substance reflects how IMS operates today, but the language is
        provisional. The final version will be linked here on launch.
      </p>

      <h2>The service</h2>
      <p>
        Innovative Medical Staffing (&ldquo;IMS&rdquo;) provides healthcare-
        staffing services connecting qualified clinicians with healthcare
        facilities for locum tenens and similar engagements. This site
        describes the service, lists open opportunities, and provides contact
        paths. Information presented on this site is general unless captured
        in a signed agreement between IMS and a clinician or facility.
      </p>

      <h2>No fees charged to clinicians</h2>
      <p>
        IMS does not charge clinicians a fee for placement or representation.
        Compensation to IMS is paid by the facility partner under a separate
        staffing agreement. Clinicians retain the right to engage directly
        with any facility outside the IMS relationship.
      </p>

      <h2>Recruiter relationship</h2>
      <p>
        Submitting a CV, contact form, or inquiry creates a non-exclusive,
        no-obligation working relationship with an IMS recruiter for the
        purpose of evaluating fit. It does not constitute employment, an
        offer of employment, or a guarantee of placement. Either party may
        end the relationship at any time before a signed engagement.
      </p>

      <h2>Information accuracy</h2>
      <p>
        Information clinicians and facilities provide must be accurate and
        complete to the best of their knowledge. IMS verifies credentials,
        references, and licensure; reliance on materially false information
        may end the working relationship.
      </p>

      <h2>Site use</h2>
      <p>
        You agree not to access this site through automated means beyond
        ordinary search-engine crawling, attempt to interfere with the site
        infrastructure, or use the site to send unsolicited commercial
        messages to addresses harvested from it.
      </p>

      <h2>Intellectual property</h2>
      <p>
        Site content (copy, marks, illustrations) is the property of IMS or
        its licensors. You may share links to public pages and quote short
        excerpts with attribution; do not reproduce the site or substantial
        portions of it without written permission.
      </p>

      <h2>Disclaimer</h2>
      <p>
        Site content is provided on an as-is basis. IMS does not warrant the
        site will be uninterrupted or error-free. To the extent permitted by
        law, IMS disclaims implied warranties of merchantability, fitness for
        a particular purpose, and non-infringement.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        To the extent permitted by law, IMS&rsquo;s liability arising from
        site use is limited to the amount paid by you to IMS in the twelve
        months preceding the claim, which for site visitors is zero. This
        does not limit liability for matters that cannot be limited by law,
        including gross negligence or willful misconduct.
      </p>

      <h2>Governing law and disputes</h2>
      <p>
        These terms are governed by the laws of the State of Texas, without
        regard to its conflict-of-laws rules. The parties agree to attempt
        good-faith resolution before filing a claim. Any unresolved dispute
        will be brought in the state or federal courts in Travis County,
        Texas, unless applicable consumer-protection law in your jurisdiction
        gives you a non-waivable right to a different venue.
      </p>

      <h2>Severability and modification</h2>
      <p>
        If any provision of these terms is found unenforceable, the remainder
        stays in effect. We may update these terms when our practices change
        or when the law requires it; the &ldquo;Last updated&rdquo; date below
        reflects the most recent change. Continued use of the site after a
        change constitutes acceptance of the updated terms.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms: <a href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>.
      </p>

      <p class="updated">Last updated {LAST_UPDATED}.</p>
    </div>
  </ScrollReveal>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  .eyebrow {
    font-family: var(--font-display);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-gold-muted);
    margin: 0 0 16px;
  }
  .legal {
    padding: clamp(64px, 12vh, 120px) clamp(24px, 5vw, 80px);
  }
  .legal__inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .legal .headline {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 56px);
    line-height: 1.1;
    color: var(--ink-on-cream);
    margin: 0 0 24px;
    letter-spacing: -0.01em;
  }
  .draft-notice {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-on-cream-3);
    background: color-mix(in srgb, var(--brand-gold) 12%, transparent);
    border-left: 3px solid var(--brand-gold);
    padding: 16px 20px;
    border-radius: 4px;
    margin: 0 0 40px;
    max-width: 64ch;
  }
  .draft-notice strong { color: var(--ink-on-cream); }
  .legal h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.6vw, 28px);
    line-height: 1.25;
    color: var(--ink-on-cream);
    margin: 40px 0 12px;
    letter-spacing: -0.005em;
  }
  .legal p {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-on-cream-3);
    margin: 0 0 12px;
    max-width: 64ch;
  }
  .legal a {
    color: var(--brand-navy);
    text-decoration: none;
    border-bottom: 1px solid var(--brand-navy);
    padding-bottom: 1px;
    transition: color 200ms var(--ease-out), border-color 200ms var(--ease-out);
  }
  .legal a:hover {
    color: var(--brand-blue-deep);
    border-color: var(--brand-blue-deep);
  }
  .legal a:focus-visible {
    outline: 2px solid var(--brand-navy);
    outline-offset: 3px;
    border-color: transparent;
  }
  .updated {
    margin-top: 56px;
    color: var(--ink-on-cream-2);
    font-size: 14px;
  }

  @media (prefers-reduced-motion: reduce) {
    .legal a { transition: none; }
  }
</style>
