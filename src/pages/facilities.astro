---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
---
<MarketingLayout title="For Facilities — Innovative Medical Staffing" description="A curated roster, not a job board. Three vetted clinicians per opening, credentialing typically under 60 days, one account lead." inCard={false}>
  <SiteNav slot="nav" />

  <div class="atmosphere atmosphere--coral" aria-hidden="true"></div>
  <div class="atmosphere atmosphere--lilac" aria-hidden="true"></div>
  <div class="atmosphere atmosphere--butter" aria-hidden="true"></div>

  <div class="variation">
    <section class="fb__hero">
      <div class="hero__blob hero__blob--coral" aria-hidden="true" style="top: -140px; right: -100px; opacity: 0.32;"></div>
      <div class="hero__blob hero__blob--lilac" aria-hidden="true" style="bottom: -120px; left: 30%; width: 320px; height: 320px; opacity: 0.30;"></div>
      <div class="container">
        <div class="hero-stage">
          <span class="fb__hero-eyebrow" style="--i:0">For facilities · since 2022</span>
          <h1 class="fb__hero-title" style="--i:1">A curated roster, <span>not a job board.</span></h1>
          <p class="fb__hero-sub" style="--i:2">We send three clinicians per opening, from a roster of physicians and CRNAs we know, not a stack of strangers. People we know by name and stand behind.</p>
          <div class="fb__hero-cta" style="--i:3">
            <a class="pill pill--swing" href="/contact"><span>Submit a staffing request</span><span class="pill__puck">→</span></a>
            <a class="pill pill--secondary" href="tel:+15125246686">Call (512) 524-6686 <span class="pill__arrow">→</span></a>
          </div>
        </div>
        <div class="fb__hero-vis">
          <div class="fb__roster reveal-group">
            <div class="fb__roster-label">Available this week · roster snapshot</div>
            <div class="fb__roster-item reveal" style="--i:0">
              <div class="fb__roster-avatar" style="background: var(--sky); color: var(--ink);">JM</div>
              <div class="fb__roster-info">
                <b>Dr. Jordan M.</b>
                <small>Anesthesia · 10y · TX</small>
              </div>
              <span class="fb__roster-badge">Open call</span>
            </div>
            <div class="fb__roster-item reveal" style="--i:1">
              <div class="fb__roster-avatar" style="background: var(--coral); color: var(--ink);">KR</div>
              <div class="fb__roster-info">
                <b>Kavi R., CRNA</b>
                <small>Anesthesia · 14y · CA</small>
              </div>
              <span class="fb__roster-badge">Available</span>
            </div>
            <div class="fb__roster-item reveal" style="--i:2">
              <div class="fb__roster-avatar" style="background: var(--violet); color: var(--ink);">SP</div>
              <div class="fb__roster-info">
                <b>Dr. Sara P.</b>
                <small>OB-GYN · 8y · CO</small>
              </div>
              <span class="fb__roster-badge">Available</span>
            </div>
            <div class="fb__roster-item reveal" style="--i:3">
              <div class="fb__roster-avatar" style="background: var(--rose); color: var(--ink);">RN</div>
              <div class="fb__roster-info">
                <b>Dr. Rae N.</b>
                <small>Emergency · 12y · NM</small>
              </div>
              <span class="fb__roster-badge">In credentialing</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="fb__pillars">
      <div class="container">
        <div class="section-anchor reveal-group">
          <div class="reveal" style="--i:0">
            <span class="eyebrow"><span class="eyebrow__dot"></span>§ 01 · Three-pillar approach</span>
            <h2 class="section-anchor__heading">What every partnership <span class="em">always</span> includes.</h2>
          </div>
          <p class="section-anchor__sub reveal" style="--i:1">Whether you're a 240-bed acute-care hospital or a single surgery center, these three commitments are the floor, never the ceiling.</p>
        </div>
        <div class="fb__pillars-grid reveal-group">
          <article class="fb__pillar reveal" style="--i:0">
            <div class="fb__pillar-num">01</div>
            <h3 class="fb__pillar-title">Concierge account management.</h3>
            <p class="fb__pillar-body">One account lead, the same person at the same number, who learns your call structure, EMR, and staff, and treats your facility like a partner. Country-club-level concierge support, not a queue or a round-robin handoff.</p>
            <ul class="fb__pillar-list">
              <li>Single point of contact, no rotation</li>
              <li>Direct phone, no triage</li>
              <li>Response within one business day</li>
            </ul>
          </article>
          <article class="fb__pillar reveal" style="--i:1">
            <div class="fb__pillar-num">02</div>
            <h3 class="fb__pillar-title">Tailored, three-candidate shortlist.</h3>
            <p class="fb__pillar-body">Three clinicians from our house roster matched to your specialty, call structure, and team culture. Not thirty resumes. Three real fits.</p>
            <ul class="fb__pillar-list">
              <li>A few vetted fits, not a stack of resumes</li>
              <li>Pre-screened for fit, not just skill</li>
              <li>References checked before we send them</li>
            </ul>
          </article>
          <article class="fb__pillar reveal" style="--i:2">
            <div class="fb__pillar-num">03</div>
            <h3 class="fb__pillar-title">Credentialing, handled.</h3>
            <p class="fb__pillar-body">Credentialing typically lands in under 60 days, and when a start can't wait, we can push emergency credentialing through in a few weeks.</p>
            <ul class="fb__pillar-list">
              <li>Typically under 60 days</li>
              <li>Emergency credentialing when timing is tight</li>
              <li>Malpractice covered</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="fc__quotes">
      <div class="container">
        <div class="section-anchor reveal-group">
          <div class="reveal" style="--i:0">
            <span class="eyebrow"><span class="eyebrow__dot"></span>§ 02 · Facility feedback</span>
            <h2 class="section-anchor__heading">From the people who <span class="em">hired them</span>.</h2>
          </div>
          <p class="section-anchor__sub reveal" style="--i:1">Submitted via our post-assignment review, lightly excerpted for length.</p>
        </div>
        <div class="fc__quotes-grid reveal-group">
          <article class="fc__quote fc__quote--mint reveal" style="--i:0">
            <p class="fc__quote-text">"In a small hospital, an uncovered anesthesia weekend turns into moved cases and frustrated surgeons fast. IMS was <em>straightforward about availability</em>, kept us posted when dates shifted, and helped us hold coverage while we kept recruiting for the permanent role."</p>
            <div class="fc__quote-attr">
              <div class="fc__quote-avatar" style="background: var(--coral); color: var(--ink);">DH</div>
              <div>
                <b>Dr. Devin Hale, VP of Medical Affairs</b>
                <small>Critical-access hospital · TX</small>
              </div>
            </div>
          </article>
          <article class="fc__quote fc__quote--butter reveal" style="--i:1">
            <p class="fc__quote-text">"Our office gets buried when a locums file shows up half-finished. IMS was different: the applications were clean, the procedure logs current, and when we needed one last item for temporary privileges, they knew exactly how to <em>close the gap</em>."</p>
            <div class="fc__quote-attr">
              <div class="fc__quote-avatar" style="background: var(--violet); color: var(--ink);">MO</div>
              <div>
                <b>Maria Ortiz, Medical Staff Office</b>
                <small>Rural hospital · AZ</small>
              </div>
            </div>
          </article>
          <article class="fc__quote fc__quote--rose reveal" style="--i:2">
            <p class="fc__quote-text">"IMS didn't flood us with random anesthesia CVs. They brought a short list of CRNAs who <em>actually fit our case mix</em>, and by the time we interviewed them, the credentialing was already moving."</p>
            <div class="fc__quote-attr">
              <div class="fc__quote-avatar" style="background: var(--rose); color: var(--ink);">RN</div>
              <div>
                <b>Renee Nakamura, Director of Perioperative Services</b>
                <small>Multi-specialty ASC · CO</small>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="fc__form">
      <div class="container">
        <div class="wns-card scroll-reveal">
          <div class="wns-card__blob" aria-hidden="true"></div>
          <span class="wns-card__eyebrow">We need staffing</span>
          <h2 class="wns-card__title">Start with a <span>conversation</span>.</h2>
          <p class="wns-card__sub">We'll listen to what you need, send three real candidates, and help keep credentialing moving with your medical-staff office, typically under 60 days, faster when a start can't wait. Submit a request or call, either works.</p>
          <div class="wns-card__row">
            <a class="pill pill--swing" href="/contact"><span>Submit a staffing request</span><span class="pill__puck">→</span></a>
            <span class="wns-card__or">or</span>
            <a class="wns-card__phone" href="tel:+15125246686">
              <span class="wns-card__phone-icon">☎</span>
              (512) 524-6686
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  /* Page-wide body bg + overflow-x:clip come from kit.css; no scoped body{}
   * rule here (Astro mangles the `body` selector so it never matches). */
  /* ============================================================
   * Seamless flow, sections are cream-throughout, color comes
   * from rounded cards, blobs decorate the negative space between.
   * ============================================================ */

  /* Marquee: full-bleed ink strip, items fade at viewport edges */
  .marquee-section.section--ink {
    background: var(--ink) !important;
    color: var(--cream-soft) !important;
    padding: var(--space-7) 0 !important;
  }
  .marquee-section .eyebrow { color: rgba(251, 246, 238, 0.5) !important; }
  .marquee-section .marquee-eyebrow {
    text-align: center;
    margin-bottom: var(--space-4);
    max-width: none;
    padding: 0 var(--container-pad);
  }
  .marquee-section .marquee {
    max-width: none;
    background: transparent;
    border-radius: 0;
    padding: 0;
  }
  .marquee-section .marquee__item { color: var(--cream-soft); }

  /* Variation A · premise: butter card on cream */
  .fa-a__premise {
    background: transparent !important;
    padding: var(--space-6) 0 !important;
  }
  .fa-a__premise .container {
    background: var(--soft-butter);
    border-radius: 28px;
    padding: var(--space-8) var(--space-7);
    max-width: 1080px !important;
  }

  /* Variation A · quote: ink card on cream */
  .fa-a__quote {
    background: transparent !important;
    color: var(--ink) !important;
    padding: var(--space-6) 0 !important;
  }
  .fa-a__quote .container {
    background: var(--ink);
    color: var(--cream-soft);
    border-radius: 28px;
    padding: var(--space-8) var(--space-7);
    max-width: 1120px !important;
    position: relative;
    overflow: hidden;
  }
  .fa-a__criteria { background: transparent !important; padding: var(--space-7) 0 !important; }
  .fa-a__cta { background: transparent !important; padding: var(--space-6) 0 var(--space-8) !important; }

  /* Variation B · hero: butter card on cream (was mint, retro vibe) */
  .fb__hero {
    background: transparent !important;
    padding: var(--space-7) 0 !important;
  }
  .fb__hero .container {
    background: var(--soft-sky);
    border-radius: 28px;
    padding: var(--space-8) var(--space-7);
    max-width: 1280px;
    position: relative;
    overflow: hidden;
  }
  /* Hero atmosphere blobs, page-scoped: warm coral + cool violet drifting on
   * the sky hero field, so the hero quietly carries three of the four hues. */
  .fb__hero .hero__blob--coral { background: var(--coral); }
  .fb__hero .hero__blob--lilac { background: var(--violet); }
  .fb__pillars { background: transparent !important; padding: var(--space-7) 0 !important; }
  .fb__cta { background: transparent !important; padding: var(--space-6) 0 var(--space-8) !important; }

  /* Variation C · hero: lilac card on cream */
  .fc__hero {
    background: transparent !important;
    padding: var(--space-7) 0 !important;
  }
  .fc__hero .container {
    background: var(--soft-lilac);
    border-radius: 28px;
    padding: var(--space-7) var(--space-6);
    max-width: 1080px;
    position: relative;
    overflow: hidden;
  }
  .fc__quotes { background: transparent !important; padding: var(--space-6) 0 !important; }
  .fc__form { background: transparent !important; padding: var(--space-6) 0 var(--space-8) !important; }

  /* Persistent atmospheric blobs, drift across the whole document */
  .atmosphere {
    position: fixed;
    pointer-events: none;
    z-index: 0;
    border-radius: 50%;
    filter: blur(120px);
  }
  .atmosphere--coral {
    width: 600px; height: 600px;
    background: var(--coral);
    opacity: 0.12;
    top: 20vh; right: -200px;
    animation: blobFloatA 28s ease-in-out infinite;
  }
  .atmosphere--lilac {
    width: 500px; height: 500px;
    background: var(--sky);
    opacity: 0.10;
    top: 60vh; left: -180px;
    animation: blobFloatB 32s ease-in-out infinite;
  }
  .atmosphere--butter {
    width: 400px; height: 400px;
    background: var(--violet);
    opacity: 0.16;
    bottom: -100px; right: 30%;
    animation: blobFloatC 24s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .atmosphere { animation: none; }
  }

  /* Make everything else stack above the atmosphere */
  .variation, .variation-label, .variation-rule { position: relative; z-index: 1; }

  .variation-rule { height: 1px; background: var(--rule-strong); margin: 0; }

  /* Shared component: We Need Staffing form preview block */
  .wns-card {
    background: var(--ink); color: var(--cream-soft);
    border-radius: 22px; padding: var(--space-7) var(--space-6);
    position: relative; overflow: hidden;
  }
  .wns-card__eyebrow {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700;
    color: var(--sky-soft); margin-bottom: var(--space-3);
    display: inline-flex; align-items: center; gap: 8px;
  }
  .wns-card__eyebrow::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--sky-soft);
  }
  .wns-card__title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(36px, 4vw, 56px); line-height: 1.0;
    letter-spacing: -0.025em; color: var(--cream-soft);
    margin: 0 0 var(--space-4); max-width: 18ch;
  }
  .wns-card__title span { color: var(--grass); }
  .wns-card__sub {
    font-family: var(--font-body); font-size: 17px; line-height: 1.55;
    color: rgba(251,246,238,0.75); margin: 0 0 var(--space-5);
    max-width: 52ch;
  }
  .wns-card__row {
    display: flex; gap: var(--space-3); align-items: center; flex-wrap: wrap;
    padding-top: var(--space-5);
    border-top: 1px solid rgba(251,246,238,0.18);
  }
  .wns-card__phone {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--font-display); font-weight: 900;
    font-size: 24px; letter-spacing: -0.02em;
    color: var(--cream-soft); text-decoration: none;
  }
  .wns-card__phone-icon {
    width: 36px; height: 36px; border-radius: 999px;
    background: rgba(251,246,238,0.1);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .wns-card__or {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(251,246,238,0.45);
    padding: 0 8px;
  }
  .wns-card__blob {
    position: absolute; pointer-events: none;
    width: 280px; height: 280px; border-radius: 50%;
    background: var(--grass); filter: blur(80px);
    opacity: 0.28;
    bottom: -120px; right: -80px;
  }

  /* ───── Variation A, Editorial long-form (Ritz-Carlton) ───── */
  .fa-a__hero {
    padding: var(--space-10) 0 var(--space-7);
    text-align: center;
    background: var(--cream);
    position: relative; overflow: hidden;
  }
  .fa-a__hero .container { display: flex; flex-direction: column; align-items: center; gap: var(--space-5); position: relative; z-index: 1; }
  .fa-a__hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute);
  }
  .fa-a__hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(56px, 8vw, 128px); line-height: 0.94;
    letter-spacing: -0.04em; color: var(--ink); margin: 0;
    max-width: 18ch;
  }
  .fa-a__hero-title span { color: var(--ink-emphasis); }
  .fa-a__hero-sub {
    font-family: var(--font-body); font-size: 20px; line-height: 1.55;
    color: var(--ink-soft); max-width: 60ch; margin: 0;
  }

  .fa-a__premise {
    padding: var(--space-9) 0;
    background: var(--soft-butter);
    position: relative; overflow: hidden;
  }
  .fa-a__premise .container { max-width: 920px; }
  .fa-a__premise-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute); margin-bottom: var(--space-4);
  }
  .fa-a__premise-text {
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(26px, 3.2vw, 44px); line-height: 1.25;
    letter-spacing: -0.018em; color: var(--ink); margin: 0;
  }
  .fa-a__premise-text span { color: var(--ink-emphasis); }

  .fa-a__quote {
    padding: var(--space-9) 0;
    background: var(--ink); color: var(--cream-soft);
  }
  .fa-a__quote .container { max-width: 1000px; text-align: center; }
  .fa-a__quote-mark {
    font-family: var(--font-display); font-weight: 900;
    font-size: 96px; line-height: 0.6;
    color: var(--grass); margin-bottom: var(--space-3);
  }
  .fa-a__quote-text {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(32px, 4.5vw, 64px); line-height: 1.1;
    letter-spacing: -0.025em; margin: 0 0 var(--space-5);
  }
  .fa-a__quote-text span { color: var(--grass); }
  .fa-a__quote-attr {
    font-family: var(--font-body); font-size: 15px;
    color: rgba(251,246,238,0.7);
  }
  .fa-a__quote-attr b { color: var(--cream-soft); font-weight: 700; }

  .fa-a__criteria {
    padding: var(--space-9) 0;
    background: var(--cream);
  }
  .fa-a__criteria-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 900px) { .fa-a__criteria-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .fa-a__criteria-grid { grid-template-columns: 1fr; } }
  .fa-a__crit {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    border-radius: 18px;
    padding: var(--space-5);
    display: flex; flex-direction: column; gap: var(--space-3);
    transition: transform 280ms var(--ease-out), box-shadow 280ms;
  }
  .fa-a__crit:hover { transform: translateY(-3px); box-shadow: 0 14px 36px rgba(31,26,35,0.08); }
  .fa-a__crit-num {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute);
  }
  .fa-a__crit-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: 22px; line-height: 1.05; letter-spacing: -0.02em;
    color: var(--ink); margin: 0;
  }
  .fa-a__crit-body {
    font-family: var(--font-body); font-size: 14px; line-height: 1.55;
    color: var(--ink-soft); margin: 0;
  }

  .fa-a__cta { padding: var(--space-8) 0 var(--space-10); background: var(--cream); }
  .fa-a__cta .container { max-width: 980px; }

  /* ───── Variation B, Service grid ───── */
  .fb__hero {
    padding: var(--space-9) 0;
    background: var(--soft-sky);
    position: relative;
    /* No overflow clip, blobs bleed up past the section edge into
       the nav area, matching the main site hero. */
  }
  .fb__hero .container {
    display: grid; grid-template-columns: 1.15fr 1fr;
    gap: var(--space-7); align-items: center;
  }
  @media (max-width: 900px) { .fb__hero .container { grid-template-columns: 1fr; } }
  .fb__hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink);
  }
  .fb__hero-title {
    font-family: var(--font-display); font-weight: 900;
    /* Sized so BOTH "A curated roster," and "not a job board." fit one line each
     * in this narrow 1.15fr column (no "board." orphan) — Zach 2026-06-16. */
    font-size: clamp(42px, 4.4vw, 56px); line-height: 1.05;
    letter-spacing: -0.035em; color: var(--ink);
    margin: var(--space-3) 0 var(--space-4);
  }
  /* Palette A: emphasis word = the BRIGHT blue thread (--sky) on the sand hero card. */
  /* Drop the colored phrase to its own line ("A curated roster," / "not a job
   * board.") so it never breaks mid-phrase — Zach 2026-06-16. */
  .fb__hero-title span { color: var(--sky, #3FB3E0); display: block; }
  .fb__hero-sub {
    font-family: var(--font-body); font-size: 18px; line-height: 1.55;
    color: var(--ink); margin: 0 0 var(--space-5); max-width: 48ch;
  }
  .fb__hero-cta { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .fb__hero-vis {
    position: relative; min-height: 360px;
    display: flex; align-items: center; justify-content: center;
  }
  .fb__roster {
    background: var(--cream-soft);
    border-radius: 20px;
    padding: var(--space-4);
    box-shadow: 0 16px 48px rgba(31,26,35,0.12);
    width: 100%; max-width: 380px;
  }
  .fb__roster-label {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute); margin-bottom: var(--space-3);
    display: flex; align-items: center; gap: 8px;
  }
  .fb__roster-label::before {
    content: ''; width: 8px; height: 8px; border-radius: 50%;
    background: var(--grass); animation: pulse 2.8s ease-in-out infinite;
  }
  .fb__roster-item {
