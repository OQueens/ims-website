---
/*
 * /contact — the dark "Get in touch" page (Phase 2, the design north-star).
 * Renders the GetInTouch dark island: ambient glows, split shell (left rail +
 * form card), client-side success state, and confetti. Real contact details
 * live in GetInTouch (recruiting@iastaffing.com / (512) 524-6686 / Fort Worth, TX).
 *
 * The homepage still uses ContactPanel (the cream contact-b panel); this page
 * is the standalone dark surface.
 *
 * STILL FLAGGED for Zach: Phase 2 is client-side success only — the form's
 * native POST to /api/contact + the endpoint + Cloudflare Turnstile + token
 * validation are a separate follow-on plan (backend not yet wired).
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import GetInTouch from '../components/sections/GetInTouch.astro';
---
<MarketingLayout
  title="Get in touch — Innovative Medical Staffing"
  description="A real conversation goes farther than a form. Email, call, or send a note — a real human replies within one business day."
  inCard={false}
>
  <SiteNav slot="nav" />
  <GetInTouch />
  <SiteFooter slot="footer" />
