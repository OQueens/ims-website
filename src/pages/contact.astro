---
/*
 * /contact — the dark "Get in touch" page (Phase 2, the design north-star).
 * Renders the GetInTouch dark island: ambient glows, split shell (left rail +
 * form card), client-side success state, and confetti. Real contact details
 * live in GetInTouch (recruiting@iastaffing.com / (512) 524-6686; IMS is remote,
 * founded in Fort Worth, TX — no office/HQ).
 *
 * The homepage still uses ContactPanel (the cream contact-b panel); this page
 * is the standalone dark surface.
 *
 * SSR (prerender=false) so the no-JS POST path can server-render the success
 * state (?sent=1) and surface a friendly error (?error=…). The JS path never
 * navigates — it fetches /api/contact and flips to success in place.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import GetInTouch from '../components/sections/GetInTouch.astro';

export const prerender = false;

const sent = Astro.url.searchParams.get('sent') === '1';
const errorCode = Astro.url.searchParams.get('error');
---
<MarketingLayout
  title="Get in touch — Innovative Medical Staffing"
  description="A real conversation goes farther than a form. Email, call, or send a note, and a real human replies within one business day."
  inCard={false}
>
  <SiteNav slot="nav" />
  <GetInTouch sent={sent} errorCode={errorCode} />
  <SiteFooter slot="footer" />
</MarketingLayout>
