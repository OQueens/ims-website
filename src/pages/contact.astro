---
/*
 * /contact — Chromia-Cream contact page. The kit's contact surface IS the
 * contact-b split panel (variations/contact.html variation B = ContactForm.jsx),
 * shared with the homepage via the ContactPanel partial. The prior page was a
 * skeleton (its Turnstile/Resend form was deferred and never wired).
 *
 * FLAG (iteration): the form does a native POST to /api/contact; Cloudflare
 * Turnstile + token validation + the success state are not yet wired into this
 * design. The kit's placeholder email/phone (hello@imsstaffing.com,
 * (817) 555-0140) are replicated per the exact-replication directive — the real
 * recruiting@iastaffing.com / (512) 524-6686 get restored in the content pass.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import ContactPanel from '../components/sections/ContactPanel.astro';
---
<MarketingLayout
  title="Get in touch — Innovative Medical Staffing"
  description="A real conversation goes farther than a form. Email, call, or send a note — a real human replies within one business day."
  inCard={false}
>
  <SiteNav slot="nav" />
  <ContactPanel as="h1" />
  <SiteFooter slot="footer" />
</MarketingLayout>
