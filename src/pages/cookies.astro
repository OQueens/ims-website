<MarketingLayout
  title="Cookies — Innovative Medical Staffing"
  description="We use cookies for the boring necessary things — no tracking pixels, no ad networks."
  inCard={false}
>
  <SiteNav slot="nav" />
  <LegalPage kind="cookies" />
  <SiteFooter slot="footer" />
</MarketingLayout>
