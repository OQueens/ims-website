---
/*
 * /cookies — Chromia-Cream legal page (kit Legal.jsx, kind="cookies").
 *
 * FLAG (content pass): replaces the prior page's real cookie notice (Plausible
 * stance, __cf_bm) with the kit's placeholder. Replicated per the exact-
 * replication directive, gated from indexed production — restore real notice
 * before launch.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import LegalPage from '../components/sections/LegalPage.astro';
