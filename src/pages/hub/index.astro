---
/*
 * /hub — internal operations dashboard (4 views: Overview, Rate Simulator,
 * Analytics, Weekly Sync). SSR (prerender=false), gated by the middleware hub
 * guard (Google @iastaffing.com session). Real Overview + Simulator-latest data
 * comes from the live ims_jobs feed via aggregateHub (same Supabase service-role
 * pattern as /jobs). Faithful port of design_handoff_hub.
 */
import HubLayout from '../../layouts/HubLayout.astro';
import HubSidebar from '../../components/hub/HubSidebar.astro';
import HubTopbar from '../../components/hub/HubTopbar.astro';
import OverviewView from '../../components/hub/OverviewView.astro';
import SimulatorView from '../../components/hub/SimulatorView.astro';
import AnalyticsView from '../../components/hub/AnalyticsView.astro';
import SyncView from '../../components/hub/SyncView.astro';
import { readHubEnv } from '../../lib/hub/hub-env';
import { aggregateHub, type HubJobRow } from '../../lib/hub/hub-data';
import { aggregateAnalytics, activityFromEvents, type HubEventRow } from '../../lib/hub/hub-analytics';
import { getHubSupabase } from '../../lib/hub/hub-supabase';
import { getWeekKey, COLUMN_KEYS, type ColumnKey } from '../../lib/hub/sync-data';
import { SYNC_SEED } from '../../lib/hub/hub-seed';
import { normalizeLsKpis, type LsKpis } from '../../lib/hub/ls-analytics';

export const prerender = false;

const env = readHubEnv(Astro.locals);
const supabase = getHubSupabase(env);

// Two independent service-role reads through the shared seam: the current active
// ims_jobs snapshot (Overview + Analytics snapshot metrics) and the append-only
// ls_events log (Analytics time-series + the days-to-close proxy). Read in
// parallel; each degrades to an empty honest state on error.
const weekKey = getWeekKey(new Date());
let rows: HubJobRow[] = [];
let events: HubEventRow[] = [];
let syncRows: Array<{ column_key: string; items: unknown }> = [];
let lsAnalytics: LsKpis | null = null;
if (supabase) {
  const jobsQ = supabase
    .from('ims_jobs')
    .select(
      'specialty_slug, specialty_name, facility_state, facility_city, public_facility_label, organization, organization_id, length_category, call_type, coverage_type, ls_last_modified',
    )
    .eq('status', 'active')
    .order('ls_last_modified', { ascending: false, nullsFirst: false })
    .limit(1000);
  const eventsQ = supabase
    .from('ls_events')
    .select('occurred_at, event_type, assignment_id, status_after, specialty_slug, specialty_name, facility_state, facility_city, organization')
    .order('occurred_at', { ascending: false, nullsFirst: false })
    .limit(5000);
  const syncQ = supabase
    .from('hub_weekly_sync')
    .select('column_key, items')
    .eq('week_key', weekKey);
  // Latest LocumSmart Sisense KPI snapshot. Tolerant of a missing table
  // (pre-migration) — degrades to the honest "—" Analytics state.
  const lsQ = supabase
    .from('ims_ls_analytics')
    .select('kpis')
    .order('snapshot_at', { ascending: false })
    .limit(1);
  try {
    const [jobsRes, eventsRes, syncRes, lsRes] = await Promise.all([jobsQ, eventsQ, syncQ, lsQ]);
    if (jobsRes.error) console.error('[/hub] ims_jobs read failed:', jobsRes.error.message);
    else if (jobsRes.data) rows = jobsRes.data as HubJobRow[];
    if (eventsRes.error) console.error('[/hub] ls_events read failed:', eventsRes.error.message);
    else if (eventsRes.data) events = eventsRes.data as HubEventRow[];
    // hub_weekly_sync is tolerant: a missing table (pre-migration) or error just
    // falls back to the seed board — the client still works via localStorage.
    if (syncRes.error) console.error('[/hub] hub_weekly_sync read failed:', syncRes.error.message);
    else if (syncRes.data) syncRows = syncRes.data as Array<{ column_key: string; items: unknown }>;
    if (lsRes.error) console.error('[/hub] ims_ls_analytics read failed:', lsRes.error.message);
    else if (lsRes.data && lsRes.data.length) lsAnalytics = normalizeLsKpis((lsRes.data[0] as { kpis: unknown }).kpis);
  } catch (e) {
    console.error('[/hub] supabase client crash:', e);
  }
} else {
  console.warn('[/hub] supabase env not configured — hub renders empty real-data state');
}

// Build the current week's board: a persisted server row wins per column; an
// un-persisted column falls back to the seed starter template. Per-column
// `persisted` flags let the client preserve local edits for not-yet-saved columns.
const syncData = { recruiting: [...SYNC_SEED.recruiting], marketing: [...SYNC_SEED.marketing], operations: [...SYNC_SEED.operations] };
const syncPersisted = { recruiting: false, marketing: false, operations: false };
for (const r of syncRows) {
  if ((COLUMN_KEYS as readonly string[]).includes(r.column_key) && Array.isArray(r.items)) {
    const col = r.column_key as ColumnKey;
    syncData[col] = (r.items as unknown[]).filter((i): i is string => typeof i === 'string');
    syncPersisted[col] = true;
  }
}

const nowSec = Math.floor(Date.now() / 1000);
const overview = aggregateHub(rows, nowSec);
const analytics = aggregateAnalytics(rows, events, nowSec);
// Prefer the true ls_events activity stream; fall back to the latest-modified
// jobs feed (aggregateHub) only when the event log is empty.
const activity = events.length ? activityFromEvents(events, nowSec) : overview.activity;

// Server-rendered eyebrow date (no client clock).
const eyebrow = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'short',
  day: 'numeric',
}).format(new Date()).replace(',', ' ·');
---
<HubLayout title="IMS Hub · Dashboard" themeFlash>
  <div class="hub">
    <HubSidebar />
    <div class="hub-main">
      <HubTopbar eyebrow={eyebrow} title="Overview" />
      <OverviewView
        activeReqs={overview.activeReqs}
        facilityCount={overview.facilityCount}
        pipelineStates={overview.pipelineStates}
        pipelineSpecs={overview.pipelineSpecs}
        activity={activity}
        fillTimeDays={analytics.daysToClose.avg}
      />
      <SimulatorView latestJobs={overview.latestJobs} />
      <AnalyticsView analytics={analytics} lsAnalytics={lsAnalytics} />
      <SyncView weekKey={weekKey} data={syncData} persisted={syncPersisted} />
    </div>
  </div>
</HubLayout>

<script>
  import '../../components/hub/hub-client';
</script>
