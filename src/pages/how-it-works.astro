---
// /how-it-works — 4-step tabbed process (spec §1 + plan T25).
//
// More detailed than HomeProcess §2.8 — each step is its own subsection with
// ~80-word expansion and a time-estimate strip. Tabbed by audience with URL-
// param sync (?audience=clinicians|facilities). Default = clinicians.
//
// Tab JS implements WAI-ARIA APG tablist pattern (mirrors HomeProcess):
//   - role=tablist / role=tab / role=tabpanel
//   - aria-selected toggles to reflect active tab
//   - tabindex management: active=0, inactive=-1 (one-stop tabbing)
//   - ArrowLeft / ArrowRight cycle within tablist; Home/End jump to ends
//   - hidden attribute on inactive panels (matches initial SSR state)
// Plus URL-param sync layer beyond HomeProcess:
//   - On load, read ?audience= and sanitize against AUDIENCES allowlist —
//     unknown / missing values fall back to default.
//   - On tab activation, history.replaceState (NOT pushState — back-button
//     should not stack tab clicks).
//   - Active panel display via .is-active class only — no inline-style mutation.
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import ScrollReveal from '../components/util/ScrollReveal.astro';

interface Step {
  num: string;
  title: string;
  estimate: string;
  body: string;
}

const cliniciansSteps: Step[] = [
  {
    num: '01',
    title: 'Submit CV',
    estimate: 'Same day · ~10 minutes',
    body: 'Send your CV with license states, certifications, and the kinds of assignments you are open to. We read every one — no resume parser triage. A real recruiter follows up within one business day with either a yes-let-us-talk, a not-yet-but-soon, or an honest no with reasoning. You will not be left wondering.',
  },
  {
    num: '02',
    title: 'Onboarding',
    estimate: '3 – 7 days',
    body: 'Once we agree on a fit, credentialing, paperwork, and travel logistics get handled with you, not at you. We collect what we need once, store it securely, and reuse it for future assignments. License verifications, references, malpractice history, and facility-specific forms move in parallel so the long tail does not become the bottleneck.',
  },
  {
    num: '03',
    title: 'Schedule',
    estimate: 'Varies — confirmed in writing',
    body: 'A schedule that fits your life and the assignment, confirmed in writing before you arrive. If the facility shifts dates, we negotiate; if your situation shifts, we negotiate. Travel is booked through our travel partner with cancellation flexibility built in. You will know the unit, the contacts, and the start time before you board.',
  },
  {
    num: '04',
    title: 'Start',
    estimate: 'First day + ongoing',
    body: 'A real human is on call when something needs adjusting — first-day support, mid-shift questions, end-of-week check-ins. If a facility is not what was described, we hear about it from you and we act on it. When the assignment ends, your file stays warm for the next match without re-collecting the same documents.',
  },
];

const facilitiesSteps: Step[] = [
  {
    num: '01',
    title: 'Request',
    estimate: 'Same day acknowledgement',
    body: 'Tell us what coverage you need, when, and any context that shapes a good fit — acuity, EMR, call structure, the kind of clinician who has worked well historically. We confirm receipt the same business day with a recruiter assigned. No round-robin handoff between agency reps.',
  },
  {
    num: '02',
    title: 'Match',
    estimate: '1 – 3 days for shortlist',
    body: 'We come back with a curated shortlist — credentials reviewed, references called, travel availability confirmed. Each profile carries notes on why we think the match works, not just keywords. If the first round is wrong, we rework — rather than spam your inbox with marginal candidates to look like progress.',
  },
  {
    num: '03',
    title: 'Coordinate',
    estimate: '1 – 2 weeks pre-start',
    body: 'Credentialing, travel, and onboarding coordination handled end-to-end with your medical staff office, the clinician, and the facility. We track every line item — privileges, EPIC training, badge access, parking — and surface blockers early so the start date holds. Status visible to you in writing.',
  },
  {
    num: '04',
    title: 'Support',
    estimate: 'Assignment duration',
    body: 'Ongoing check-ins through the assignment so issues surface early, not late. Mid-assignment timing changes, scope adjustments, or extension conversations go through one recruiter who knows the file. Post-assignment, we capture what worked and what did not so the next match is better than the last.',
  },
];

interface Tab {
  id: 'clinicians' | 'facilities';
  label: string;
  steps: Step[];
}
const tabs: Tab[] = [
  { id: 'clinicians', label: 'For Clinicians', steps: cliniciansSteps },
  { id: 'facilities', label: 'For Facilities', steps: facilitiesSteps },
];
---
<MarketingLayout
  title="How It Works — Innovative Medical Staffing"
  description="The 4-step process for clinicians and facilities — from first contact to ongoing assignment support."
>
  <SiteNav slot="nav" />

  <ScrollReveal as="section" id="hero" class="hw-hero" aria-labelledby="hw-hero-heading">
    <div class="hw-hero__inner">
      <p class="eyebrow">HOW IT WORKS</p>
      <h1 id="hw-hero-heading" class="headline">Four steps. One real recruiter on the file.</h1>
      <p class="body">
        The process is the same shape on both sides — a careful intake, a
        considered match, a coordinated start, and ongoing support through
        the assignment. The detail differs by audience.
      </p>
    </div>
  </ScrollReveal>

  <ScrollReveal as="section" id="process" class="hw-process" aria-labelledby="hw-process-heading">
    <div class="hw-process__inner">
      <h2 id="hw-process-heading" class="visually-hidden">The 4-step process</h2>

      <div class="tabs" role="tablist" aria-label="Audience">
        {tabs.map((t, i) => (
          <button
            type="button"
            role="tab"
            id={`hw-tab-${t.id}`}
            class:list={['tab', { 'is-active': i === 0 }]}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`hw-panel-${t.id}`}
            tabindex={i === 0 ? 0 : -1}
            data-tab={t.id}
          >
            {t.label}
          </button>
        ))}
      </div>

      {tabs.map((t, i) => (
        <div
          role="tabpanel"
          id={`hw-panel-${t.id}`}
          aria-labelledby={`hw-tab-${t.id}`}
          class:list={['panel', { 'is-active': i === 0 }]}
          hidden={i !== 0}
          data-panel={t.id}
        >
          <ol class="steps">
            {t.steps.map((step) => (
              <li class="step">
                <p class="num">{step.num}</p>
                <h3 class="step-title">{step.title}</h3>
                <p class="estimate">{step.estimate}</p>
                <p class="step-body">{step.body}</p>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </ScrollReveal>

  <ScrollReveal as="section" id="closing" class="hw-closing" aria-labelledby="hw-closing-heading">
    <div class="hw-closing__inner">
      <h2 id="hw-closing-heading" class="closing-headline">Ready to start the conversation?</h2>
      <div class="closing-ctas">
        <a class="cta cta--primary" href="/jobs">Find Opportunities</a>
        <a class="cta cta--secondary" href="/contact?intent=coverage">Request Coverage</a>
      </div>
    </div>
  </ScrollReveal>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .eyebrow {
    font-family: var(--font-display);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-gold-muted);
    margin: 0 0 16px;
  }

  /* Hero */
  .hw-hero {
    padding: clamp(64px, 12vh, 144px) clamp(24px, 5vw, 80px) clamp(40px, 6vh, 80px);
  }
  .hw-hero__inner { max-width: 880px; margin: 0 auto; }
  .hw-hero .headline {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.1;
    color: var(--ink-on-cream);
    margin: 0 0 24px;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .hw-hero .body {
    font-family: var(--font-body);
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-on-cream-3);
    max-width: 60ch;
    margin: 0;
  }

  /* Process tabs */
  .hw-process {
    padding: clamp(40px, 6vh, 80px) clamp(24px, 5vw, 80px) clamp(64px, 10vh, 128px);
  }
  .hw-process__inner { max-width: 1200px; margin: 0 auto; }

  .tabs {
    display: inline-flex;
    gap: 8px;
    margin: 0 0 clamp(40px, 6vw, 64px);
    padding: 4px;
    background: color-mix(in srgb, var(--ink-on-cream) 4%, transparent);
    border-radius: var(--r-pill-mkt);
    width: fit-content;
  }
  .tab {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 10px 20px;
    border-radius: var(--r-pill-mkt);
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink-on-cream-3);
    cursor: pointer;
    transition: background-color 200ms var(--ease-out), color 200ms var(--ease-out);
  }
  .tab:hover { color: var(--ink-on-cream); }
  .tab.is-active {
    background: var(--brand-navy);
    color: var(--ink-on-dark);
  }
  .tab:focus-visible {
    outline: 2px solid var(--brand-navy);
    outline-offset: 2px;
  }

  .panel { display: none; }
  .panel.is-active { display: block; }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(40px, 5vw, 64px);
  }
  @media (min-width: 900px) {
    .steps { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: clamp(40px, 4vw, 56px); }
  }
  .step {
    padding: clamp(24px, 3vw, 32px);
    border: 1px solid var(--border-hairline);
    border-radius: var(--r-section);
    background: transparent;
  }
  .num {
    font-family: var(--font-display);
    font-size: clamp(40px, 4vw, 48px);
    line-height: 1;
    color: var(--ink-on-cream-2);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .step-title {
    font-family: var(--font-display);
    font-size: 26px;
    line-height: 1.2;
    color: var(--ink-on-cream);
    margin: 0 0 6px;
    letter-spacing: -0.005em;
  }
  .estimate {
    font-family: var(--font-body);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-gold-muted);
    margin: 0 0 16px;
  }
  .step-body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-on-cream-3);
    margin: 0;
    max-width: 60ch;
  }

  /* Closing */
  .hw-closing {
    padding: clamp(56px, 9vh, 120px) clamp(24px, 5vw, 80px);
    text-align: center;
  }
  .hw-closing__inner { max-width: 720px; margin: 0 auto; }
  .closing-headline {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.1;
    color: var(--ink-on-cream);
    margin: 0 0 24px;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .closing-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: var(--r-pill-mkt);
    font-family: var(--font-body);
    font-size: 16px;
    text-decoration: none;
    transition: background-color 200ms var(--ease-out), color 200ms var(--ease-out), border-color 200ms var(--ease-out);
  }
  .cta--primary {
    background: var(--brand-navy);
    color: var(--ink-on-dark);
    border: 1.5px solid var(--brand-navy);
  }
  .cta--primary:hover {
    background: color-mix(in srgb, var(--brand-navy) 88%, white);
    border-color: color-mix(in srgb, var(--brand-navy) 88%, white);
  }
  .cta--secondary {
    background: transparent;
    color: var(--brand-navy);
    border: 1.5px solid var(--brand-navy);
  }
  .cta--secondary:hover { background: var(--brand-navy); color: var(--ink-on-dark); }
  .cta:focus-visible {
    outline: 2px solid var(--brand-navy);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tab, .cta { transition: none; }
  }
</style>

<script>
  // /how-it-works tab toggle — WAI-ARIA APG tablist pattern + URL-param sync.
  // - aria-selected on tabs reflects active state
  // - tabindex management: active=0, inactive=-1 (one-stop tabbing)
  // - ArrowLeft / ArrowRight cycle within tablist; Home / End jump to ends
  // - hidden attribute on inactive panels (matches initial SSR state)
  // - URL ?audience= sanitized against AUDIENCES allowlist; unknown values
  //   fall through to the SSR-default panel (clinicians) without throwing
  // - history.replaceState (NOT pushState) so back-button does not stack
  //   tab clicks
  const AUDIENCES = ['clinicians', 'facilities'] as const;
  type Audience = typeof AUDIENCES[number];

  function isAudience(v: string | null): v is Audience {
    return v !== null && (AUDIENCES as readonly string[]).includes(v);
  }

  function init() {
    const tablist = document.querySelector<HTMLElement>('.hw-process [role="tablist"]');
    if (!tablist) return;
    const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
    if (tabs.length === 0) return;

    function indexFor(audience: Audience): number {
      const idx = tabs.findIndex((tab) => tab.dataset.tab === audience);
      return idx >= 0 ? idx : 0;
    }

    function activate(index: number, options: { focus?: boolean; updateUrl?: boolean } = {}) {
      const target = tabs[index];
      if (!target) return;
      tabs.forEach((tab, i) => {
        const isActive = i === index;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        tab.classList.toggle('is-active', isActive);
        const panelId = tab.getAttribute('aria-controls');
        if (panelId) {
          const panel = document.getElementById(panelId);
          if (panel) {
            panel.hidden = !isActive;
            panel.classList.toggle('is-active', isActive);
          }
        }
      });
      if (options.focus) target.focus();
      if (options.updateUrl) {
        const audience = target.dataset.tab;
        if (audience && isAudience(audience)) {
          const url = new URL(window.location.href);
          url.searchParams.set('audience', audience);
          history.replaceState({}, '', url.toString());
        }
      }
    }

    // Initial: read ?audience= sanitized against allowlist.
    const initial = new URL(window.location.href).searchParams.get('audience');
    if (isAudience(initial)) {
      activate(indexFor(initial));
    }
    // else: leave SSR default (clinicians) active — no URL rewrite.

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => activate(i, { updateUrl: true }));
      tab.addEventListener('keydown', (event) => {
        let next = -1;
        switch (event.key) {
          case 'ArrowRight': next = (i + 1) % tabs.length; break;
          case 'ArrowLeft':  next = (i - 1 + tabs.length) % tabs.length; break;
          case 'Home':       next = 0; break;
          case 'End':        next = tabs.length - 1; break;
          default: return;
        }
        event.preventDefault();
        activate(next, { focus: true, updateUrl: true });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
