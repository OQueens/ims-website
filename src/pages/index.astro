---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Innovative Medical Staffing"
  description="We're crafting something new. Back shortly."
  noindex={true}
>
  <main>
    <h1 class="wordmark">Innovative Medical Staffing</h1>
    <p class="subline">We're crafting something new. Back shortly.</p>
  </main>
</BaseLayout>

<style>
  main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
    animation: fade-in 0.6s var(--ease-out) both;
  }

  .wordmark {
    font-size: clamp(28px, 6vw, 56px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text);
    margin: 0 0 16px 0;
  }

  .subline {
    font-size: clamp(15px, 2vw, 17px);
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
    max-width: 32ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    main { animation: none; }
  }
</style>
