---
/*
 * Homepage — IMS dark redesign, translated from Claude Design handoff
 * (design-imports/claude-design-01/ims-dark-website/, 2026-05-12).
 *
 * Sections (top to bottom):
 *   1. Hero cluster — duotone headline + 5-card saturated cluster
 *   2. Trust strip — 5 stats in a deep-navy shell
 *   3. Audience split — clinicians (cyan) + facilities (champagne)
 *   4. How we work — 3 saturated cards (cobalt / tangerine / seafoam)
 *   5. Closing CTA — cream/champagne shell + this-week stats card
 *
 * Deferred to next session: Specialties grid + chip cloud, Pull quote with
 * member card SVG, 4-step Placement workflow, Featured assignments, Team
 * teaser, Traveler's Pamphlet (the showstopper). The other 10 marketing
 * pages still render with the new chrome but their inner content uses the
 * old cream-card tokens and will look broken — to be rewritten next session.
 *
 * prerender = false preserved so the homepage continues routing through
 * src/middleware.ts for the pages.dev → innovativemedicalstaffing.com 301
 * canonical redirect (Phase 1.0 architecture).
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';

export const prerender = false;
---
<MarketingLayout
  title="Innovative Medical Staffing — locum tenens, refined"
  description="Every clinical specialty, 47 states. One recruiter, their cell, a team that picks up the phone. Friday pay, $2M malpractice, travel handled — the country club of locum tenens."
  inCard={false}
>
  <SiteNav slot="nav" />

  <!-- ====================================================================
       1. HERO CLUSTER
       =================================================================== -->
  <section class="hero" aria-labelledby="hero-headline">
    <div class="hero__eyebrow">
      <span aria-hidden="true">⟶</span>
      <span>Locum tenens, refined · est. 2018 as IAS</span>
    </div>
    <h1 id="hero-headline" class="hero__duo">
      <span class="hero__claim">Stop chasing agency callbacks.</span>{' '}
      <span class="hero__soft">A real human picks up at IMS.</span>
    </h1>
    <p class="hero__lede">
      We staff every clinical specialty across 47 states — and we treat you the
      way the big firms forgot to. One recruiter. Their cell. A team that picks
      up the phone.
    </p>
    <div class="hero__ctas">
      <a href="/contact" class="btn btn--primary">
        Apply now
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
      </a>
      <a href="/facilities" class="btn btn--ghost">
        I run a facility
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="hero__proof">
      <span class="hero__proof-item"><span class="hero__proof-dot"></span>Friday direct deposit, every Friday</span>
      <span class="hero__proof-item"><span class="hero__proof-dot"></span>$2M / $4M occurrence malpractice</span>
      <span class="hero__proof-item"><span class="hero__proof-dot"></span>47 states · every specialty</span>
    </div>

    <!-- 5-card saturated cluster: tangerine spans 2 rows on the left;
         periwinkle / cobalt / seafoam / rose fill a 2×2 on the right -->
    <div class="cluster">
      <a href="/jobs" class="cluster__card cluster__card--lg cluster__tangerine">
        <span class="cluster__eyebrow">Daily placements</span>
        <h3 class="cluster__h--lg">
          Anesthesia.<br/>OB-GYN.<br/>Urology.<br/>EM. IM. Surgery.
        </h3>
        <p class="cluster__body">
          Six specialties we live in — and a long tail of forty more we know cold.
        </p>
        <div class="cluster__chips">
          <span>Radiology</span>
          <span>Psychiatry</span>
          <span>Hospitalist</span>
          <span>Pain</span>
          <span>Cardiology</span>
          <span>Family</span>
          <span>+ 40 more</span>
        </div>
        <div class="cluster__foot">
          See open assignments
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/clinicians" class="cluster__card cluster__periwinkle">
        <span class="cluster__eyebrow">Your recruiter</span>
        <h3 class="cluster__h">
          One name,<br/>
          <span class="cluster__h-accent">one cell.</span>
        </h3>
        <p class="cluster__body">
          Same person who placed you, every assignment after.
          Texting, calling, weekends — your person, not a queue.
        </p>
        <div class="cluster__foot cluster__foot--soft">(512) 524-6686 · call or text</div>
      </a>

      <a href="/jobs" class="cluster__card cluster__cobalt">
        <span class="cluster__eyebrow">This week</span>
        <h3 class="cluster__h">
          Open<br/>assignments.
        </h3>
        <p class="cluster__body">
          Live board, curated by a recruiter — not auto-scraped. Updated as
          LocumSmart pushes new roles.
        </p>
        <div class="cluster__live">
          <span class="cluster__live-dot" aria-hidden="true"></span>
          <span>See the job board</span>
        </div>
      </a>

      <a href="/clinicians" class="cluster__card cluster__seafoam">
        <span class="cluster__eyebrow">Cash flow</span>
        <h3 class="cluster__h cluster__h--ink">
          Friday pay.<br/>
          <span class="cluster__h-mute">Every Friday.</span>
        </h3>
        <p class="cluster__body cluster__body--ink">
          Direct deposit. Not "within 14 days." Not "pending clearance." Friday.
        </p>
        <div class="cluster__foot cluster__foot--ink">Weekly pay · simple timesheets</div>
      </a>

      <a href="/facilities" class="cluster__card cluster__rose">
        <span class="cluster__eyebrow">Where we work</span>
        <h3 class="cluster__h">
          47 states.<br/>
          <span class="cluster__h-accent">Every specialty.</span>
        </h3>
        <p class="cluster__body">
          One licensing team. One credentialing engine. One coast-to-coast roster.
        </p>
        <div class="cluster__foot cluster__foot--soft">Coast to coast · every specialty</div>
      </a>
    </div>
  </section>

  <!-- ====================================================================
       2. TRUST STRIP — verifiable / qualitative copy only.
       Codex r1 [medium] fold: dropped fabricated metrics (1,840 roster,
       <1 hr avg reply, 92% return rate) in line with CLAUDE.md
       "no estimated/fake data" rule. Numbers below are verifiable
       (founding year, licensing footprint, malpractice coverage from
       spec) or qualitative truths.
       =================================================================== -->
  <section class="trust">
    <div class="trust__shell">
      <div class="trust__stat">
        <div class="trust__num trust__num--accent">est. 2018</div>
        <div class="trust__label">as IAS · anesthesia-first</div>
      </div>
      <div class="trust__stat">
        <div class="trust__num">47</div>
        <div class="trust__label">states + D.C., licensed</div>
      </div>
      <div class="trust__stat">
        <div class="trust__num">every</div>
        <div class="trust__label">clinical specialty</div>
      </div>
      <div class="trust__stat">
        <div class="trust__num trust__num--accent">$2M / $4M</div>
        <div class="trust__label">occurrence malpractice, included</div>
      </div>
      <div class="trust__stat">
        <div class="trust__num">Friday</div>
        <div class="trust__label">direct deposit, every Friday</div>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       3. AUDIENCE SPLIT
       =================================================================== -->
  <section class="audience">
    <div class="audience__intro">
      <div>
        <span class="eyebrow eyebrow--mut" style="display:block;margin-bottom:24px">Two sides of the same handshake</span>
        <h2 class="audience__h2">
          We work for <span class="audience__accent-cyan">clinicians.</span><br/>
          We work with <span class="audience__accent-champagne">facilities.</span>
        </h2>
      </div>
      <p class="audience__sub">
        The same care we give a CRNA on a Sunday night is the care we give a chief
        medical officer on a Monday morning. Different needs, one standard.
      </p>
    </div>

    <div class="audience__pair">
      <div class="audience__card audience__card--clin">
        <span class="audience__card-eyebrow audience__card-eyebrow--clin">For clinicians</span>
        <h3 class="audience__card-title">The career-long handshake.</h3>
        <p class="audience__card-body">
          Your recruiter doesn't rotate. Your cell number doesn't change. Your
          credentials don't expire on our watch.
        </p>
        <ul class="audience__list">
          <li>
            <span class="audience__li-icon audience__li-icon--clin"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg></span>
            <div>
              <div class="audience__li-text">One recruiter. Their cell.</div>
              <div class="audience__li-meta">Texting, calling, weekends. A real human, not a queue or a portal ping.</div>
            </div>
          </li>
          <li>
            <span class="audience__li-icon audience__li-icon--clin"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2h-4v-7H9v7H5a2 2 0 0 1-2-2z"/></svg></span>
            <div>
              <div class="audience__li-text">Travel handled, end to end.</div>
              <div class="audience__li-meta">We negotiate the best the facility will cover, then handle the booking, the keys, and the arrival details.</div>
            </div>
          </li>
          <li>
            <span class="audience__li-icon audience__li-icon--clin"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            <div>
              <div class="audience__li-text">$2M / $4M occurrence malpractice.</div>
              <div class="audience__li-meta">Occurrence-based coverage, included with every assignment.</div>
            </div>
          </li>
          <li>
            <span class="audience__li-icon audience__li-icon--clin"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
            <div>
              <div class="audience__li-text">Friday direct deposit, every Friday.</div>
              <div class="audience__li-meta">Not "within 14 days." Not "pending clearance." Friday.</div>
            </div>
          </li>
        </ul>
        <div class="audience__cta-row">
          <a href="/contact" class="btn btn--cyan">
            Apply now
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
          <a href="/jobs" class="audience__link audience__link--cyan">
            Browse open assignments
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
        </div>
      </div>

      <div class="audience__card audience__card--fac">
        <span class="audience__card-eyebrow audience__card-eyebrow--fac">For facilities</span>
        <h3 class="audience__card-title">The roster you can vouch for.</h3>
        <p class="audience__card-body">
          We don't volume-staff. We send three clinicians we know personally —
          because you'll remember the one you wish we hadn't sent.
        </p>
        <ul class="audience__list">
          <li>
            <span class="audience__li-icon audience__li-icon--fac"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg></span>
            <div>
              <div class="audience__li-text">Curated, not scraped.</div>
              <div class="audience__li-meta">Three hand-picked candidates. Each vetted by a recruiter who's met them.</div>
            </div>
          </li>
          <li>
            <span class="audience__li-icon audience__li-icon--fac"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            <div>
              <div class="audience__li-text">Credentialing handled in-house.</div>
              <div class="audience__li-meta">One licensing team works your privileging packets alongside the placement — not after.</div>
            </div>
          </li>
          <li>
            <span class="audience__li-icon audience__li-icon--fac"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M11 17 9 19l-3-3 6-6 3 3"/><path d="m14 10 3-3 4 4-3 3"/><path d="M9 13 3 7l3-3 6 6"/></svg></span>
            <div>
              <div class="audience__li-text">Direct line to your account lead.</div>
              <div class="audience__li-meta">No call center, no offshoring. A name and a cell, from the start.</div>
            </div>
          </li>
          <li>
            <span class="audience__li-icon audience__li-icon--fac"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <div>
              <div class="audience__li-text">A real human picks up when it matters.</div>
              <div class="audience__li-meta">Holiday call-out, sick CRNA, last-minute trauma — you reach a person, not a portal.</div>
            </div>
          </li>
        </ul>
        <div class="audience__cta-row">
          <a href="/facilities" class="btn btn--cream">
            See our model
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="audience__link audience__link--champagne">
            Request a roster
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       4. HOW WE WORK — 3 saturated cards (cobalt / tangerine / seafoam)
       =================================================================== -->
  <section class="how">
    <div class="how__head">
      <div>
        <span class="eyebrow" style="display:block;margin-bottom:24px">⟶ How we work</span>
        <h2 class="how__h2">
          A staffing firm <br/>that acts like a <span class="how__accent">private club.</span>
        </h2>
      </div>
      <p class="how__sub">
        You aren't a number on a portal. You work with us — and the care we put in
        matches the kind of clinician we want on a Sunday-night call. Three pillars,
        all included.
      </p>
    </div>
    <div class="how__grid">
      <div class="how__card how__card--cobalt">
        <span class="how__card-eyebrow">Concierge desk</span>
        <h3 class="how__card-title">Your recruiter. Their cell.</h3>
        <p class="how__card-body">
          Not a 1-800 maze. The same person who placed you keeps your career, for years.
        </p>
        <ul class="how__list">
          <li><span class="how__bullet how__bullet--gold"></span>A real human, not a queue</li>
          <li><span class="how__bullet how__bullet--gold"></span>Small caseload, intentional</li>
          <li><span class="how__bullet how__bullet--gold"></span>A recruiting desk with names you'll learn</li>
        </ul>
      </div>
      <div class="how__card how__card--tangerine">
        <span class="how__card-eyebrow">Travel &amp; landing</span>
        <h3 class="how__card-title">We handle the trip.</h3>
        <p class="how__card-body">
          Whatever the facility covers — flight, hotel, rental, stipend — we book it,
          negotiate it, and make sure you arrive without a headache.
        </p>
        <ul class="how__list">
          <li><span class="how__bullet how__bullet--gold"></span>Curated booking, not a stack of receipts</li>
          <li><span class="how__bullet how__bullet--gold"></span>Keys, parking, and pager handed over on arrival</li>
          <li><span class="how__bullet how__bullet--gold"></span>Plus a Traveler's Issue — every city, curated</li>
        </ul>
      </div>
      <div class="how__card how__card--seafoam">
        <span class="how__card-eyebrow how__card-eyebrow--ink">Credentials &amp; coverage</span>
        <h3 class="how__card-title how__card-title--ink">We do the paperwork.</h3>
        <p class="how__card-body how__card-body--ink">
          Licensure, privileging, NPDB, $2M / $4M occurrence-based malpractice —
          included, expedited, and tracked by a real human.
        </p>
        <ul class="how__list how__list--ink">
          <li><span class="how__bullet how__bullet--ink"></span>Occurrence-based · included, not extra</li>
          <li><span class="how__bullet how__bullet--ink"></span>Expedited state licensure where possible</li>
          <li><span class="how__bullet how__bullet--ink"></span>Renewals tracked proactively, not last-minute</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       5. CLOSING CTA
       =================================================================== -->
  <section class="cta-out">
    <div class="cta-out__shell">
      <div class="cta-out__bg" aria-hidden="true"></div>
      <div class="cta-out__copy">
        <span class="cta-out__eyebrow">⟶ Ready when you are</span>
        <h2 class="cta-out__h2">Tell us where you want to work next.</h2>
        <p class="cta-out__body">
          Whether you're a clinician between assignments or a chief medical officer who
          needs coverage soon — give us a call, send a note, or fill the form.
          A real human replies, fast.
        </p>
        <div class="cta-out__btns">
          <a href="/contact" class="btn btn--ink-on-cream">
            Apply now
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
          <a href="/jobs" class="btn btn--ghost-on-cream">Browse assignments</a>
        </div>
      </div>
      <div class="cta-out__sidecard">
        <!-- Codex r1 [medium] fold: dropped fabricated week-of-IMS counts.
             Replaced with verifiable / qualitative facts from the spec. -->
        <h3 class="cta-out__sidecard-title">What's on the table</h3>
        <div class="cta-out__sidecard-row"><span>Open assignments</span><span class="cta-out__sidecard-val">Live board ↗</span></div>
        <div class="cta-out__sidecard-row"><span>Coverage</span><span class="cta-out__sidecard-val">47 states</span></div>
        <div class="cta-out__sidecard-row"><span>Response</span><span class="cta-out__sidecard-val">Real human</span></div>
        <div class="cta-out__sidecard-row"><span>Malpractice</span><span class="cta-out__sidecard-val">$2M / $4M occurrence</span></div>
      </div>
    </div>
  </section>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  /* =====================================================================
   * BUTTONS — shared across the homepage
   * =================================================================== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font: 600 15px/1 var(--font);
    letter-spacing: -0.2px;
    padding: 14px 22px;
    border-radius: 999px;
    border: 0;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: filter 120ms var(--ease-out), transform 120ms var(--ease-out), background 200ms var(--ease-out);
  }
  .btn:hover { filter: brightness(1.05); }
  .btn:active { transform: scale(0.98); }
  /* Codex r1 [medium] fold — white text on #FF8C3A is ~1.95:1 (fails WCAG AA
   * for normal text). Navy ink on tangerine measures ~7.3:1 (passes AA).
   * Cluster-card display headlines still use white text since the source
   * design accepts the trade-off there, but interactive buttons must pass
   * AA contrast as primary CTAs. */
  .btn--primary { background: var(--card-tangerine); color: var(--ims-navy-900); }
  .btn--primary:hover { color: var(--ims-navy-900); }
  .btn--cyan    { background: var(--ims-cyan-500); color: var(--ims-navy-900); }
  .btn--cyan:hover { color: var(--ims-navy-900); }
  .btn--cream   { background: var(--card-champagne); color: var(--ims-navy-900); }
  .btn--cream:hover { color: var(--ims-navy-900); }
  .btn--ghost   {
    background: transparent;
    color: var(--fg-1);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.18);
  }
  .btn--ghost:hover { color: var(--fg-1); }
  .btn--ink-on-cream {
    background: var(--ims-navy-900);
    color: var(--card-champagne);
  }
  .btn--ink-on-cream:hover { color: var(--card-champagne); }
  .btn--ghost-on-cream {
    background: transparent;
    color: #1a1409;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.20);
  }
  .btn--ghost-on-cream:hover { color: #1a1409; }

  /* =====================================================================
   * 1. HERO
   * =================================================================== */
  .hero {
    max-width: 1368px;
    margin: 0 auto;
    padding: 80px 36px 80px;
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font: 600 13px/1 var(--font);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--card-tangerine);
    margin-bottom: 28px;
  }
  .hero__duo {
    font: 800 clamp(48px, 6.4vw, 92px) / 0.96 var(--font);
    letter-spacing: -0.025em;
    margin: 0;
    text-wrap: balance;
    max-width: 1100px;
  }
  .hero__claim { color: var(--fg-1); }
  .hero__soft  { color: var(--fg-3); }
  .hero__lede {
    font: 500 18px/1.55 var(--font);
    letter-spacing: -0.3px;
    color: var(--fg-2);
    margin-top: 32px;
    max-width: 560px;
  }
  .hero__ctas {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .hero__proof {
    margin-top: 36px;
    display: flex;
    gap: 22px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero__proof-item {
    display: flex;
    align-items: center;
