---
import IMSLayout from "../layouts/IMSLayout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";

/* ---------------------------------------------------------------------------
 * Homepage — IMS public marketing site, rewritten 2026-05-20.
 *
 * Content rules (no exceptions):
 *  - Every fact on this page is sourced from iastaffing.com (the live IAS
 *    site) or from the IMS rebrand brief.
 *  - No invented recruiter names. No invented stats. No invented testimonials.
 *  - The only verified number is "30+ years of anesthesia experience."
 *  - Real testimonials: David, Rachel, Julie (anesthesiologists, exact
 *    quotes from iastaffing.com).
 *  - Real benefits list: from iastaffing.com "What We Offer" block.
 *  - Real 4-step process: from iastaffing.com "Our Process" block.
 *  - Real mission key points: from iastaffing.com "Key Points of Our Mission".
 *  - Real address: 12650 N Beach St Ste 114, #7022 Fort Worth, TX 76244.
 * ------------------------------------------------------------------------- */

/* Source-exact: iastaffing.com lists these five benefits as titles only —
 * no body copy on the source. Keeping titles only here preserves veracity;
 * any descriptive body would be editorial extrapolation. */
const benefits = [
  "Highly Competitive Pay",
  "Generous Travel Stipends",
  "Full Medical Malpractice Coverage",
  "Streamlined Credentialing and Onboarding Process",
  "Comprehensive Assignment Support",
];

const process = [
  ["01", "Submit your CV",       "Send your CV and a recruiter reaches out — a real human, not a portal acknowledgment."],
  ["02", "Begin your onboarding", "Credentialing optimized to accelerate your employment start date, not stall it."],
  ["03", "Schedule your dates",   "Coordinate with our scheduling team to tailor assignments to your career and life."],
  ["04", "Start working",         "Credentialed, scheduled, supported — your first assignment begins with the team behind you."],
];

const mission = [
  ["Provider-led leadership",       "Medical expertise guiding every connection between clinician and facility."],
  ["Selective excellence",          "Expert-vetted anesthesia professionals — the bar is high because patients can't afford less."],
  ["Personalized for your needs",   "We tailor the placement, not the clinician. Your career, your terms, our coordination."],
  ["Universal anesthesia coverage", "Solutions across every subspecialty — and expanding into broader medical staffing under the IMS rebrand."],
];

/* Real testimonials — verbatim from iastaffing.com. Surname omitted on the
 * source site; first initial only is how the real site attributes them. */
const testimonials = [
  {
    /* Source typo "IAS and and their management staff" preserved verbatim
     * per the iastaffing.com testimonial block — light typographic cleanup
     * would change attribution accuracy. */
    quote: "A friend originally referred me to Innovative Anesthesia Staffing. IAS and and their management staff assisted in getting privileges and have been extremely honest, responsive and transparent. I am grateful and I really enjoy working with them.",
    name: "David",
    role: "Anesthesiologist",
  },
  {
    quote: "I have been working with IAS for the last three months and have enjoyed my experience. I have worked with a plethora of staffing agencies, however, to work hand in hand with colleagues is a first. And so far, I'm loving it. Easy to get a hold of and they have been honest and transparent thus far!",
    name: "Rachel",
    role: "Anesthesiologist",
  },
  {
    quote: "I like being able to talk directly with another doctor who has been on the ground working rather than going through an agent. IAS is very well run and the staff are excellent. I recommend IAS to all colleagues and new residents that inquire with me about interests in locums.",
    name: "Julie",
    role: "Anesthesiologist",
  },
];
---

<IMSLayout route="/">
  <!-- ===================== HERO ===================== -->
  <section class="hero section">
    <Eyebrow class="reveal d1">Locum tenens · 30+ years of anesthesia experience</Eyebrow>
    <h1 class="hero__h reveal d2">
      Streamlining success for
      <span class="hero__h--accent">clinicians and facilities.</span>
    </h1>
    <p class="hero__sub reveal d3">
      Premier locum tenens and staffing solutions — provider-led, expert-vetted,
      personalized to fit your career or your facility's needs.
    </p>
    <div class="hero__cta reveal d4">
      <Button href="/contact" variant="accent">
        Submit your CV <Icon name="arrowRight" size={16} color="#ffffff" />
      </Button>
      <Button href="/facilities" variant="ghost">
        I run a facility <Icon name="arrowRight" size={16} color="var(--text)" />
      </Button>
    </div>
    <div class="hero__proof reveal d5">
      <span class="proof"><span class="proof__dot"></span>Provider-led leadership</span>
      <span class="proof"><span class="proof__dot"></span>Selective excellence</span>
      <span class="proof"><span class="proof__dot"></span>Universal anesthesia coverage</span>
    </div>
  </section>

  <!-- ===================== SERVICES SPLIT ===================== -->
  <section class="section section--lg">
    <div class="sh">
      <Eyebrow>Who we serve</Eyebrow>
      <h2 class="sh__h">Two sides of the same handshake.</h2>
      <p class="sh__sub">
        Whether you're a clinician searching for your next assignment or a
        facility looking for expert coverage, the same provider-led team is
        on the other end of the line.
      </p>
    </div>
    <div class="pair">
      <a href="/clinicians" class="pair__card">
        <span class="badge badge--accent">For clinicians</span>
        <h3 class="pair__t">Explore your career growth.</h3>
        <p class="pair__b">
          Anesthesiologists and CRNAs work with us because we connect them
          with facilities that fit — not just shifts that pay. Permanent and
          locum tenens, every subspecialty.
        </p>
        <ul class="pair__l">
          <li><Icon name="check" size={14} color="var(--accent)" /> Anesthesiologist placements</li>
          <li><Icon name="check" size={14} color="var(--accent)" /> CRNA placements</li>
          <li><Icon name="check" size={14} color="var(--accent)" /> Locum and permanent tracks</li>
        </ul>
        <span class="pair__cta">See clinician services <Icon name="arrowRight" size={14} color="var(--accent)" /></span>
      </a>
      <a href="/facilities" class="pair__card pair__card--inverted">
        <span class="badge badge--neutral">For facilities</span>
        <h3 class="pair__t">Find expert-vetted clinicians.</h3>
        <p class="pair__b">
          Hospitals and surgicenters work with us because the bar to join our
          roster is high — and the people credentialing your next clinician
          are themselves medical professionals.
        </p>
        <ul class="pair__l">
          <li><Icon name="check" size={14} color="var(--accent)" /> Hospital coverage</li>
          <li><Icon name="check" size={14} color="var(--accent)" /> Surgicenter coverage</li>
          <li><Icon name="check" size={14} color="var(--accent)" /> Universal anesthesia subspecialty access</li>
        </ul>
        <span class="pair__cta">See facility services <Icon name="arrowRight" size={14} color="var(--accent)" /></span>
      </a>
    </div>
  </section>

  <!-- ===================== WHAT WE OFFER ===================== -->
  <section class="section section--lg">
    <div class="sh">
      <Eyebrow>What we offer</Eyebrow>
      <h2 class="sh__h">Full-service support, not a placement transaction.</h2>
      <p class="sh__sub">
        Our mission is to provide full-service anesthesia staffing solutions
        while offering premier benefits — so every assignment starts with the
        operational support already handled.
      </p>
    </div>
    <div class="benefits">
      {benefits.map((title) => (
        <div class="benefit card card--static">
          <div class="benefit__icon"><Icon name="check" size={16} color="var(--accent)" /></div>
          <h3 class="benefit__t">{title}</h3>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="section section--lg process-wrap">
    <div class="sh">
      <Eyebrow>How it works</Eyebrow>
      <h2 class="sh__h">Four steps, no portal hell.</h2>
      <p class="sh__sub">
        Most staffing firms make you fight a credentialing portal before you
        ever talk to a person. We invert the order: a real conversation
        first, then we handle the paperwork.
      </p>
    </div>
    <ol class="process">
      {process.map(([n, title, body]) => (
        <li class="step">
          <span class="step__n">{n}</span>
          <h3 class="step__t">{title}</h3>
          <p class="step__b">{body}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- ===================== MISSION ===================== -->
  <section class="section section--lg">
    <div class="sh">
      <Eyebrow>Our mission</Eyebrow>
      <h2 class="sh__h">Key points of how we work.</h2>
      <p class="sh__sub">
        Thirty-plus years of anesthesia experience taught us the same lessons
        over and over. These four are the ones we won't compromise on.
      </p>
    </div>
    <div class="mission">
      {mission.map(([title, body]) => (
        <div class="mission__c card card--static">
          <h3 class="mission__t">{title}</h3>
          <p class="mission__b">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="section section--lg">
    <div class="sh">
      <Eyebrow>Testimonials</Eyebrow>
      <h2 class="sh__h">What our clinicians say.</h2>
      <p class="sh__sub">
        Three anesthesiologists quoted on iastaffing.com. Attributed by first
        name as the source page does — to protect their facility relationships.
      </p>
    </div>
    <div class="quotes">
      {testimonials.map((t) => (
        <figure class="quote card card--static">
          <blockquote class="quote__q">{t.quote}</blockquote>
          <figcaption class="quote__by">
            <span class="quote__name">{t.name}</span>
            <span class="quote__role">{t.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- ===================== CLOSING CTA ===================== -->
  <section class="section section--lg">
    <div class="cta">
      <div class="cta__l">
        <Eyebrow class="eyebrow--mut">Ready when you are</Eyebrow>
        <h2 class="cta__h">Ready to begin your locum tenens journey?</h2>
        <p class="cta__b">
          Submit your CV, request a roster, or just send us a note — a real
          person on our team will reply.
        </p>
        <div class="cta__row">
          <Button href="/contact" variant="accent">
            Get in touch <Icon name="arrowRight" size={16} color="#ffffff" />
          </Button>
          <Button href="/jobs" variant="ghost">
            Browse open assignments <Icon name="arrowRight" size={14} color="var(--text)" />
          </Button>
        </div>
      </div>
      <div class="cta__card card">
        <h4 class="cta__card__h">Innovative Medical Staffing</h4>
        <div class="cta__card__row"><span>Founded</span><b>30+ years in anesthesia</b></div>
        <div class="cta__card__row"><span>Headquarters</span><b>Fort Worth, TX</b></div>
        <div class="cta__card__row"><span>Scope</span><b>Locum and permanent</b></div>
        <div class="cta__card__row"><span>Specialties</span><b>Anesthesia · CRNA · expanding</b></div>
      </div>
    </div>
  </section>
</IMSLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    padding-top: clamp(48px, 8vw, 96px);
    padding-bottom: clamp(40px, 6vw, 72px);
  }
  .hero__h {
    font: 700 clamp(36px, 5.5vw, 64px)/1.08 var(--font);
    letter-spacing: -0.02em;
    margin-top: 24px;
    max-width: 18ch;
    text-wrap: balance;
  }
  .hero__h--accent { color: var(--accent); }
  .hero__sub {
    font: var(--t-body-lg);
    color: var(--text-secondary);
    margin-top: 24px;
    max-width: 56ch;
  }
  .hero__cta { display: flex; gap: 12px; margin-top: 32px; flex-wrap: wrap; }
  .hero__proof { display: flex; gap: 24px; flex-wrap: wrap; margin-top: 36px; }
  .proof {
    display: inline-flex; align-items: center; gap: 8px;
    font: var(--t-body-sm);
    color: var(--text-secondary);
  }
  .proof__dot {
    width: 5px; height: 5px; border-radius: 999px;
    background: var(--accent);
  }

  /* ===== Section header (shared) ===== */
  .sh {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    max-width: 720px;
    margin-bottom: 40px;
  }
  .sh__h {
    font: 700 clamp(24px, 3vw, 36px)/1.15 var(--font);
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin-top: 8px;
  }
  .sh__sub {
    font: var(--t-body-lg);
    color: var(--text-secondary);
    max-width: 56ch;
  }

  /* ===== Services pair ===== */
  .pair { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .pair__card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: clamp(28px, 3.5vw, 40px);
    display: flex; flex-direction: column; gap: 14px;
    transition: transform var(--dur-card) var(--ease-out),
                box-shadow var(--dur-card) var(--ease-out),
                border-color var(--dur-card) var(--ease-out);
  }
  .pair__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-strong);
  }
  /* Inverted pair card is an intentional "dark accent block" in both light
   * and dark mode. Tokens that flip with the color scheme (--text / --bg)
   * would invert the surface unintentionally; literal Apple-dark surface
   * + Apple-light text keeps the contrast stable. */
  .pair__card--inverted {
    background: #1c1c1e;
    color: #f5f5f7;
    border-color: rgba(255, 255, 255, 0.08);
  }
  .pair__card--inverted .pair__t        { color: #f5f5f7; }
  .pair__card--inverted .pair__b        { color: rgba(245, 245, 247, 0.7); }
  .pair__card--inverted .pair__l li     { color: #f5f5f7; }
  .pair__card--inverted .badge--neutral {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(245, 245, 247, 0.85);
  }
  .pair__t {
    font: 700 clamp(22px, 2.6vw, 28px)/1.2 var(--font);
    letter-spacing: -0.015em;
    color: var(--text);
    margin-top: 8px;
  }
  .pair__b {
    font: var(--t-body);
    color: var(--text-secondary);
    max-width: 42ch;
  }
  .pair__l {
    list-style: none; padding: 0; margin: 8px 0 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  .pair__l li {
    display: flex; align-items: center; gap: 10px;
    font: 500 14px/1.5 var(--font);
    color: var(--text);
  }
  .pair__cta {
    margin-top: auto;
    display: inline-flex; align-items: center; gap: 6px;
    font: 600 14px/1 var(--font);
    color: var(--accent);
    padding-top: 16px;
  }

  /* ===== Benefits grid — title-only chips (source-faithful: iastaffing.com
   * lists benefits as titles only, no body copy on the source page). ===== */
  .benefits {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 12px;
  }
  .benefit {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 24px;
  }
  .benefit__icon {
    width: 36px; height: 36px;
    border-radius: var(--r-xs);
    background: var(--accent-bg);
    display: grid; place-items: center;
    flex-shrink: 0;
  }
  .benefit__t {
    font: 600 15px/1.3 var(--font);
    color: var(--text);
    margin: 0;
  }
  /* Suppress hover lift on cards that aren't clickable (benefits, mission,
   * testimonials) — Apple HIG reserves motion for interactive surfaces. */
  .card--static:hover {
    transform: none;
    box-shadow: var(--shadow);
    border-color: var(--border);
  }

  /* ===== Process steps ===== */
  .process-wrap {
    background: var(--bg-alt);
    border-radius: var(--r-xl);
    margin-inline: var(--gutter);
    max-width: calc(var(--maxw) - 2 * var(--gutter));
    margin-left: auto; margin-right: auto;
    padding-inline: clamp(28px, 4vw, 56px);
  }
  .process {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    counter-reset: step;
  }
  .step { display: flex; flex-direction: column; gap: 10px; }
  .step__n {
    font: 700 32px/1 var(--font);
    color: var(--accent);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .step__t {
    font: 600 17px/1.3 var(--font);
    color: var(--text);
  }
  .step__b {
    font: var(--t-body-sm);
    color: var(--text-secondary);
  }

  /* ===== Mission grid ===== */
  .mission {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .mission__c { display: flex; flex-direction: column; gap: 10px; }
  .mission__t {
    font: 600 17px/1.3 var(--font);
    color: var(--text);
  }
  .mission__b {
    font: var(--t-body-sm);
    color: var(--text-secondary);
  }

  /* ===== Testimonials ===== */
  .quotes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .quote {
    display: flex; flex-direction: column;
    gap: 16px;
    background: var(--bg-card);
  }
  .quote__q {
    margin: 0;
    font: 400 16px/1.55 var(--font);
    color: var(--text);
  }
  .quote__by {
    display: flex; flex-direction: column;
    gap: 2px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .quote__name {
    font: 600 15px/1.3 var(--font);
    color: var(--text);
  }
  .quote__role {
    font: 500 13px/1.3 var(--font);
    color: var(--text-secondary);
  }

  /* ===== Closing CTA ===== */
  .cta {
    background: var(--bg-alt);
    border-radius: var(--r-xl);
    padding: clamp(36px, 5vw, 56px);
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(32px, 4vw, 48px);
    align-items: center;
  }
  .cta__h {
    font: 700 clamp(24px, 3.4vw, 36px)/1.15 var(--font);
    letter-spacing: -0.015em;
    margin-top: 12px;
    color: var(--text);
    text-wrap: balance;
  }
  .cta__b {
    font: var(--t-body-lg);
    color: var(--text-secondary);
    margin-top: 16px;
    max-width: 48ch;
  }
  .cta__row { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
  .cta__card { background: var(--bg-card); padding: 24px; }
  .cta__card__h {
    font: 600 16px/1.3 var(--font);
    color: var(--text);
    margin-bottom: 8px;
  }
  .cta__card__row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 10px 0;
    border-top: 1px solid var(--border);
    font: 500 13px/1.4 var(--font);
    color: var(--text-secondary);
  }
  .cta__card__row b {
    font: 600 13px/1.4 var(--font);
    color: var(--text);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .pair, .cta { grid-template-columns: 1fr; }
    .process { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .process { grid-template-columns: 1fr; }
    .hero__h { max-width: 100%; }
    .cta__card { padding: 20px; }
  }
</style>
