---
/*
 * Homepage — Chromia-Cream / Magenta-Noir. Ported from the IMS Design System V3
 * kit (ui_kits/website/*). Section order follows the kit's App.jsx home route:
 *   Hero → Marquee → Positioning → AudienceSplit → Compare → CTABand →
 *   ProcessSteps → SpecialtyGrid → ValuesGrid → ContactPanel
 *
 * All styling resolves from the global kit CSS (src/styles/*). Behaviors are
 * zero-JS: the hero rotating word is a CSS-only keyframe cycle; the contact
 * form does a native POST. The kit's React router/tweaks panel are dropped.
 *
 * prerender=false preserved so `/` keeps routing through src/middleware.ts for
 * the canonical 301 to imstaffing.ai (pages.dev + legacy
 * innovativemedicalstaffing.com → imstaffing.ai; Phase 1.0 + 2026-06-11 flip).
 *
 * NOTE (content pass): demo content (named hospitals, role/candidate cards,
 * "open this week" counts, specialty counts) is replicated from the kit per the
 * exact-replication directive; gated from indexed production until reconciled.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
import MarqueeStrip from '../components/sections/MarqueeStrip.astro';
import ContactPanel from '../components/sections/ContactPanel.astro';
import { createClient } from '@supabase/supabase-js';
import { countMatching, type JobSearchFields } from '../lib/job-search';

export const prerender = false;

const ROTATING_WORDS = ['Personal', 'Curated', 'Thoughtful', 'Human'];
const widestWord = ROTATING_WORDS.reduce((a, b) => (a.length > b.length ? a : b));

const stats = [
  { num: '47',   label: 'States staffed',        tint: 'coral'  },
  { num: '2022', label: 'Founded',               tint: 'butter' },
  { num: 'All',  label: 'Specialties',           tint: 'mint'   },
  { num: '1:1',  label: 'Recruiter per clinician', tint: 'lilac'  },
];

const compareRows = [
  ['Below average industry rates',      'Highly competitive pay'],
  ['Overcomplicated communication',     'One recruiter who knows your file'],
  ['Redundant onboarding processes',    'Streamlined onboarding process'],
  ['Lack of licensing support',         'Comprehensive assignment support'],
  ['Mediocre credentialing assistance', 'Your own dedicated support team'],
  ['Mismatched job placements',         'Tailored assignments to best suit you'],
  ['Treated like just another number',  'Family-oriented approach'],
];

// Editorial specialty cards. `query` is the search term the card deep-links to
// (/jobs?q=) AND the term we count against the live feed, so the "N open" count
// shown here equals what /jobs renders for the same query. See countMatching.
const specialties = [
  { n: '01', title: 'Anesthesia',        body: 'MDs, CRNAs, AAs. Our origin specialty, deepest expertise.',                   query: 'anesth',            tint: 'coral'  },
  { n: '02', title: 'OB-GYN',            body: 'Generalist, MFM, GYN-only call. Surgery centers and hospitals.',              query: 'ob-gyn',            tint: 'rose'   },
  { n: '03', title: 'Urology',           body: 'General + robotic. Outpatient and hospital coverage.',                       query: 'urolog',            tint: 'butter' },
  { n: '04', title: 'Emergency',         body: 'MDs, APPs, Pediatric EM. 12-hour blocks, rural and urban.',                  query: 'emergency',         tint: 'mint'   },
  { n: '05', title: 'Internal Medicine', body: 'Hospitalist, outpatient, rounding-only. Short and long-stay coverage.', query: 'internal medicine', tint: 'sky'    },
  { n: '06', title: 'Surgery',           body: 'General, ortho, cardio, vascular. Long-stay and call coverage.',              query: 'surg',              tint: 'lilac'  },
  { n: '07', title: 'Radiology',         body: 'Diagnostic and IR. Remote-read assignments available.',                      query: 'radiolog',          tint: 'coral'  },
  { n: '08', title: 'Psychiatry',        body: 'Inpatient, consult-liaison, telepsych.',                                     query: 'psych',             tint: 'butter' },
];

const values = [
  { title: 'Three, not thirty.',       tint: 'coral',  body: 'We send a few vetted candidates, not a stack of resumes. The work happens before the email, in conversations with clinicians we already know.' },
  { title: 'One recruiter, for life.', tint: 'butter', body: 'No rotating account reps. The person who places you for your first assignment is the person who calls you for your fifteenth.' },
  { title: 'A real human answers.',    tint: 'mint',   body: 'Call and a person picks up. We respond within one business day, every day of the week, weekends included. No queue, no ticket number, no chatbot.' },
];

const calDays = Array.from({ length: 30 }, (_, i) => i + 1);

// ── Live feed (Supabase ims_jobs) ──────────────────────────────────────────
// Same read as /jobs (src/pages/jobs/index.astro): active assignments only,
// newest first. SSR (prerender=false) so new LS events surface without a
// rebuild. public_facility_label is the PUBLIC field; facility_name is never
// read. Failure degrades to an empty feed (cards fall back gracefully) rather
// than crashing the homepage.
interface HomeJob extends JobSearchFields {
  id: string;
}
interface PagesEnv {
  SUPABASE_URL?: string;
  SUPABASE_SERVICE_ROLE_KEY?: string;
}

const cfEnv = (Astro.locals as { runtime?: { env?: PagesEnv } }).runtime?.env;
const env: PagesEnv = cfEnv ?? {
  SUPABASE_URL: import.meta.env.SUPABASE_URL,
  SUPABASE_SERVICE_ROLE_KEY: import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
};

let activeJobs: HomeJob[] = [];
if (env.SUPABASE_URL && env.SUPABASE_SERVICE_ROLE_KEY) {
  try {
    const supabase = createClient(env.SUPABASE_URL, env.SUPABASE_SERVICE_ROLE_KEY, {
      auth: { persistSession: false, autoRefreshToken: false },
    });
    const { data, error } = await supabase
      .from('ims_jobs')
      .select(
        'id, specialty_slug, specialty_name, facility_state, facility_city, public_facility_label, length_category, call_type, coverage_type',
      )
      .eq('status', 'active')
      .order('ls_last_modified', { ascending: false, nullsFirst: false })
      .limit(1000);
    if (error) {
      console.error('[/] homepage feed read failed:', error.message);
    } else if (data) {
      activeJobs = data as HomeJob[];
    }
  } catch (e) {
    console.error('[/] homepage feed client crash:', e);
  }
} else {
  console.warn('[/] supabase env not configured — homepage feed empty');
}

const titleCase = (s: string) => s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
const lengthDisplay = (c: string | null | undefined) =>
  c ? c.charAt(0).toUpperCase() + c.slice(1) : '';
const locationOf = (j: HomeJob) =>
  [j.facility_city, j.facility_state].filter(Boolean).join(', ') || j.public_facility_label || 'Nationwide';

// "Open this week" — the 3 most-recent real assignments, linked to their detail
// page. Real fields only (no fabricated pay/weeks).
const openThisWeek = activeJobs.slice(0, 3).map((j) => {
  const spec = j.specialty_name ?? titleCase(j.specialty_slug);
  const loc = locationOf(j);
  const label = j.public_facility_label && j.public_facility_label !== loc ? j.public_facility_label : null;
  const sub = [label, lengthDisplay(j.length_category)].filter(Boolean).join(' · ') || 'Rate on request';
  return { id: j.id, title: `${spec} · ${loc}`, sub };
});

// Editorial specialty cards with REAL counts from the live feed.
const specialtyCards = specialties.map((s) => ({ ...s, count: countMatching(activeJobs, s.query) }));
---
<MarketingLayout
  title="Innovative Medical Staffing — A More Personal Way to Staff Care"
  description="A boutique, family-style approach to locum staffing — connecting clinicians and facilities with the care, speed, and concierge support they deserve."
  inCard={false}
>
  <SiteNav slot="nav" />

  <!-- ============================ HERO ============================ -->
  <section class="section section--cream hero hero--center" aria-labelledby="hero-headline">
    <div class="hero__blob hero__blob--coral" aria-hidden="true"></div>
    <div class="hero__blob hero__blob--butter" aria-hidden="true"></div>
    <div class="hero__blob hero__blob--lilac" aria-hidden="true"></div>

    <div class="container hero__inner hero-stage">
      <div class="eyebrow hero__eyebrow" style="--i:0"><span class="eyebrow__dot"></span>Locum tenens · est. 2022</div>
      <h1 class="hero__headline" id="hero-headline" style="--i:1">
        A More <span class="hero__rotator" aria-label={ROTATING_WORDS[0]}>
          {ROTATING_WORDS.map((w) => (
            <span class="hero__rotator-word" aria-hidden="true">{w}</span>
          ))}
          <span class="hero__rotator-sizer" aria-hidden="true">{widestWord}</span>
        </span>
        <br />
        Way to Staff Care.
      </h1>
      <p class="hero__sub" style="--i:2">
        A boutique, family-style approach to locum staffing, connecting clinicians and facilities with the care, speed, and country-club-level concierge support they deserve.
      </p>
      <div class="hero__cta-row" role="group" aria-label="Primary actions" style="--i:3">
        <a class="pill pill--swing" href="/facilities">
          For Facilities
          <span class="pill__puck" aria-hidden="true">→</span>
        </a>
        <a class="pill pill--swing pill--swing--mint" href="/clinicians">
          For Clinicians
          <span class="pill__puck" aria-hidden="true">→</span>
        </a>
      </div>
      <div class="hero__scroll-hint" aria-hidden="true">
        <span>Scroll to explore</span>
        <span class="hero__scroll-arrow">↓</span>
      </div>
    </div>
  </section>

  <!-- ========================== MARQUEE =========================== -->
  <MarqueeStrip />

  <!-- ======================== POSITIONING ========================= -->
  <section class="section section--ink section--sm" aria-label="Company at a glance">
    <div class="container">
      <div class="positioning reveal-group">
        {stats.map((s, i) => (
          <div class:list={['statchip', 'reveal']} style={`--i:${i}`}>
            <div class={`statchip__num statchip__num--${s.tint} tabular`}>{s.num}</div>
            <div class="statchip__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================== AUDIENCE SPLIT ========================= -->
  <section class="section section--cream audience-mix-section" aria-labelledby="audience-anchor">
    <div class="container">
      <div class="section-anchor reveal-group">
        <div class="reveal" style="--i:0">
          <span class="eyebrow"><span class="eyebrow__dot"></span>§ 02 · Two audiences</span>
          <h2 class="section-anchor__heading" id="audience-anchor">Built for <span class="em">both</span> sides of the room.</h2>
        </div>
        <p class="section-anchor__sub reveal" style="--i:1">
          Most agencies write to a hypothetical "everyone." We don't. Whether you're staffing a unit or looking for your next assignment, you get a straight answer and one person who owns it.
        </p>
      </div>

      <div class="aud-mix reveal-group" role="group" aria-label="Audience options">
        <article class="aud-mix__card aud-mix__card--fac reveal reveal--left" tabindex="0" style="--i:0">
          <span class="aud-mix__chip">For facilities · 01</span>
          <h3 class="aud-mix__title">Curated,<br /><span>not volume</span>.</h3>
          <p class="aud-mix__body">
            Three vetted candidates. One account lead. Credentialing typically lands in under 60 days — with emergency credentialing when a start can't wait — and we keep the date on track.
          </p>
          <div class="aud-mix__roles">
            <span class="aud-mix__roles-label">Recently placed</span>
            <div class="role-card">
              <div class="role-card__avatar" style="background: var(--pop-rose)">JM</div>
              <div class="role-card__main">
                <b>Dr. Jordan M.</b>
                <small>Anesthesia · 10y · Open call</small>
              </div>
            </div>
            <div class="role-card">
              <div class="role-card__avatar" style="background: var(--pop-butter); color: var(--ink)">KR</div>
              <div class="role-card__main">
                <b>Dr. Kavi R., CRNA</b>
                <small>Anesthesia · 14y · Available now</small>
              </div>
            </div>
            <div class="role-card">
              <div class="role-card__avatar" style="background: var(--pop-coral)">SP</div>
              <div class="role-card__main">
                <b>Dr. Sara P.</b>
                <small>OB-GYN · 8y · Texas-based</small>
              </div>
            </div>
          </div>
          <a class="pill pill--swing aud-mix__cta" href="/facilities">
            Hire a clinician
            <span class="pill__puck" aria-hidden="true">→</span>
          </a>
        </article>

        <article class="aud-mix__card aud-mix__card--cli reveal reveal--right" tabindex="0" style="--i:1">
          <span class="aud-mix__chip">For clinicians · 02</span>
          <h3 class="aud-mix__title">One recruiter,<br /><span>for life</span>.</h3>
          <p class="aud-mix__body">
            Not a rotating queue. One recruiter who knows your specialty, your geography, your preferred call structure — and treats you like family.
          </p>
          <div class="aud-mix__roles">
            <span class="aud-mix__roles-label">Open this week</span>
            {openThisWeek.length > 0 ? openThisWeek.map((j) => (
              <a class="role-card" href={`/jobs/${j.id}`} aria-label={`${j.title} — view assignment`}>
                <div class="role-card__main">
                  <b>{j.title}</b>
                  <small>{j.sub}</small>
                </div>
                <span class="role-card__dot" aria-hidden="true"></span>
              </a>
            )) : (
              <a class="role-card" href="/jobs" aria-label="Browse the live job board">
                <div class="role-card__main">
                  <b>New roles every week</b>
                  <small>Browse the live board</small>
                </div>
                <span class="role-card__dot" aria-hidden="true"></span>
              </a>
            )}
          </div>
          <a class="pill pill--swing pill--swing--magenta aud-mix__cta" href="/clinicians">
            Find your assignment
            <span class="pill__puck" aria-hidden="true">→</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ========================== COMPARE =========================== -->
  <section class="section section--cream compare" aria-labelledby="compare-anchor">
    <div class="container">
      <div class="section-anchor reveal-group">
        <div class="reveal" style="--i:0">
          <span class="eyebrow"><span class="eyebrow__dot"></span>§ 03 · How we're different</span>
          <h2 class="section-anchor__heading" id="compare-anchor">The way most <span class="em">aren't</span>.</h2>
        </div>
        <p class="section-anchor__sub reveal" style="--i:1">
          Locum staffing has a default mode. We don't operate in it.
        </p>
      </div>

      <div class="compare__grid reveal-group">
        <div class="compare__col compare__col--old reveal reveal--left" style="--i:0">
          <div class="compare__header">
            <span class="compare__tag">The default</span>
            <h3 class="compare__heading">Other agencies</h3>
          </div>
          <ul class="compare__list">
            {compareRows.map((r) => (
              <li class="compare__item compare__item--bad">
                <span class="compare__mark compare__mark--x" aria-hidden="true">✕</span>
                <span>{r[0]}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="compare__col compare__col--ims reveal reveal--right" style="--i:1">
          <div class="compare__header">
            <span class="compare__tag compare__tag--pop">The IMS way</span>
            <h3 class="compare__heading">Innovative Medical Staffing</h3>
          </div>
          <ul class="compare__list">
            {compareRows.map((r) => (
              <li class="compare__item compare__item--good">
                <span class="compare__mark compare__mark--check" aria-hidden="true">✓</span>
                <span>{r[1]}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================== CTA BAND ========================== -->
  <section class="section section--butter cta-band" aria-labelledby="cta-band-anchor">
    <div class="cta-pop cta-pop--tl" aria-hidden="true">
      <div class="cta-pop__pill" style="background: var(--mn-black, #0A0A0F); color: var(--mn-cream, #F4ECDF)">● Live phone line</div>
    </div>
    <div class="cta-pop cta-pop--tr" aria-hidden="true">
      <div class="cta-pop__pill" style="background: var(--mn-black, #0A0A0F); color: var(--mn-cream, #F4ECDF)">★ Replies within one business day</div>
    </div>
    <div class="cta-pop cta-pop--bl" aria-hidden="true">
      <div class="cta-pop__card">
        <div class="cta-pop__card-eyebrow">Same name</div>
        <div class="cta-pop__card-line">Every call</div>
      </div>
    </div>
    <div class="cta-pop cta-pop--br" aria-hidden="true">
      <div class="cta-pop__card">
        <div class="cta-pop__card-eyebrow">No AI</div>
        <div class="cta-pop__card-line">Just humans</div>
      </div>
    </div>

    <div class="container cta-band__inner reveal-group">
      <span class:list={['eyebrow', 'reveal']} style="--i:0"><span class="eyebrow__dot" style="background: var(--mn-black, #0A0A0F)"></span>Skip ahead</span>
      <h2 class:list={['cta-band__headline', 'reveal']} id="cta-band-anchor" style="--i:1">
        Tell us what you <span class="em">need</span>.
      </h2>
      <p class:list={['cta-band__sub', 'reveal']} style="--i:2">
        The fastest path is a conversation. We answer messages within one business day, every day of the week, weekends included.
      </p>
      <a class:list={['pill', 'pill--swing', 'pill--swing--magenta', 'reveal']} href="/contact" style="--i:3">
        Start a conversation
        <span class="pill__puck" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- ======================== PROCESS STEPS ======================= -->
  <section class="section section--lilac process-section" aria-labelledby="process-anchor">
    <div class="container">
      <div class="section-anchor reveal-group">
        <div class="reveal" style="--i:0">
          <span class="eyebrow"><span class="eyebrow__dot" style="background: var(--pop-magenta)"></span>§ 04 · The process</span>
          <h2 class="section-anchor__heading" id="process-anchor">Three steps, <span class="em" style="color: var(--pop-magenta)">nothing</span> hidden.</h2>
        </div>
        <p class="section-anchor__sub reveal" style="--i:1">
          Same process whether you're a 240-bed acute-care hospital or a CRNA looking for a long-stay placement.
        </p>
      </div>

      <div class="process-cards reveal-group">
        <article class="proc-card proc-card--brief reveal" style="--i:0">
          <div class="proc-card__badge">Step 01</div>
          <h3 class="proc-card__title">Tell us what you <span style="color: var(--ink-emphasis)">need</span>.</h3>
          <p class="proc-card__body">Coverage to fill or an assignment to find — specialty, geography, schedule, call structure, EMR. The actual details.</p>
          <div class="proc-card__art proc-card__art--form" aria-hidden="true">
            <div class="proc-mock__row"><span class="proc-mock__label">Specialty</span><span class="proc-mock__field">Anesthesiology</span></div>
            <div class="proc-mock__row"><span class="proc-mock__label">Location</span><span class="proc-mock__field">Austin, TX</span></div>
            <div class="proc-mock__row"><span class="proc-mock__label">Start</span><span class="proc-mock__field">June 15</span></div>
            <div class="proc-mock__row"><span class="proc-mock__label">Length</span><span class="proc-mock__field">12 weeks</span></div>
          </div>
        </article>

        <article class="proc-card proc-card--shortlist reveal" style="--i:1">
          <div class="proc-card__badge" style="background: var(--pop-mint); color: var(--ink)">Step 02</div>
          <h3 class="proc-card__title">A curated <span style="color: var(--ink-emphasis)">shortlist</span>.</h3>
          <p class="proc-card__body">A few that fit, not a stack to sort. Facilities get vetted candidates; clinicians get assignments matched to them.</p>
          <div class="proc-card__art proc-card__art--stack" aria-hidden="true">
            <div class="cand-card cand-card--3" style="background: var(--soft-rose)">
              <div class="cand-card__avatar" style="background: var(--pop-rose)">JM</div>
              <div class="cand-card__name">Dr. Jordan M.</div>
              <div class="cand-card__meta">10y · Open call</div>
            </div>
            <div class="cand-card cand-card--2" style="background: var(--soft-butter)">
              <div class="cand-card__avatar" style="background: var(--pop-butter); color: var(--ink)">KR</div>
              <div class="cand-card__name">Dr. Kavi R.</div>
              <div class="cand-card__meta">14y · Available now</div>
            </div>
            <div class="cand-card cand-card--1" style="background: var(--cream-soft)">
              <div class="cand-card__avatar" style="background: var(--pop-mint); color: var(--ink)">SP</div>
              <div class="cand-card__name">Dr. Sara P.</div>
              <div class="cand-card__meta">8y · Texas-based</div>
            </div>
          </div>
        </article>

        <article class="proc-card proc-card--start reveal" style="--i:2">
          <div class="proc-card__badge" style="background: var(--pop-coral); color: var(--cream-soft)">Step 03</div>
          <h3 class="proc-card__title">Meet, choose, <span style="color: var(--ink-emphasis)">start</span>.</h3>
          <p class="proc-card__body">Credentialing typically lands in under 60 days, with emergency credentialing when a start can't wait. We keep the paperwork moving so the start date holds.</p>
          <div class="proc-card__art proc-card__art--calendar" aria-hidden="true">
            <div class="cal-mock">
              <div class="cal-mock__header">
                <span>JUN</span>
                <span class="cal-mock__year">2026</span>
              </div>
              <div class="cal-mock__grid">
                {calDays.map((day) => (
                  <div class={`cal-mock__cell ${day === 15 ? 'is-mark' : ''} ${day < 15 ? 'is-before' : ''}`}>
                    {day === 15 ? '✓' : day}
                  </div>
                ))}
              </div>
              <div class="cal-mock__caption">First shift</div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ======================= SPECIALTY GRID ======================= -->
  <section class="section section--cream" aria-labelledby="spec-anchor">
    <div class="container">
      <div class="section-anchor reveal-group">
        <div class="reveal" style="--i:0">
          <span class="eyebrow"><span class="eyebrow__dot"></span>§ 04 · The daily six (and then some)</span>
          <h2 class="section-anchor__heading" id="spec-anchor">Where we live <span class="em">deepest</span>.</h2>
        </div>
        <p class="section-anchor__sub reveal" style="--i:1">
          Anesthesia is the origin. Everything else is built on the same recruiter-led, curated model.
        </p>
      </div>
      <div class="spec-grid reveal-group">
        {specialtyCards.map((s, i) => (
          <a
            class:list={['spec-card', `spec-card--${s.tint}`, 'reveal']}
            style={`--i:${Math.min(i,5)}`}
            href={`/jobs?q=${encodeURIComponent(s.query)}`}
            aria-label={`${s.title} — ${s.count > 0 ? `${s.count} open this week` : 'roles open soon'}, view on the job board`}
          >
            <div class="spec-card__number">Nº {s.n}</div>
            <h3 class="spec-card__title">{s.title}</h3>
            <p class="spec-card__body">{s.body}</p>
            <div class="spec-card__count">
              <span class="spec-card__dot" aria-hidden="true"></span>
              {s.count > 0 ? `${s.count} open this week` : 'Roles open soon'}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= VALUES GRID ======================== -->
  <section class="section section--cream" aria-labelledby="values-anchor">
    <div class="container">
      <div class="section-anchor reveal-group">
        <div class="reveal" style="--i:0">
          <span class="eyebrow"><span class="eyebrow__dot"></span>§ 06 · How we operate</span>
          <h2 class="section-anchor__heading" id="values-anchor">Three rules we won't <span class="em">break</span>.</h2>
        </div>
        <p class="section-anchor__sub reveal" style="--i:1">
          Everything else is negotiable. These aren't.
        </p>
      </div>
      <div class="values reveal-group">
        {values.map((v, i) => (
          <article class:list={['value-card', `value-card--${v.tint}`, 'reveal']} style={`--i:${i}`}>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================== CONTACT =========================== -->
  <div class="scroll-reveal">
    <ContactPanel />
  </div>

  <SiteFooter slot="footer" />
</MarketingLayout>

<!-- The "Open this week" role-cards and the specialty cards are now real links
     into the live job board. They keep the kit's card visuals (the <a> carries
     the same .role-card / .spec-card class); this only strips anchor defaults.
     is:global because both are rendered inside {map()} expressions (same Astro
     scoping caveat as /jobs). Selectors are anchor-scoped so nothing else moves. -->
<style is:global>
  a.role-card,
  a.spec-card { text-decoration: none; color: inherit; cursor: pointer; }
</style>
