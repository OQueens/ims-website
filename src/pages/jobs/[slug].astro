---
/**
 * /jobs/[slug] — Job detail click-through (design_handoff_job_board).
 *
 * SSR (prerender=false): reads ONE ims_jobs row by id (the slug) from Supabase
 * and renders the tone-tinted hero + 4-stat strip + about/highlights/facility
 * panels + a dark sticky "Ask about this role" apply rail (reuses the /contact
 * dark-form aesthetic + fireConfetti).
 *
 * No fabrication (hard project rule + the listing's own contract):
 *  - pay shows "Rate on request" (the LocumSmart feed carries no rate);
 *  - the public/internal boundary is preserved (never facility_name — only
 *    facility_city/state + public_facility_label);
 *  - every panel/stat renders REAL fields and gracefully omits nulls, so a
 *    sparse assignment still reads well.
 *
 * Apply posts to the existing /api/contact pipeline (Turnstile + durable
 * capture + Resend) with the role + assignment ref folded into the submission,
 * so the lead is tied to this exact role and lands in ims_contact_messages +
 * the recruiter inbox. No new endpoint needed for v1.
 *
 * Slug = the job's uuid (robust + guaranteed unique). Readable slugs are a
 * later enhancement; the listing links each card to /jobs/<id>.
 */
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import SiteFooter from '../../components/footer/SiteFooter.astro';
import TurnstileWidget from '../../components/forms/TurnstileWidget.astro';
import { createClient } from '@supabase/supabase-js';

export const prerender = false;

interface PagesEnv {
  SUPABASE_URL?: string;
  SUPABASE_SERVICE_ROLE_KEY?: string;
}

interface JobDetail {
  id: string;
  assignment_number: string | null;
  specialty_name: string | null;
  specialty_slug: string | null;
  provider_type: string | null;
  facility_city: string | null;
  facility_state: string | null;
  public_facility_label: string | null;
  num_providers_requested: number | null;
  start_date: string | null;
  duration_display: string | null;
  length_category: string | null;
  coverage_type: string | null;
  call_type: string | null;
  request_type: string | null;
  practice_setting: string | null;
  public_description: string | null;
  emr_system: string | null;
  board_certification_required: boolean | null;
  board_certification_minimum: string | null;
  fellowship: string | null;
  require_bls: boolean | null;
  require_acls: boolean | null;
  require_atls: boolean | null;
  require_pals: boolean | null;
  trauma_level: number | null;
  patient_encounters_per_shift: string | null;
  estimated_credentialing_time: string | null;
  temporary_privileges_available: boolean | null;
  call_ratio: string | null;
}

const { slug } = Astro.params;

const cfEnv = (Astro.locals as { runtime?: { env?: PagesEnv } }).runtime?.env;
const env: PagesEnv = cfEnv ?? {
  SUPABASE_URL: import.meta.env.SUPABASE_URL,
  SUPABASE_SERVICE_ROLE_KEY: import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
};

// A valid slug is a uuid; reject anything else before hitting Supabase (an
// invalid uuid would make the query throw, which we'd treat as not-found anyway).
const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

let job: JobDetail | null = null;
if (slug && UUID_RE.test(slug) && env.SUPABASE_URL && env.SUPABASE_SERVICE_ROLE_KEY) {
  try {
    const supabase = createClient(env.SUPABASE_URL, env.SUPABASE_SERVICE_ROLE_KEY, {
      auth: { persistSession: false, autoRefreshToken: false },
    });
    const { data, error } = await supabase
      .from('ims_jobs')
      .select(
        'id, assignment_number, specialty_name, specialty_slug, provider_type, facility_city, facility_state, public_facility_label, num_providers_requested, start_date, duration_display, length_category, coverage_type, call_type, request_type, practice_setting, public_description, emr_system, board_certification_required, board_certification_minimum, fellowship, require_bls, require_acls, require_atls, require_pals, trauma_level, patient_encounters_per_shift, estimated_credentialing_time, temporary_privileges_available, call_ratio',
      )
      .eq('id', slug)
      .eq('status', 'active')
      .maybeSingle();
    if (error) {
      console.error('[/jobs/[slug]] supabase read failed:', error.message);
    } else if (data) {
      job = data as JobDetail;
    }
  } catch (e) {
    console.error('[/jobs/[slug]] supabase client crash:', e);
  }
}

// ── Not found ──────────────────────────────────────────────────────────────
if (!job) {
  Astro.response.status = 404;
}

// ── Field mapping (real data only; nulls omitted) ───────────────────────────
const TINTS = ['coral', 'rose', 'butter', 'mint', 'sky', 'lilac'] as const;
const SPEC_TINT: Record<string, (typeof TINTS)[number]> = {
  anesthesia: 'coral',
  'ob-gyn': 'rose',
  obgyn: 'rose',
  urology: 'butter',
  emergency: 'mint',
  'emergency-medicine': 'mint',
  'internal-medicine': 'sky',
  hospitalist: 'sky',
  surgery: 'lilac',
  'general-surgery': 'lilac',
  radiology: 'coral',
  psychiatry: 'butter',
};
const titleCase = (s: string) => s.replace(/[-_]/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
// LocumSmart feeds placeholder strings ("N/A", "None", "TBD") rather than nulls;
// treat those as empty so they never render as content.
const clean = (v: string | null | undefined): string => {
  const s = (v ?? '').trim();
  return /^(n\/?a|none|null|tbd|unknown|n\.a\.?)$/i.test(s) ? '' : s;
};
const anA = (s: string): string => (/^[aeiou]/i.test(s.trim()) ? 'an' : 'a');
// Render a call ratio ONLY when it's an unambiguous "1:N" — LS free-texts this
// field with junk ("100", "60%", "TBD", "*", "0", "varies"), so drop anything
// that isn't a clean ratio rather than show nonsense.
const cleanCallRatio = (r: string | null | undefined): string | null => {
  const m = /^1\s*[:/]\s*([1-9]\d?)$/.exec((r ?? '').trim());
  return m ? `1:${m[1]}` : null;
};

let tone: (typeof TINTS)[number] = 'coral';
let spec = '';
let cityTitle = 'Nationwide';
let ref: string | null = null;
let spots = 0;
let sub = '';
let stats: { label: string; value: string }[] = [];
let highlights: string[] = [];
let facility: { label: string; value: string }[] = [];
let aboutText = '';

if (job) {
  tone = (job.specialty_slug && SPEC_TINT[job.specialty_slug]) || 'coral';
  spec = [job.specialty_name ?? (job.specialty_slug ? titleCase(job.specialty_slug) : null), job.provider_type]
    .filter(Boolean)
    .join(' · ');
  cityTitle =
    [job.facility_city, job.facility_state].filter(Boolean).join(', ') ||
    job.public_facility_label ||
    'Nationwide';
  ref = job.assignment_number;
  spots = job.num_providers_requested ?? 0;

  // Hero sub: first sentence of the public description when present; otherwise
  // omit it (the pill + title + stats already carry the facts — a composed
  // restatement just reads as filler).
  const pubDesc = clean(job.public_description);
  if (pubDesc) {
    const first = pubDesc.split(/(?<=[.!?])\s/)[0]?.trim() ?? '';
    sub = first.length > 4 ? first : pubDesc.slice(0, 160).trim();
  } else {
    sub = '';
  }

  // Stat strip — labelled to the real fields we actually have.
  const lengthVal = clean(job.duration_display) || (job.length_category ? titleCase(job.length_category) : '');
  const coverageVal = [clean(job.coverage_type), clean(job.call_type)].filter(Boolean).join(' · ');
  let startVal = '';
  if (job.start_date) {
    const d = new Date(job.start_date + 'T00:00:00');
    if (!Number.isNaN(d.getTime())) {
      startVal = d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    }
  }
  stats = [
    { label: 'Coverage', value: coverageVal },
    { label: 'Length', value: lengthVal },
    { label: 'Openings', value: spots > 0 ? `${spots} ${spots === 1 ? 'spot' : 'spots'}` : '' },
    { label: 'Start', value: startVal || 'Flexible' },
  ].filter((s) => s.value);

  // Highlights — composed from real per-job fields + documented IMS benefits.
  const reqCerts = [
    job.require_bls && 'BLS',
    job.require_acls && 'ACLS',
    job.require_atls && 'ATLS',
    job.require_pals && 'PALS',
  ].filter(Boolean);
  // Anesthesiology + CRNA assignments carry the specialty-standard malpractice
  // limits ($1M per claim / $3M aggregate, tail included); every other specialty
  // just gets the true, figure-free "Malpractice covered".
  const isAnesthesia = job.specialty_slug === 'anesthesiology' || job.specialty_slug === 'crna';
  const callRatio = cleanCallRatio(job.call_ratio);
  highlights = [
    job.board_certification_required &&
      (/eligible/i.test(clean(job.board_certification_minimum))
        ? 'Board-certified or board-eligible'
        : `Board certification required${clean(job.board_certification_minimum) ? ` (${clean(job.board_certification_minimum)})` : ''}`),
    clean(job.fellowship) && `${titleCase(clean(job.fellowship))} fellowship`,
    typeof job.trauma_level === 'number' && job.trauma_level > 0 && `Level ${job.trauma_level} trauma center`,
    reqCerts.length > 0 && `${reqCerts.join(', ')} required`,
    job.temporary_privileges_available === true && 'Temporary privileges available',
    callRatio && `Call ratio ${callRatio}`,
    clean(job.estimated_credentialing_time) &&
      `Facility estimate: credentialing ~${clean(job.estimated_credentialing_time)}${/^\d+$/.test(clean(job.estimated_credentialing_time)) ? ' days' : ''}`,
    // Documented, true IMS benefits.
    isAnesthesia ? 'Malpractice coverage — $1M / $3M with tail' : 'Malpractice covered',
    'One recruiter for the life of your assignment',
    'Friday direct deposit, every week',
  ].filter((x): x is string => Boolean(x));

  // The facility — real fields, null rows omitted.
  facility = [
    { label: 'Setting', value: clean(job.practice_setting) ? titleCase(clean(job.practice_setting)) : '' },
    { label: 'Patients / shift', value: clean(job.patient_encounters_per_shift) },
    { label: 'EMR', value: clean(job.emr_system) },
    { label: 'Location', value: cityTitle },
  ].filter((f) => f.value);

  // About: the public description when present, else a factual summary composed
  // from the structured fields (prose-ifying real data; nothing invented). The
  // facility TYPE is grounded in the location so a generic public label (e.g.
  // "Hospital") reads as "...at a hospital in Portsmouth, NH" rather than the
  // old standalone "Hosted at a hospital." nonsense (Zach 2026-06-14).
  aboutText = clean(job.public_description);
  if (!aboutText) {
    const cap = (s: string) => (s ? s.charAt(0).toUpperCase() + s.slice(1) : s);
    const specHuman =
      clean(job.specialty_name) || (job.specialty_slug ? titleCase(job.specialty_slug) : 'Locum');
    const fac = clean(job.public_facility_label);
    // A generic category label (vs. a real facility name) — articled + lowercased.
    // NB: "regional / community / teaching / rural" are deliberately NOT prefixes
    // here — they belong to real hospital NAMES ("Portsmouth Regional Hospital")
    // far more than to standalone generic labels, so including them misclassified
    // named facilities (Codex/review fold 2026-06-14). A bare generic label still
    // matches via the terminal alternation.
    const GENERIC_FAC =
      /^((acute[- ]care|critical[- ]access|tertiary)\s+)*(hospital|medical\s+center|health(\s*(system|care))?(\s*(facility|center|system))?|clinic|surgery\s+center|ambulatory\s+surgery\s+center|asc|outpatient\s+(center|clinic)|practice|facility)$/i;
    const facIsName = Boolean(fac) && !GENERIC_FAC.test(fac);
    const where = cityTitle !== 'Nationwide' ? cityTitle : '';

    // S1 — what + where. The location grounds a generic facility type so it
    // never renders as an orphan "at a hospital." with no place attached.
    let s1: string;
    if (facIsName && where) s1 = `${specHuman} locum coverage at ${fac} in ${where}.`;
    else if (facIsName) s1 = `${specHuman} locum coverage at ${fac}.`;
    else if (fac && where) s1 = `${specHuman} locum coverage at ${anA(fac)} ${fac.toLowerCase()} in ${where}.`;
    else if (where) s1 = `${specHuman} locum coverage in ${where}.`;
    else s1 = `${specHuman} locum tenens assignment.`;

    // S2 — schedule: length + start + openings, only the parts we actually have.
    const sched: string[] = [];
    if (lengthVal) sched.push(lengthVal);
    if (startVal) sched.push(`starting ${startVal}`);
    if (spots > 0) sched.push(`${spots} ${spots === 1 ? 'opening' : 'openings'}`);
    const s2 = sched.length ? `${cap(sched.join(', '))}.` : '';

    // S3 — coverage / call model when present.
    const s3 = coverageVal ? `${cap(coverageVal)} coverage.` : '';

    aboutText = [s1, s2, s3].filter(Boolean).join(' ');
  }
}

const pageTitle = job ? `${spec || 'Open role'} · ${cityTitle} — Innovative Medical Staffing` : 'Role not found — Innovative Medical Staffing';
const pageDesc = job ? (sub || `Open locum assignment: ${spec} in ${cityTitle}.`) : 'That role is no longer listed.';
---

<MarketingLayout title={pageTitle} description={pageDesc} inCard={false}>
  <SiteNav slot="nav" />

  <div class="jd">
    <div class="container">
      {job ? (
        <>
          <a class="jd-back" href="/jobs"><span class="jd-back__arrow" aria-hidden="true">←</span> Back to all jobs</a>

          <!-- HERO -->
          <section class={`jd-hero jd-hero--${tone}`}>
            <div class="jd-hero__glow" aria-hidden="true"></div>
            <div class="jd-hero__top">
              <div class="jd-hero__tags">
                {spec && <span class="jd-hero__spec"><span class="jd-hero__spec-dot" aria-hidden="true"></span>{spec}</span>}
                {spots > 0 && <span class="jd-hero__badge">{spots} {spots === 1 ? 'spot' : 'spots'} open</span>}
              </div>
              {ref && <span class="jd-hero__ref">Ref {ref}</span>}
            </div>
            <h1 class="jd-hero__title">{cityTitle}</h1>
            {sub && <p class="jd-hero__sub">{sub}</p>}
          </section>

          <!-- STAT STRIP -->
          {stats.length > 0 && (
            <section class="jd-stats">
              {stats.map((s) => (
                <div class="jd-stat">
                  <span class="jd-stat__label">{s.label}</span>
                  <span class="jd-stat__value">{s.value}</span>
                </div>
              ))}
            </section>
          )}

          <!-- BODY -->
          <div class="jd-body">
            <div class="jd-main">
              {aboutText && (
                <section class="jd-panel">
                  <div class="jd-panel__head"><span class="jd-panel__label">About this assignment</span><span class="jd-panel__rule" aria-hidden="true"></span></div>
                  <p class="jd-panel__lede">{aboutText}</p>
                </section>
              )}

              {highlights.length > 0 && (
                <section class="jd-panel">
                  <div class="jd-panel__head"><span class="jd-panel__label">Highlights</span><span class="jd-panel__rule" aria-hidden="true"></span></div>
                  <ul class="jd-highlights">
                    {highlights.map((h) => (
                      <li class="jd-highlights__item"><span class="jd-highlights__arrow" aria-hidden="true">→</span>{h}</li>
                    ))}
                  </ul>
                </section>
              )}

              {facility.length > 0 && (
                <section class="jd-panel">
                  <div class="jd-panel__head"><span class="jd-panel__label">The facility</span><span class="jd-panel__rule" aria-hidden="true"></span></div>
                  <dl class="jd-facility">
                    {facility.map((f) => (
                      <div class="jd-facility__row">
                        <dt class="jd-facility__k">{f.label}</dt>
                        <dd class="jd-facility__v">{f.value}</dd>
                      </div>
                    ))}
                  </dl>
                </section>
              )}
            </div>

            <!-- STICKY APPLY RAIL (dark "talk to us" skin, reused from /contact) -->
            <aside class="jd-rail">
              <div class="jd-apply" id="jdApply">
                <div class="jd-apply__glow jd-apply__glow--a" aria-hidden="true"></div>
                <div class="jd-apply__glow jd-apply__glow--b" aria-hidden="true"></div>

                <div class="jd-apply__eyebrow"><span class="jd-apply__dot" aria-hidden="true"></span>Interested?</div>
                <h2 class="jd-apply__title">Ask about <em>this role</em>.</h2>
                <p class="jd-apply__sub">Send a note and your account lead will follow up with full details, within one business day.</p>

                <div class="jd-apply__chip">
                  <span class="jd-apply__chip-role">{[spec, cityTitle].filter(Boolean).join(' · ')}</span>
                  {ref && <span class="jd-apply__chip-id">{ref}</span>}
                </div>

                <form class="jd-form" id="jdApplyForm" method="post" action="/api/contact" novalidate>
                  <input type="hidden" name="audience" value="clinician" />
                  {/* role carries the assignment ref so even a no-JS native POST
                      (which can't run the message-composing script) captures
                      which exact role the inquiry is about. */}
                  <input type="hidden" name="role" value={ref ? `${spec} · Ref ${ref}` : spec} />
                  <input type="hidden" name="jobRole" value={spec} />
                  <input type="hidden" name="jobRef" value={ref ?? job.id} />
                  <input type="hidden" name="jobCity" value={cityTitle} />
                  {/* The uuid slug → the server builds a TRUSTED direct link to
                      THIS posting for the recruiter email (see /api/contact); the
                      client never supplies the URL, so it can't be tampered. */}
                  <input type="hidden" name="jobSlug" value={job.id} />

                  <div class="jd-field">
                    <label for="jdName">Your name</label>
                    <input id="jdName" name="name" type="text" placeholder="Your name" required />
                  </div>
                  <div class="jd-field">
                    <label for="jdEmail">Email</label>
                    <input id="jdEmail" name="email" type="email" placeholder="Email" required />
                  </div>
                  <div class="jd-field">
                    <label for="jdPhone">Phone <span class="jd-hint">(optional)</span></label>
                    <input id="jdPhone" name="phone" type="tel" placeholder="Phone (optional)" />
                  </div>
                  <div class="jd-field">
                    <label for="jdMessage">Anything you'd like us to know? <span class="jd-hint">(optional)</span></label>
                    <textarea id="jdMessage" name="message" placeholder="Anything you'd like us to know? (optional)"></textarea>
                  </div>

                  <!-- Honeypot — off-screen, never display:none. NO <label> and
                       named `website_url` (not "company") so password managers /
                       browser autofill don't fill it and silently drop a real
                       lead (INC-2). -->
                  <div class="jd-hp" aria-hidden="true">
                    <input id="jdWebsiteUrl" name="website_url" type="text" tabindex="-1" autocomplete="off" />
                  </div>

                  <TurnstileWidget form="#jdApplyForm" />

                  <p class="jd-form__error" id="jdError" role="alert" hidden>Something went wrong. Please email recruiting@iastaffing.com directly.</p>

                  <button class="jd-submit" type="submit">
                    Ask about this role <span class="jd-submit__puck" aria-hidden="true">→</span>
                  </button>
                  <p class="jd-fine">No commitment. We'll just reach out with details.</p>
                </form>
              </div>

              <!-- SUCCESS -->
              <div class="jd-sent" id="jdSent" role="status" aria-live="polite" tabindex="-1">
                <div class="jd-sent__check" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#0C1C30" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>
                </div>
                <h3 class="jd-sent__title">Request sent.</h3>
                <p class="jd-sent__body">Thanks for your interest in <strong>{[spec, cityTitle].filter(Boolean).join(' · ')}</strong>. Your account lead will reach out within one business day with the full details.</p>
                <a class="jd-sent__pill" href="/jobs">Browse more roles →</a>
              </div>
            </aside>
          </div>
        </>
      ) : (
        <section class="jd-404">
          <span class="jd-404__eyebrow">404</span>
          <h1 class="jd-404__title">We couldn't find that role.</h1>
          <p class="jd-404__body">It may have just been filled, or the link is out of date. Browse what's open now.</p>
          <a class="pill pill--swing pill--swing--magenta" href="/jobs"><span>Browse open jobs</span><span class="pill__puck" aria-hidden="true">→</span></a>
        </section>
      )}
    </div>
  </div>

  <canvas class="jd-confetti" id="jdConfetti" aria-hidden="true"></canvas>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  /* Tone tints (soft brand pastels from the active palette). The hero wears the
     job's tone as a soft wash + a stronger corner glow. */
  .jd-hero--coral  { --jd-tint: #FBD7CF; --jd-glow: rgba(242, 106, 91, 0.32); }
  .jd-hero--rose   { --jd-tint: #F3D2E5; --jd-glow: rgba(212, 86, 158, 0.34); }
  .jd-hero--butter { --jd-tint: #F8E2B8; --jd-glow: rgba(242, 160, 61, 0.36); }
  .jd-hero--mint   { --jd-tint: #C5E9D4; --jd-glow: rgba(61, 190, 133, 0.28); }
  .jd-hero--sky    { --jd-tint: #CDE9F5; --jd-glow: rgba(63, 179, 224, 0.28); }
  .jd-hero--lilac  { --jd-tint: #D9DCF7; --jd-glow: rgba(124, 132, 232, 0.26); }

  .jd { padding: var(--space-7) 0 var(--space-10); }

  .jd-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.04em;
    color: var(--ink-soft); text-decoration: none; margin-bottom: var(--space-5);
    transition: gap var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .jd-back:hover { color: var(--ink); gap: 12px; }
  .jd-back__arrow { transition: transform var(--dur-fast) var(--ease-out); }

  /* ── Hero ── */
  .jd-hero {
    position: relative; overflow: hidden;
    background: var(--jd-tint);
    border-radius: 28px;
    padding: clamp(28px, 4vw, 52px);
    margin-bottom: var(--space-4);
  }
  .jd-hero__glow {
    position: absolute; top: -120px; right: -100px; width: 520px; height: 420px;
    background: radial-gradient(closest-side, var(--jd-glow), transparent 72%);
    pointer-events: none;
  }
  .jd-hero__top { position: relative; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 22px; }
  .jd-hero__tags { display: flex; flex-wrap: wrap; gap: 10px; }
  .jd-hero__spec {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(31, 26, 35, 0.06); border: 1px solid rgba(31, 26, 35, 0.14);
    border-radius: 999px; padding: 7px 15px;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase; font-weight: 700; color: var(--ink);
  }
  .jd-hero__spec-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--sky, #3FB3E0); }
  .jd-hero__badge {
    display: inline-flex; align-items: center; border-radius: 999px;
    background: var(--ink); color: var(--cream-soft);
    padding: 7px 15px; font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700;
  }
  .jd-hero__ref { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.08em; color: var(--ink-mute); white-space: nowrap; flex-shrink: 0; }
  .jd-hero__title {
    position: relative; font-family: var(--font-display); font-weight: 900;
    font-size: clamp(44px, 6.5vw, 92px); line-height: 1.02; letter-spacing: -0.035em;
    color: var(--ink); margin: 0 0 16px; max-width: 16ch;
  }
  .jd-hero__sub { position: relative; font-family: var(--font-body); font-size: clamp(16px, 2vw, 19px); line-height: 1.55; color: var(--ink-soft); max-width: 52ch; margin: 0 0 28px; }
  .jd-hero__pay { position: relative; display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
  .jd-hero__pay-fig { font-family: var(--font-display); font-weight: 900; font-size: clamp(30px, 4vw, 46px); letter-spacing: -0.03em; color: var(--ink); }
  .jd-hero__pay-note { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.02em; color: var(--ink-mute); }

  /* ── Stat strip ── */
  .jd-stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--rule); border-radius: 18px; overflow: hidden;
    background: var(--cream-soft); margin-bottom: var(--space-6);
  }
  .jd-stat { padding: 20px 22px; border-left: 1px solid var(--rule); }
  .jd-stat:first-child { border-left: 0; }
  .jd-stat__label { display: block; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700; color: var(--ink-mute); margin-bottom: 8px; }
  .jd-stat__value { font-family: var(--font-display); font-weight: 800; font-size: clamp(17px, 1.6vw, 21px); letter-spacing: -0.01em; color: var(--ink); }
  @media (max-width: 720px) { .jd-stats { grid-template-columns: 1fr 1fr; } .jd-stat:nth-child(3) { border-left: 0; } .jd-stat:nth-child(odd) { border-left: 0; } .jd-stat:nth-child(n+3) { border-top: 1px solid var(--rule); } }

  /* ── Body grid ── */
  .jd-body { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--space-5); align-items: start; }
  @media (max-width: 920px) { .jd-body { grid-template-columns: 1fr; } }

  .jd-main { display: flex; flex-direction: column; gap: var(--space-4); }
  .jd-panel { background: var(--cream-soft); border: 1px solid var(--rule); border-radius: 20px; padding: clamp(22px, 3vw, 34px); }
  .jd-panel__head { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }
  .jd-panel__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700; color: var(--ink-mute); white-space: nowrap; }
  .jd-panel__rule { flex: 1; height: 1px; background: var(--rule); }
  .jd-panel__lede { font-family: var(--font-body); font-size: 16px; line-height: 1.7; color: var(--ink-soft); margin: 0; }

  .jd-highlights { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 13px; }
  .jd-highlights__item { display: flex; gap: 14px; font-family: var(--font-body); font-size: 15px; line-height: 1.5; color: var(--ink); }
  .jd-highlights__arrow { color: var(--sky, #3FB3E0); font-weight: 700; flex-shrink: 0; }

  .jd-facility { margin: 0; display: flex; flex-direction: column; }
  .jd-facility__row { display: grid; grid-template-columns: 110px 1fr; gap: 18px; align-items: baseline; padding: 13px 0; border-bottom: 1px solid var(--rule); }
  .jd-facility__row:last-child { border-bottom: 0; }
  .jd-facility__k { margin: 0; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; color: var(--ink-mute); }
  .jd-facility__v { margin: 0; font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--ink); }

  /* ── Sticky apply rail (dark skin, mirrors /contact) ── */
  .jd-rail { position: sticky; top: 20px; }
  @media (max-width: 920px) { .jd-rail { position: static; } }
  .jd-apply {
    position: relative; overflow: hidden;
    background: #0C1C30; color: var(--cream-soft);
    border-radius: 24px; padding: clamp(24px, 3vw, 32px);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.4);
  }
  .jd-apply__glow { position: absolute; border-radius: 50%; filter: blur(60px); pointer-events: none; }
  .jd-apply__glow--a { width: 260px; height: 260px; background: rgba(63, 179, 224, 0.34); top: -110px; right: -80px; }
  .jd-apply__glow--b { width: 220px; height: 220px; background: rgba(212, 86, 158, 0.24); bottom: -120px; left: -90px; }
  .jd-apply__eyebrow { position: relative; display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; color: #79C7E8; margin-bottom: 14px; }
  .jd-apply__dot { width: 8px; height: 8px; border-radius: 50%; background: #79C7E8; }
  .jd-apply__title { position: relative; font-family: var(--font-display); font-weight: 900; font-size: clamp(26px, 3vw, 34px); line-height: 1.04; letter-spacing: -0.03em; color: var(--cream-soft); margin: 0 0 10px; }
  .jd-apply__title em { font-style: normal; color: #3FB3E0; }
  .jd-apply__sub { position: relative; font-family: var(--font-body); font-size: 14px; line-height: 1.55; color: rgba(251, 246, 238, 0.72); margin: 0 0 18px; }
  .jd-apply__chip { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid rgba(251, 246, 238, 0.14); border-radius: 12px; padding: 11px 14px; margin-bottom: 18px; }
  .jd-apply__chip-role { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; color: rgba(251, 246, 238, 0.82); }
  .jd-apply__chip-id { font-family: var(--font-mono); font-size: 12px; font-weight: 700; color: #79C7E8; white-space: nowrap; }

  .jd-form { position: relative; display: flex; flex-direction: column; gap: 12px; }
  .jd-field { display: flex; flex-direction: column; gap: 6px; }
  .jd-field label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(251, 246, 238, 0.55); font-weight: 600; }
  .jd-hint { text-transform: none; letter-spacing: 0; color: rgba(251, 246, 238, 0.4); }
  .jd-field input, .jd-field textarea {
    font-family: var(--font-body); font-size: 15px; padding: 12px 14px;
    border: 1px solid rgba(251, 246, 238, 0.16); border-radius: 12px;
    background: rgba(251, 246, 238, 0.04); color: var(--cream-soft);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .jd-field textarea { min-height: 96px; resize: vertical; }
  .jd-field input::placeholder, .jd-field textarea::placeholder { color: rgba(251, 246, 238, 0.4); }
  .jd-field input:focus, .jd-field textarea:focus { outline: none; border-color: #3FB3E0; box-shadow: 0 0 0 3px rgba(63, 179, 224, 0.30); }

  .jd-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

  .jd-form__error { margin: 0; padding: 11px 13px; border-radius: 10px; background: rgba(242, 106, 91, 0.14); border: 1px solid rgba(242, 106, 91, 0.4); color: #FFC9B8; font-family: var(--font-body); font-size: 13px; line-height: 1.45; }
  .jd-form__error[hidden] { display: none; }

  .jd-submit {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    background: #3FB3E0; color: #0C1C30; border: none; border-radius: 999px;
    padding: 15px 22px; font-family: var(--font-body); font-weight: 700; font-size: 15px;
    cursor: pointer; margin-top: 4px; transition: transform 0.15s, box-shadow 0.15s;
  }
  .jd-submit:focus-visible { outline: 3px solid var(--cream-soft); outline-offset: 3px; }
  .jd-submit__puck { width: 26px; height: 26px; border-radius: 50%; background: #0C1C30; color: var(--cream-soft); display: grid; place-items: center; font-size: 13px; transition: transform 0.15s; }
  @media (hover: hover) and (pointer: fine) {
    .jd-submit:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(63, 179, 224, 0.4); }
    .jd-submit:active { transform: scale(0.98); transition-duration: 110ms; }
    .jd-submit:hover .jd-submit__puck { transform: translateX(3px); }
  }
  .jd-fine { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.02em; color: rgba(251, 246, 238, 0.45); text-align: center; margin: 4px 0 0; }

  /* Success — transform-only entrance (never opacity:0 at rest). */
  .jd-sent { display: none; position: relative; background: #0C1C30; color: var(--cream-soft); border-radius: 24px; padding: clamp(28px, 3vw, 36px); text-align: center; box-shadow: 0 30px 70px rgba(0, 0, 0, 0.4); }
  .jd-sent.is-active { display: block; }
  .jd-sent:focus { outline: none; }
  .jd-sent__check { width: 72px; height: 72px; border-radius: 50%; background: #3DBE85; display: grid; place-items: center; margin: 0 auto 20px; box-shadow: 0 16px 40px rgba(61, 190, 133, 0.45); }
  .jd-sent__check svg { width: 36px; height: 36px; }
  .jd-sent__title { font-family: var(--font-display); font-weight: 900; font-size: clamp(26px, 3vw, 34px); letter-spacing: -0.03em; margin: 0 0 12px; color: var(--cream-soft); }
  .jd-sent__body { font-family: var(--font-body); font-size: 15px; line-height: 1.6; color: rgba(251, 246, 238, 0.78); margin: 0 0 22px; }
  .jd-sent__body strong { color: #5FC2EC; font-weight: 700; }
  .jd-sent__pill { display: inline-flex; align-items: center; gap: 8px; background: var(--cream-soft); color: #0C1C30; border-radius: 999px; padding: 13px 24px; font-family: var(--font-body); font-weight: 700; font-size: 14px; text-decoration: none; transition: transform 0.15s; }
  @media (hover: hover) and (pointer: fine) { .jd-sent__pill:hover { transform: translateY(-2px); } }
  .jd-sent.is-active .jd-sent__check { animation: jdPop 0.6s cubic-bezier(0.32, 0.72, 0, 1) backwards; }
  .jd-sent.is-active .jd-sent__title { animation: jdRise 0.6s ease 80ms backwards; }
  .jd-sent.is-active .jd-sent__body { animation: jdRise 0.6s ease 150ms backwards; }
  .jd-sent.is-active .jd-sent__pill { animation: jdRise 0.6s ease 220ms backwards; }
  @keyframes jdPop { 0% { transform: scale(0.4); } 55% { transform: scale(1.12); } 100% { transform: scale(1); } }
  @keyframes jdRise { from { transform: translateY(16px); } to { transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) {
    .jd-sent.is-active .jd-sent__check, .jd-sent.is-active .jd-sent__title,
    .jd-sent.is-active .jd-sent__body, .jd-sent.is-active .jd-sent__pill { animation: none; }
  }

  .jd-confetti { position: fixed; inset: 0; pointer-events: none; z-index: 60; }

  /* ── 404 ── */
  .jd-404 { text-align: center; padding: var(--space-9) 0; max-width: 560px; margin: 0 auto; }
  .jd-404__eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.2em; font-weight: 700; color: var(--sky, #3FB3E0); }
  .jd-404__title { font-family: var(--font-display); font-weight: 900; font-size: clamp(34px, 5vw, 56px); line-height: 1.02; letter-spacing: -0.03em; color: var(--ink); margin: 14px 0 16px; }
  .jd-404__body { font-family: var(--font-body); font-size: 17px; line-height: 1.6; color: var(--ink-soft); margin: 0 0 28px; }
</style>

<script>
  // Apply form: progressive enhancement. Validate name/email client-side, fold
  // the job ref/role into the message so the lead is tied to this role, POST to
  // /api/contact (reuses the Turnstile + capture + Resend pipeline), then flip to
  // the success state + fire confetti. No-JS falls back to a native POST.
  const form = document.getElementById('jdApplyForm') as HTMLFormElement | null;
  const apply = document.getElementById('jdApply');
  const sent = document.getElementById('jdSent');
  const errorEl = document.getElementById('jdError');
  const canvas = document.getElementById('jdConfetti') as HTMLCanvasElement | null;

  let confettiRaf: number | null = null;

  function shake(el: Element) {
    el.animate(
      [
        { transform: 'translateX(0)' },
        { transform: 'translateX(-6px)' },
        { transform: 'translateX(6px)' },
        { transform: 'translateX(0)' },
      ],
      { duration: 320, easing: 'ease-in-out' },
    );
  }

  if (form && apply && sent) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const name = ((fd.get('name') as string) ?? '').trim();
      const email = ((fd.get('email') as string) ?? '').trim();

      if (!name) {
        const el = form.querySelector('[name="name"]') as HTMLElement | null;
        if (el) { el.focus(); shake(el); }
        return;
      }
      if (!/.+@.+\..+/.test(email)) {
        const el = form.querySelector('[name="email"]') as HTMLElement | null;
        if (el) { el.focus(); shake(el); }
        return;
      }

      // Fold the job context into the message so the recruiter (and the captured
      // row) always know which role this inquiry is about. Phone is NOT folded
      // here anymore — the server reads the `phone` field directly (INC-2), so a
      // no-JS native POST captures it too; folding it here as well would duplicate it.
      const role = ((fd.get('jobRole') as string) ?? '').toString();
      const refId = ((fd.get('jobRef') as string) ?? '').toString();
      const city = ((fd.get('jobCity') as string) ?? '').toString();
      const userMsg = ((fd.get('message') as string) ?? '').trim();
      const header = `Job inquiry — ${[role, city].filter(Boolean).join(' · ')}${refId ? ` (Ref ${refId})` : ''}.`;
      const composed = [header, userMsg].filter(Boolean).join('\n');
      fd.set('message', composed);

      const submitBtn = form.querySelector('.jd-submit') as HTMLButtonElement | null;
      const originalBtnHtml = submitBtn ? submitBtn.innerHTML : '';
      if (errorEl) errorEl.setAttribute('hidden', '');
      const showError = (msg: string) => {
        if (errorEl) { errorEl.textContent = msg; errorEl.removeAttribute('hidden'); }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = originalBtnHtml; }
      };
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

      fetch(form.action, { method: 'POST', body: fd, headers: { Accept: 'application/json' } })
        .then((res) => {
          if (!res.ok) {
            showError(
              res.status === 403
                ? "We couldn't confirm you're human. Please reload and try again."
                : 'Something went wrong. Please email recruiting@iastaffing.com directly.',
            );
            return;
          }
          apply.style.display = 'none';
          sent.classList.add('is-active');
          (sent as HTMLElement).focus();
          fireConfetti();
        })
        .catch(() => showError('We could not reach the server. Please email recruiting@iastaffing.com directly.'));
    });
  }

  function fireConfetti() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const c = canvas;
    if (!c) return;
    const ctx = c.getContext('2d');
    if (!ctx) return;
    if (confettiRaf !== null) cancelAnimationFrame(confettiRaf);
    let W = (c.width = window.innerWidth);
    let H = (c.height = window.innerHeight);
    const onResize = () => { W = c.width = window.innerWidth; H = c.height = window.innerHeight; };
    window.addEventListener('resize', onResize);
    const colors = ['#3FB3E0', '#F26A5B', '#7C84E8', '#3DBE85', '#D4569E', '#F2A03D'];
    const pieces = Array.from({ length: 160 }, () => ({
      x: W / 2 + (Math.random() - 0.5) * 120,
      y: H / 2 + (Math.random() - 0.5) * 40,
      r: 4 + Math.random() * 7,
      c: colors[(Math.random() * colors.length) | 0],
      vx: (Math.random() - 0.5) * 14,
      vy: -6 - Math.random() * 12,
      rot: Math.random() * 6.28,
      vr: (Math.random() - 0.5) * 0.5,
      shape: Math.random() > 0.5 ? 'rect' : 'circle',
      life: 0,
    }));
    let t = 0;
    const frame = () => {
      ctx.clearRect(0, 0, W, H);
      t++;
      let alive = false;
      for (const p of pieces) {
        p.life++; p.vy += 0.35; p.vx *= 0.99; p.x += p.vx; p.y += p.vy; p.rot += p.vr;
        if (p.y < H + 40) alive = true;
        ctx.globalAlpha = Math.max(0, 1 - p.life / 170);
        ctx.fillStyle = p.c;
        ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
        if (p.shape === 'rect') ctx.fillRect(-p.r, -p.r, p.r * 2, p.r * 2);
        else { ctx.beginPath(); ctx.arc(0, 0, p.r, 0, 6.28); ctx.fill(); }
        ctx.restore();
      }
      ctx.globalAlpha = 1;
      if (t < 240 && alive) confettiRaf = requestAnimationFrame(frame);
      else { ctx.clearRect(0, 0, W, H); window.removeEventListener('resize', onResize); confettiRaf = null; }
    };
    confettiRaf = requestAnimationFrame(frame);
  }
</script>
