---
/**
 * /jobs — Open opportunities. Chromia-Cream "jb-b" card-grid design (kit
 * page-variations/jobs.html, pick B) fed by the REAL Supabase ims_jobs feed.
 *
 * Data source: Supabase ims_jobs WHERE status='active' (LocumSmart webhook
 * receiver at src/pages/api/locumsmart-webhook.ts). SSR (prerender=false) so LS
 * events surface without a rebuild; routes through _worker.js.
 *
 * Per the exact-replication directive the LAYOUT is the kit's; per the
 * jobs-specific directive the DATA is real (NOT the kit's fake "124
 * assignments"). The kit cards show fabricated pay/schedule/openings — the feed
 * has none, so we show real fields only (specialty, location, length, call,
 * coverage) and "Rate on request" (no fabricated numbers).
 *
 * Public/internal boundary preserved: facility_name is INTERNAL and never read;
 * the card always renders public_facility_label (see facilityLabel below).
 */
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import SiteFooter from '../../components/footer/SiteFooter.astro';
import { createClient } from '@supabase/supabase-js';
import { jobHaystack } from '../../lib/job-search';

export const prerender = false;

interface PagesEnv {
  SUPABASE_URL?: string;
  SUPABASE_SERVICE_ROLE_KEY?: string;
}

interface JobRow {
  id: string;
  specialty_slug: string;
  specialty_name: string | null;
  provider_type: string | null;
  facility_state: string | null;
  facility_city: string | null;
  public_facility_label: string | null;
  length_category: string | null;
  call_type: string | null;
  coverage_type: string | null;
}

const cfEnv = (Astro.locals as { runtime?: { env?: PagesEnv } }).runtime?.env;
const env: PagesEnv = cfEnv ?? {
  SUPABASE_URL: import.meta.env.SUPABASE_URL,
  SUPABASE_SERVICE_ROLE_KEY: import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
};

let jobs: JobRow[] = [];
if (env.SUPABASE_URL && env.SUPABASE_SERVICE_ROLE_KEY) {
  try {
    const supabase = createClient(env.SUPABASE_URL, env.SUPABASE_SERVICE_ROLE_KEY, {
      auth: { persistSession: false, autoRefreshToken: false },
    });
    // LIMIT 1000 matches PostgREST default server max — Phase 1.A volume is
    // tens-to-low-hundreds of active assignments, so one page fetches the whole
    // list. Beyond 1000 the chip rail also truncates; range pagination is a
    // later concern.
    const { data, error } = await supabase
      .from('ims_jobs')
      .select(
        'id, specialty_slug, specialty_name, provider_type, facility_state, facility_city, public_facility_label, length_category, call_type, coverage_type',
      )
      .eq('status', 'active')
      .order('ls_last_modified', { ascending: false, nullsFirst: false })
      .limit(1000);
    if (error) {
      console.error('[/jobs] supabase read failed:', error.message);
    } else if (data) {
      jobs = data as JobRow[];
    }
  } catch (e) {
    console.error('[/jobs] supabase client crash:', e);
  }
} else {
  console.warn('[/jobs] env not configured — rendering empty state');
}

const totalCount = jobs.length;

const specialtyLabel = (s: string) =>
  s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

// Distinct specialties present, for the filter chips.
const specialtiesPresent = [...new Set(jobs.map((j) => j.specialty_slug))].sort();

// Distinct provider types present (e.g. CRNA, NP, PA, MD, Physician) for the
// provider-type chip row. Values come straight from LocumSmart and are already
// display-ready; rendered as-is, matched case-insensitively via data-provider.
// Dedup by lowercase so a mixed-case source ("CRNA"/"crna") yields ONE chip.
const providerByLower = new Map<string, string>();
for (const j of jobs) {
  const v = (j.provider_type ?? '').trim();
  if (v && !providerByLower.has(v.toLowerCase())) providerByLower.set(v.toLowerCase(), v);
}
const providersPresent = [...providerByLower.values()].sort();

// Map a specialty slug to one of the kit's soft card tints; cycle for any slug
// not in the canonical map so every card gets a stable colour.
const SPEC_TINT: Record<string, string> = {
  anesthesia: 'coral',
  'ob-gyn': 'rose',
  obgyn: 'rose',
  urology: 'butter',
  emergency: 'mint',
  'emergency-medicine': 'mint',
  'internal-medicine': 'sky',
  hospitalist: 'sky',
  surgery: 'lilac',
  'general-surgery': 'lilac',
  radiology: 'coral',
  psychiatry: 'butter',
};
const TINTS = ['coral', 'rose', 'butter', 'mint', 'sky', 'lilac'];
const tintFor = (slug: string, i: number) => SPEC_TINT[slug] ?? TINTS[i % TINTS.length];

const lengthDisplay = (c: string | null): string =>
  c ? c.charAt(0).toUpperCase() + c.slice(1) : '';

const locationTitle = (j: JobRow): string => {
  const loc = [j.facility_city, j.facility_state].filter(Boolean).join(', ');
  return loc || j.public_facility_label || 'Nationwide';
};

const facilityLabel = (j: JobRow): string => j.public_facility_label ?? 'Healthcare facility';

// data-keywords MUST equal jobHaystack(job) — the input to the shared matcher —
// so the homepage "N open" count and the /jobs client filter agree for every
// query (now including the full state name, e.g. "Texas"). Single source of truth.
const keywords = (j: JobRow): string => jobHaystack(j);

// Up to 4 search hints derived from real data (specialty labels first, then
// states present). Empty when the feed is dormant.
const hintList = [
  ...specialtiesPresent.slice(0, 3).map(specialtyLabel),
  ...[...new Set(jobs.map((j) => j.facility_state).filter((s): s is string => !!s))].slice(0, 2),
].slice(0, 4);

// State silhouettes shipped in public/state-shapes/ (2-letter codes, incl. PR).
// facility_state is a 2-letter code; only emit the card's geographic watermark
// when we actually have that state's SVG — otherwise the mask URL 404s and the
// element paints as a solid ink block. Unknown/blank/territory codes → no shape.
const STATE_SHAPES = new Set([
  'al', 'ak', 'az', 'ar', 'ca', 'co', 'ct', 'de', 'fl', 'ga', 'hi', 'id', 'il',
  'in', 'ia', 'ks', 'ky', 'la', 'me', 'md', 'ma', 'mi', 'mn', 'ms', 'mo', 'mt',
  'ne', 'nv', 'nh', 'nj', 'nm', 'ny', 'nc', 'nd', 'oh', 'ok', 'or', 'pa', 'pr',
  'ri', 'sc', 'sd', 'tn', 'tx', 'ut', 'vt', 'va', 'wa', 'wv', 'wi', 'wy',
]);
const stateShape = (j: JobRow): string | null => {
  const code = (j.facility_state ?? '').trim().toLowerCase();
  return STATE_SHAPES.has(code) ? `/state-shapes/${code}.svg` : null;
};
---
<MarketingLayout
  title="Open Roles — Innovative Medical Staffing"
  description={`${totalCount} open locum assignments across the IMS network. Search by city, state, or specialty.`}
  inCard={false}
>
  <SiteNav slot="nav" />

  <div class="variation">
    <section class="jb__hero">
      <div class="container hero-stage">
        <span class="jb__hero-eyebrow" style="--i:0">{totalCount} open {totalCount === 1 ? 'assignment' : 'assignments'} · live feed</span>
        <h1 class="jb__hero-title" style="--i:1">Browse <span>open roles</span>.</h1>
        <p class="jb__hero-sub" style="--i:2">Live feed from LocumSmart, curated by a recruiter. Search by city, state, or specialty.</p>
      </div>

      <div class="jb-b__search">
        <form class="jb-b__search-shell" id="jobs-search-form">
          <span class="jb-b__search-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m20 20-3.5-3.5"></path>
            </svg>
          </span>
          <input
            id="jobs-search-input"
            class="jb-b__search-input"
            type="search"
            placeholder="Search any specialty or city, typos OK"
            autocomplete="off"
            aria-label="Search open jobs by specialty, city, or state — typo-tolerant"
          />
          <button type="button" id="jobs-search-clear" class="jb-b__search-clear" aria-label="Clear search">×</button>
          <button type="submit" class="jb-b__search-btn">
            Search
            <span aria-hidden="true">→</span>
          </button>
        </form>
        {hintList.length > 0 && (
          <div class="jb-b__search-hints">
            <span class="jb-b__search-hints-label">Try:</span>
            {hintList.map((h) => (
              <button type="button" class="jb-b__search-hint" data-q={h}>{h}</button>
            ))}
          </div>
        )}
      </div>

      {(specialtiesPresent.length > 0 || providersPresent.length > 0) && (
        <div class="jb-b__filters">
          {specialtiesPresent.length > 0 && (
            <div class="jb-b__chip-row">
              <span class="jb-b__chip-label" id="jobs-spec-label">Specialty</span>
              <div class="jb-b__chips" id="jobs-chips" role="group" aria-labelledby="jobs-spec-label">
                <button type="button" class="jb-b__chip jb-b__chip--active" data-spec="all" aria-pressed="true">All · <span data-count="all">{totalCount}</span></button>
                {specialtiesPresent.map((s) => (
                  <button type="button" class="jb-b__chip" data-spec={s} aria-pressed="false">{specialtyLabel(s)}</button>
                ))}
              </div>
            </div>
          )}
          {providersPresent.length > 0 && (
            <div class="jb-b__chip-row">
              <span class="jb-b__chip-label" id="jobs-prov-label">Provider type</span>
              <div class="jb-b__chips" id="jobs-provider-chips" role="group" aria-labelledby="jobs-prov-label">
                <button type="button" class="jb-b__chip jb-b__chip--active" data-provider="all" aria-pressed="true">All</button>
                {providersPresent.map((p) => (
                  <button type="button" class="jb-b__chip" data-provider={p.toLowerCase()} aria-pressed="false">{p}</button>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </section>

    <section class="jb-section">
      <p id="jobs-status" class="visually-hidden" role="status" aria-live="polite"></p>
      <div class="jb-b__grid reveal-group" id="jobs-grid">
        {jobs.map((j, i) => {
          const shape = stateShape(j);
          return (
          <a
            href={`/jobs/${j.id}`}
            aria-label={`${j.specialty_name ?? specialtyLabel(j.specialty_slug)} — ${locationTitle(j)}, view details`}
            class:list={[`jb-b__card jb-b__card--${tintFor(j.specialty_slug, i)}`, 'reveal']}
            style={`--i:${Math.min(i, 5)}`}
            data-spec={j.specialty_slug}
            data-provider={(j.provider_type ?? '').toLowerCase()}
            data-state={(j.facility_state ?? '').toLowerCase()}
            data-city={(j.facility_city ?? '').toLowerCase()}
            data-keywords={keywords(j)}
          >
            {shape && (
              <span class="jb-b__card-state" aria-hidden="true" style={`--state-shape:url(${shape})`}></span>
            )}
            <span class="jb-b__card-arrow" aria-hidden="true">→</span>
            <span class="jb-b__card-spec">{j.specialty_name ?? specialtyLabel(j.specialty_slug)}</span>
            <h3 class="jb-b__card-title">{locationTitle(j)}</h3>
            <div class="jb-b__card-meta">
              <div class="jb-b__card-meta-row"><span>Facility</span><b>{facilityLabel(j)}</b></div>
              {j.length_category && (
                <div class="jb-b__card-meta-row"><span>Length</span><b>{lengthDisplay(j.length_category)}</b></div>
              )}
              {(j.call_type || j.coverage_type) && (
                <div class="jb-b__card-meta-row"><span>Type</span><b>{[j.call_type, j.coverage_type].filter(Boolean).join(' · ')}</b></div>
              )}
            </div>
          </a>
          );
        })}
      </div>

      <div class={`jb-b__empty${totalCount === 0 ? ' is-visible' : ''}`} id="jobs-empty">
        <h3 class="jb-b__empty-title">No openings match that yet.</h3>
        <p class="jb-b__empty-body">
          Our roster is curated, not a job aggregator. If nothing here fits,
          send us your CV anyway, and a recruiter will reach out as soon as
          something opens.
        </p>
        <a class="pill pill--swing" href="/contact">
          <span>Tell us what you're looking for</span><span class="pill__puck" aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>

  <SiteFooter slot="footer" />
</MarketingLayout>

<!-- is:global — the job cards are rendered inside a {jobs.map()} expression, so
     a scoped <style> can't reliably target them (same Astro scoping limitation
     as the hero rotator). These .jb-b__/.jb__ classes are jobs-only, so global
     scope is safe and deterministic. -->
<style is:global>
  /* Page-specific jb-b styles ported from the kit jobs.html (variation B).
   * Shared atoms (.pill, .container, .eyebrow) resolve from kit.css. */
  .jb__hero { padding: var(--space-9) 0 var(--space-6); text-align: center; }
  .jb__hero-eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; color: var(--ink-mute); }
  .jb__hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(52px, 7vw, 112px); line-height: 0.94;
    letter-spacing: -0.04em; color: var(--ink); margin: var(--space-3) auto var(--space-4);
    max-width: 18ch;
  }
  .jb__hero-title span { color: var(--ink-emphasis); }
  .jb__hero-sub { font-family: var(--font-body); font-size: 19px; line-height: 1.5; color: var(--ink-soft); max-width: 60ch; margin: 0 auto; }

  .jb-section { padding: var(--space-7) 0; position: relative; }

  .jb-b__search { max-width: 880px; margin: var(--space-5) auto var(--space-3); padding: 0 var(--container-pad); }
  .jb-b__search-shell {
    position: relative; display: flex; align-items: center;
    background: var(--cream-soft); border: 1.5px solid var(--rule);
    border-radius: 999px; padding: 6px 6px 6px 22px;
    transition: border-color 200ms, box-shadow 200ms;
    box-shadow: 0 8px 24px rgba(31,26,35,0.04);
  }
  .jb-b__search-shell:focus-within { border-color: var(--ink); box-shadow: 0 12px 32px rgba(31,26,35,0.10); }
  .jb-b__search-icon { width: 20px; height: 20px; flex-shrink: 0; color: var(--ink-mute); display: inline-flex; align-items: center; justify-content: center; }
  .jb-b__search-input { flex: 1; border: none; background: transparent; font-family: var(--font-body); font-size: 16px; font-weight: 500; color: var(--ink); padding: 14px; outline: none; }
  .jb-b__search-input::placeholder { color: var(--ink-mute); font-weight: 400; }
  .jb-b__search-clear { width: 32px; height: 32px; border-radius: 50%; border: none; cursor: pointer; background: rgba(31,26,35,0.08); color: var(--ink); display: none; align-items: center; justify-content: center; font-size: 16px; font-weight: 600; margin-right: 6px; }
  .jb-b__search-shell.has-text .jb-b__search-clear { display: inline-flex; }
  .jb-b__search-clear:hover { background: rgba(31,26,35,0.16); }
  .jb-b__search-btn { border: none; cursor: pointer; background: var(--ink); color: var(--cream-soft); padding: 12px 22px; border-radius: 999px; font-family: var(--font-body); font-weight: 700; font-size: 14px; display: inline-flex; align-items: center; gap: 6px; transition: background 180ms, transform 180ms; }
  .jb-b__search-btn:hover { background: var(--sky); color: var(--ink); transform: translateX(2px); }
  .jb-b__search-hints { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-top: var(--space-3); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-mute); }
  .jb-b__search-hints-label { color: var(--ink-mute); font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .jb-b__search-hint { font: inherit; letter-spacing: inherit; border: none; padding: 4px 10px; border-radius: 999px; background: rgba(31,26,35,0.06); color: var(--ink); cursor: pointer; transition: background 160ms; }
  .jb-b__search-hint:hover { background: var(--pop-butter); }

  .jb-b__empty { max-width: 880px; margin: var(--space-7) auto; padding: var(--space-7) var(--space-6); text-align: center; background: var(--cream-soft); border: 1px dashed var(--rule); border-radius: 24px; display: none; }
  .jb-b__empty.is-visible { display: block; }
  .jb-b__empty-title { font-family: var(--font-display); font-weight: 900; font-size: 28px; letter-spacing: -0.02em; color: var(--ink); margin: 0 0 var(--space-3); }
  .jb-b__empty-body { font-family: var(--font-body); font-size: 15px; line-height: 1.55; color: var(--ink-soft); margin: 0 auto var(--space-4); max-width: 48ch; }
  .jb-b__empty .pill { display: inline-flex; }

  .jb-b__filters { max-width: 1280px; margin: var(--space-6) auto var(--space-5); padding: 0 var(--container-pad); display: flex; flex-direction: column; gap: var(--space-4); }
  .jb-b__chip-row { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .jb-b__chip-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; color: var(--ink-mute); }
  .jb-b__chips { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .jb-b__chip { padding: 9px 18px; border-radius: 999px; font-family: var(--font-body); font-weight: 600; font-size: 13px; background: var(--cream-soft); border: 1px solid var(--rule); color: var(--ink); cursor: pointer; transition: all 200ms; }
  .jb-b__chip:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(31,26,35,0.08); }
  .jb-b__chip--active { background: var(--ink); color: var(--cream-soft); border-color: var(--ink); }

  .jb-b__grid { max-width: 1280px; margin: 0 auto; padding: 0 var(--container-pad); display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); }
  @media (max-width: 900px) { .jb-b__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .jb-b__grid { grid-template-columns: 1fr; } }
  .jb-b__card { border-radius: 24px; padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); transition: transform 280ms var(--ease-out), box-shadow 280ms, opacity 220ms; cursor: pointer; text-decoration: none; color: var(--ink); position: relative; overflow: hidden; min-height: 280px; }
  .jb-b__card.is-hidden { display: none; }
  .jb-b__card:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(31,26,35,0.12); }
  .jb-b__card--coral { background: var(--soft-coral); }
  .jb-b__card--rose { background: var(--soft-rose); }
  .jb-b__card--butter { background: var(--soft-butter); }
  .jb-b__card--mint { background: var(--soft-mint); }
  .jb-b__card--sky { background: var(--soft-sky); }
  .jb-b__card--lilac { background: var(--soft-lilac); }
  .jb-b__card-spec { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; color: var(--ink); display: flex; align-items: center; gap: 8px; }
  .jb-b__card-spec::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--ink); }
  .jb-b__card-title { font-family: var(--font-display); font-weight: 900; font-size: 26px; line-height: 1.05; letter-spacing: -0.025em; color: var(--ink); margin: 0; }
  .jb-b__card-pay { font-family: var(--font-display); font-weight: 900; font-size: 36px; line-height: 0.9; letter-spacing: -0.025em; color: var(--ink); font-variant-numeric: tabular-nums; margin: var(--space-2) 0; }
  .jb-b__card-pay--text { font-size: 20px; font-family: var(--font-body); font-weight: 600; color: var(--ink-soft); letter-spacing: 0; }
  .jb-b__card-meta { display: flex; flex-direction: column; gap: 4px; padding-top: var(--space-3); border-top: 1px solid rgba(31,26,35,0.15); margin-top: auto; }
  .jb-b__card-meta-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: 11px; color: var(--ink); letter-spacing: 0.04em; }
  .jb-b__card-meta-row b { font-weight: 700; text-align: right; }
  .jb-b__card-arrow { position: absolute; top: var(--space-4); right: var(--space-4); width: 32px; height: 32px; border-radius: 999px; background: var(--ink); color: var(--cream-soft); display: inline-flex; align-items: center; justify-content: center; font-weight: 700; z-index: 2; }

  /* State silhouette watermark (Zach 2026-06-15): the role's home state as a
   * large, low-opacity ink shape bleeding off the bottom-right corner, behind
   * the card content — a quiet geographic accent. The shape is painted by
   * MASKING a solid background, so the source SVG's own fill is ignored and the
   * colour lives in this one `background-color` line (easy to retint). Only
   * rendered for states we ship an SVG for (see stateShape() guard). */
  .jb-b__card-state {
    position: absolute;
    right: -14px;
    bottom: -18px;
    width: clamp(118px, 48%, 178px);
    aspect-ratio: 1 / 1;
    background-color: var(--ink);
    -webkit-mask: var(--state-shape) center / contain no-repeat;
    mask: var(--state-shape) center / contain no-repeat;
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  /* Keep text + meta above the watermark — the card is the positioned ancestor,
   * so an absolute child would otherwise paint over in-flow content. */
  .jb-b__card-spec,
  .jb-b__card-title,
  .jb-b__card-meta { position: relative; z-index: 1; }
</style>

<script>
  // Client filter (bundled, served from 'self' — CSP-clean; no inline handlers).
  // Live text search + specialty chips over the server-rendered cards. The text
  // search is TYPO-TOLERANT and uses the SAME matcher as the homepage count
  // (src/lib/job-search.ts) over the SAME fields (each card's data-keywords is
  // exactly jobHaystack(job)), so the homepage "N open" count equals what shows
  // here for any query — misspellings included.
  import { haystackMatchesQuery } from '../../lib/job-search';

  const input = document.getElementById('jobs-search-input') as HTMLInputElement | null;
  const shell = document.getElementById('jobs-search-form');
  const clear = document.getElementById('jobs-search-clear');
  const grid = document.getElementById('jobs-grid');
  const empty = document.getElementById('jobs-empty');
  const chips = document.getElementById('jobs-chips');
  const count = document.querySelector('[data-count="all"]');
  const status = document.getElementById('jobs-status');

  if (input && grid) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.jb-b__card'));
    const TOTAL = cards.length;

    // Multi-select filter state: an empty Set means "All" for that group. A card
    // shows when it matches the search AND (no specialty selected OR its specialty
    // is selected) AND (no provider selected OR its provider is selected) — OR
    // within a group, AND across groups.
    const activeSpecs = new Set<string>();
    const activeProviders = new Set<string>();
    let query = '';

    function applyFilter() {
      let visible = 0;
      for (const c of cards) {
        const specOk = activeSpecs.size === 0 || activeSpecs.has(c.dataset.spec || '');
        const provOk = activeProviders.size === 0 || activeProviders.has(c.dataset.provider || '');
        // data-keywords === jobHaystack(job); haystackMatchesQuery is the shared,
        // typo-tolerant matcher (substring-first + edit-distance fallback).
        const queryOk = haystackMatchesQuery(c.dataset.keywords || '', query);
        const show = specOk && provOk && queryOk;
        c.classList.toggle('is-hidden', !show);
        if (show) visible++;
      }
      if (empty) empty.classList.toggle('is-visible', visible === 0);
      const noFilter = activeSpecs.size === 0 && activeProviders.size === 0 && !query;
      if (count) count.textContent = String(noFilter ? TOTAL : visible);
      if (status) status.textContent = visible === 0
        ? 'No roles match your filters'
        : `${visible} role${visible === 1 ? '' : 's'} match`;
    }

    input.addEventListener('input', (e) => {
      query = (e.target as HTMLInputElement).value.trim();
      shell?.classList.toggle('has-text', query.length > 0);
      applyFilter();
    });
    clear?.addEventListener('click', () => {
      input.value = '';
      query = '';
      shell?.classList.remove('has-text');
      input.focus();
      applyFilter();
    });
    shell?.addEventListener('submit', (e) => {
      e.preventDefault();
      applyFilter();
    });
    document.querySelectorAll<HTMLElement>('.jb-b__search-hint').forEach((h) => {
      h.addEventListener('click', () => {
        input.value = h.dataset.q || '';
        query = input.value;
        shell?.classList.add('has-text');
        applyFilter();
        input.focus();
      });
    });
    // Wire a chip group for multi-select. The "All" chip clears the group's Set;
    // any specific chip toggles its value in/out. "All" is active iff the Set is
    // empty; specific chips are active iff their value is in the Set.
    function wireChipGroup(container: HTMLElement | null, key: 'spec' | 'provider', selected: Set<string>) {
      if (!container) return;
      const setChip = (el: Element, on: boolean) => {
        el.classList.toggle('jb-b__chip--active', on);
        el.setAttribute('aria-pressed', String(on));
      };
      const sync = () => {
        container.querySelectorAll<HTMLElement>('.jb-b__chip').forEach((c) => {
          const v = c.dataset[key] || '';
          setChip(c, v === 'all' ? selected.size === 0 : selected.has(v));
        });
      };
      container.querySelectorAll<HTMLElement>('.jb-b__chip').forEach((chip) => {
        chip.addEventListener('click', () => {
          const val = chip.dataset[key] || '';
          if (val === 'all') selected.clear();
          else if (selected.has(val)) selected.delete(val);
          else selected.add(val);
          sync();
          applyFilter();
        });
      });
    }
    wireChipGroup(chips, 'spec', activeSpecs);
    wireChipGroup(document.getElementById('jobs-provider-chips'), 'provider', activeProviders);

    // Deep-link support: the homepage specialty cards link here as
    // /jobs?q=<query>. Pre-fill the search and apply the same filter so the
    // "N open this week" count shown on the homepage matches what's listed here
    // (both use the shared typo-tolerant matcher — see src/lib/job-search.ts).
    const initialQuery = new URLSearchParams(location.search).get('q');
    if (initialQuery && initialQuery.trim()) {
      query = initialQuery.trim();
      input.value = query;
      shell?.classList.add('has-text');
      applyFilter();
    }
  }
</script>
