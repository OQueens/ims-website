---
/**
 * /jobs — Open opportunities listing.
 *
 * Data source: Supabase ims_jobs WHERE status='active'.
 * Populated by the LocumSmart webhook receiver at src/pages/api/locumsmart-webhook.ts;
 * see migrations/20260508_ims_jobs_table.sql for the row shape + CHECK constraints.
 *
 * Render mode: SSR (prerender=false) so LS events surface without a rebuild.
 * The route flows through _worker.js; on Pages preview/production
 * Astro.locals.runtime.env exposes SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
 *
 * Public/internal boundary (schema design): facility_name is INTERNAL data
 * and is NEVER read by this page. The /jobs headline always renders
 * public_facility_label (derived by the receiver via derivePublicFacilityLabel).
 * The schema's facility_name_public clearance flag is intentionally ignored
 * here — see facilityHeadline below for the sticky-clearance rationale.
 */

import MarketingLayout from '../../layouts/MarketingLayout.astro';
import SiteNav from '../../components/nav/SiteNav.astro';
import SiteFooter from '../../components/footer/SiteFooter.astro';
import { createClient } from '@supabase/supabase-js';

export const prerender = false;

interface PagesEnv {
  SUPABASE_URL?: string;
  SUPABASE_SERVICE_ROLE_KEY?: string;
}

interface JobRow {
  id: string;
  specialty_slug: string;
  specialty_name: string | null;
  facility_state: string | null;
  facility_city: string | null;
  public_facility_label: string | null;
  length_category: string | null;
  call_type: string | null;
  coverage_type: string | null;
}

const cfEnv = (Astro.locals as { runtime?: { env?: PagesEnv } }).runtime?.env;
const env: PagesEnv = cfEnv ?? {
  SUPABASE_URL: import.meta.env.SUPABASE_URL,
  SUPABASE_SERVICE_ROLE_KEY: import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
};

let jobs: JobRow[] = [];
if (env.SUPABASE_URL && env.SUPABASE_SERVICE_ROLE_KEY) {
  try {
    const supabase = createClient(env.SUPABASE_URL, env.SUPABASE_SERVICE_ROLE_KEY, {
      auth: { persistSession: false, autoRefreshToken: false },
    });
    // LIMIT 1000 matches PostgREST default server max — Phase 1.A scale is
    // tens-to-low-hundreds of active assignments at any time, so a single
    // page fetches the whole list. Beyond 1000 active rows the filter rail
    // also starts truncating; Phase 1.5 adds range pagination if scale
    // exceeds the bound. Spec §3.1 explicitly defers search to Phase 1.5.
    const { data, error } = await supabase
      .from('ims_jobs')
      .select(
        'id, specialty_slug, specialty_name, facility_state, facility_city, public_facility_label, length_category, call_type, coverage_type',
      )
      .eq('status', 'active')
      .order('ls_last_modified', { ascending: false, nullsFirst: false })
      .limit(1000);
    if (error) {
      console.error('[/jobs] supabase read failed:', error.message);
    } else if (data) {
      jobs = data as JobRow[];
    }
  } catch (e) {
    console.error('[/jobs] supabase client crash:', e);
  }
} else {
  console.warn('[/jobs] env not configured — rendering empty grid');
}

const specialtiesPresent = [...new Set(jobs.map((j) => j.specialty_slug))].sort();
const statesPresent = [
  ...new Set(jobs.map((j) => j.facility_state).filter((s): s is string => !!s)),
].sort();
const totalCount = jobs.length;

const specialtyLabel = (s: string) =>
  s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

// length_category enum from the schema: short | medium | long | ongoing | NULL.
// Filter UI exposes short/medium/long only — fold 'ongoing' into 'long' for
// the data attribute so the "12+ weeks" checkbox captures open-ended assignments
// alongside bucketed-long. NULL (start_date present but end_date absent and
// vice-versa edge cases) renders no data-length so it shows only when no
// length filter is active.
const lengthDataAttr = (c: string | null): string => (c === 'ongoing' ? 'long' : c ?? '');
const lengthDisplay = (c: string | null): string =>
  c ? c.charAt(0).toUpperCase() + c.slice(1) : '';

const facilityHeadline = (j: JobRow): string => {
  // Always render public_facility_label — the schema clearance flag
  // facility_name_public is intentionally NOT consulted here. The flag is
  // recruiter-owned (sticky across LS updates), but facility_name itself
  // overwrites on every LS event. A prior clearance for "Hospital A" would
  // therefore expose "Hospital B" the next time LS routes the assignment
  // through the same row. The fallback default ('Healthcare Facility') only
  // fires for the admin-set-NULL edge case; the receiver's
  // derivePublicFacilityLabel always emits a non-null value.
  const label = j.public_facility_label ?? 'Healthcare Facility';
  const locTail = [j.facility_city, j.facility_state].filter(Boolean).join(', ');
  return locTail ? `${label} · ${locTail}` : label;
};

const bodyParts = (j: JobRow): string =>
  [j.call_type, j.coverage_type].filter(Boolean).join(' · ');

// jobTitle is the denormalized string the ApplyModal will display in confirmation
// + the recruiter email subject (per spec §3.3). Specialty alone is informative
// enough — the modal composes richer text from data-state + data-job-ref.
const cardTitle = (j: JobRow): string =>
  j.specialty_name ?? specialtyLabel(j.specialty_slug);
---
<MarketingLayout
  title="Open Roles · Innovative Medical Staffing"
  description={`${totalCount} open opportunities across the IMS network.`}
  noindex={false}
  inCard={false}
>
  <SiteNav slot="nav" />
  <div class="card-wrap">
    <header class="page-hero">
      <h1>Open opportunities</h1>
      <p>{totalCount} active roles. Filter by specialty, state, or length.</p>
    </header>

    <div class="layout">
      <aside class="filter-rail" aria-label="Filters">
        <section>
          <h2>Specialty</h2>
          <ul role="group" aria-label="Filter by specialty">
            {specialtiesPresent.map((s) => (
              <li>
                <label>
                  <input type="checkbox" name="specialty" value={s} />
                  <span>{specialtyLabel(s)}</span>
                </label>
              </li>
            ))}
          </ul>
        </section>
        <section>
          <h2>State</h2>
          <ul role="group" aria-label="Filter by state">
            {statesPresent.map((st) => (
              <li><label><input type="checkbox" name="state" value={st} /> <span>{st}</span></label></li>
            ))}
          </ul>
        </section>
        <section>
          <h2>Length</h2>
          <ul role="group" aria-label="Filter by length">
            <li><label><input type="checkbox" name="length" value="short" /> &lt; 4 weeks</label></li>
            <li><label><input type="checkbox" name="length" value="medium" /> 4–12 weeks</label></li>
            <li><label><input type="checkbox" name="length" value="long" /> 12+ weeks</label></li>
          </ul>
        </section>
        <button type="button" class="reset" id="filter-reset">Reset filters</button>
      </aside>

      <section class="results" id="results-grid" aria-live="polite">
        {jobs.map((j) => (
          <article
            class="job-card"
            data-job-ref={j.id}
            data-job-title={cardTitle(j)}
            data-specialty={j.specialty_slug}
            data-state={j.facility_state ?? ''}
            data-length={lengthDataAttr(j.length_category)}
          >
            <div class="eyebrow">
              <span class="specialty">{specialtyLabel(j.specialty_slug)}</span>
              {j.length_category && <span class="length">{lengthDisplay(j.length_category)}</span>}
            </div>
            <h3>{facilityHeadline(j)}</h3>
            {bodyParts(j) && <p>{bodyParts(j)}</p>}
            <p class="rate"><em>Rate on request</em></p>
            <button class="apply-trigger" type="button" data-apply-trigger>Apply through IMS →</button>
          </article>
        ))}
      </section>
    </div>

    <div id="empty-state" hidden>
      <p>No openings match those filters. Tell us what you're looking for and we'll reach out when one opens.</p>
      {/* Mini form per spec §3.1 — specialty + state + email. Posts to /api/contact at T34/T46 with intent=coverage. */}
      <form id="empty-state-alert-form" class="empty-form" novalidate>
        <label>
          <span>Specialty</span>
          <select name="specialty" required>
            <option value="">Choose…</option>
            {specialtiesPresent.map((s) => (
              <option value={s}>{specialtyLabel(s)}</option>
            ))}
            <option value="other">Other / not listed</option>
          </select>
        </label>
        <label>
          <span>State</span>
          <select name="state" required>
            <option value="">Choose…</option>
            {statesPresent.map((st) => (<option value={st}>{st}</option>))}
            <option value="OPEN">Open / no preference</option>
          </select>
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" required maxlength="254" />
        </label>
        <input type="text" name="phone_alt" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
        {/* TurnstileWidget mounts here at T48; submit-handler wires to /api/contact at T34. */}
        <button type="submit" class="submit-btn" disabled>Notify me when one opens</button>
        <p class="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>

  {/* T50 will mount ApplyModal here and T51 will wire .apply-trigger click handlers. */}

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  .card-wrap {
    background: var(--surface-card);
    color: var(--ink-on-cream);
    border-radius: var(--r-card);
    margin: clamp(20px, 4vw, 64px);
    overflow: hidden;
    padding: clamp(48px, 8vw, 96px) clamp(24px, 4vw, 64px);
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .page-hero p {
    font-family: var(--font-body);
    color: var(--ink-on-cream-2);
    font-size: 17px;
  }
  .layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 48px;
    margin-top: 48px;
  }
  .filter-rail {
    position: sticky;
    top: 96px;
    align-self: start;
    font-family: var(--font-body);
  }
  .filter-rail h2 {
    font-family: var(--font-display);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    margin: 24px 0 8px;
    color: var(--ink-on-cream-2);
  }
  .filter-rail ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .filter-rail label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 14px;
  }
  .filter-rail .reset {
    margin-top: 16px;
    background: transparent;
    border: 1px solid var(--border-strong-mkt);
    border-radius: var(--r-pill-mkt);
    padding: 8px 16px;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
    color: var(--ink-on-cream);
  }
  .results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }
  .job-card {
    border: 1px solid var(--border-hairline);
    border-radius: 16px;
    padding: 32px;
    background: var(--surface-card-2);
    transition: border-color 180ms ease-out, transform 180ms ease-out;
  }
  .job-card[hidden] { display: none !important; }
  .job-card:hover {
    /* Cyan accent border on hover — needs to be visible against the dark
     * card surface. --brand-navy alias resolves to dark navy, which would
     * disappear into the surface. Codex r2 fold (parallel fix for legacy
     * /jobs CSS during the dark-system reskin). */
    border-color: var(--ims-cyan-500);
    transform: translateY(-1px);
  }
  .job-card .eyebrow {
    font-family: var(--font-display);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  .job-card .eyebrow .specialty {
    color: var(--brand-gold-muted);
    margin-right: 12px;
  }
  .job-card .eyebrow .length {
    color: var(--brand-teal);
  }
  .job-card h3 {
    font-family: var(--font-display);
    font-size: 24px;
    margin: 0 0 12px;
    line-height: 1.3;
  }
  .job-card p {
    font-size: 15px;
    margin: 0 0 8px;
    color: var(--ink-on-cream-2);
  }
  .job-card .rate {
    /* Cyan accent — needs contrast against dark card surface. */
    color: var(--ims-cyan-400);
    font-weight: 600;
  }
  .job-card .apply-trigger {
    margin-top: 16px;
    background: transparent;
    /* Cyan outline button (was dark navy on cream). Patched for the
     * dark-system reskin: outline must contrast against the dark card
     * surface. Codex r2 fold. */
    border: 1.5px solid var(--ims-cyan-500);
    color: var(--ims-cyan-400);
    padding: 10px 20px;
    border-radius: var(--r-pill-mkt);
    cursor: pointer;
    font-family: inherit;
    font-size: 14px;
  }
  .job-card .apply-trigger:hover {
    background: var(--ims-cyan-500);
    color: var(--ims-navy-900);
  }
  #empty-state {
    text-align: center;
    padding: 96px 0;
  }
  .empty-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    max-width: 720px;
    margin: 32px auto 0;
    text-align: left;
  }
  .empty-form label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 14px;
  }
  .empty-form select,
  .empty-form input[type="email"] {
    border: 1px solid var(--border-strong-mkt);
    border-radius: 8px;
    padding: 8px 12px;
    font-family: inherit;
    font-size: 15px;
    background: var(--surface-card-2);
  }
  .empty-form .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
  }
  .empty-form .submit-btn {
    grid-column: 1 / -1;
    /* Cyan filled CTA — patched for dark-system reskin. Codex r2 fold. */
    background: var(--ims-cyan-500);
    color: var(--ims-navy-900);
    border: none;
    border-radius: var(--r-pill-mkt);
    padding: 12px 24px;
    cursor: pointer;
    font-family: inherit;
    font-size: 15px;
  }
  .empty-form .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; gap: 32px; }
    .filter-rail { position: static; }
  }
</style>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.job-card'));
  const empty = document.getElementById('empty-state');
  const checkboxes = document.querySelectorAll<HTMLInputElement>(
    '.filter-rail input[type=checkbox]',
  );
  const reset = document.getElementById('filter-reset');

  function readUrlFilters() {
    const p = new URL(window.location.href).searchParams;
    return {
      specialty: new Set(p.getAll('specialty')),
      state: new Set(p.getAll('state')),
      length: new Set(p.getAll('length')),
    };
  }

  function applyFilters() {
    const f = readUrlFilters();
    let visible = 0;
    for (const card of cards) {
      const sp = card.dataset.specialty || '';
      const st = card.dataset.state || '';
      const ln = card.dataset.length || '';
      const show =
        (f.specialty.size === 0 || f.specialty.has(sp)) &&
        (f.state.size === 0 || f.state.has(st)) &&
        (f.length.size === 0 || f.length.has(ln));
      card.hidden = !show;
      if (show) visible++;
    }
    if (empty) empty.hidden = visible !== 0;
  }

  function syncCheckboxesFromUrl() {
    const f = readUrlFilters();
    checkboxes.forEach((cb) => {
      const set = f[cb.name as keyof typeof f];
      cb.checked = !!set?.has(cb.value);
    });
  }

  function writeUrlFromCheckboxes() {
    const url = new URL(window.location.href);
    url.searchParams.delete('specialty');
    url.searchParams.delete('state');
    url.searchParams.delete('length');
    checkboxes.forEach((cb) => {
      if (cb.checked) url.searchParams.append(cb.name, cb.value);
    });
    history.replaceState({}, '', url.toString());
  }

  // Spec section 0.5.5: filtered URLs (any specialty/state/length param)
  // flip the robots meta directive + retarget canonical to root /jobs.
  // Prevents thin-content indexing of every filter combination.
  // Symmetric: both branches set canonical explicitly so navigation between
  // filtered and unfiltered states cannot leave stale metadata behind.
  function updateRobotsMeta() {
    const params = new URL(window.location.href).searchParams;
    const isFiltered =
      params.has('specialty') || params.has('state') || params.has('length');
    const head = document.head;
    let robots = head.querySelector<HTMLMetaElement>('meta[name="robots"]');
    const can = head.querySelector<HTMLLinkElement>('link[rel="canonical"]');
    // Always retarget canonical to the unfiltered /jobs URL — same value for
    // both branches, since the canonical for the page is the search-less form.
    if (can) {
      const u = new URL(can.href);
      u.search = '';
      can.href = u.toString();
    }
    if (isFiltered) {
      if (!robots) {
        robots = document.createElement('meta');
        robots.name = 'robots';
        head.appendChild(robots);
      }
      robots.content = 'noindex,follow';
    } else if (robots) {
      robots.remove();
    }
  }

  syncCheckboxesFromUrl();
  applyFilters();
  updateRobotsMeta();
  checkboxes.forEach((cb) =>
    cb.addEventListener('change', () => {
      writeUrlFromCheckboxes();
      applyFilters();
      updateRobotsMeta();
    }),
  );
  reset?.addEventListener('click', () => {
    checkboxes.forEach((cb) => {
      cb.checked = false;
    });
    writeUrlFromCheckboxes();
    applyFilters();
    updateRobotsMeta();
  });
  window.addEventListener('popstate', () => {
    syncCheckboxesFromUrl();
    applyFilters();
    updateRobotsMeta();
  });
</script>
