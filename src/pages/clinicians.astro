---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
---
<MarketingLayout title="For Clinicians — Innovative Medical Staffing" description="From CV to first shift in four clear steps. One recruiter for life, Friday pay, malpractice covered." inCard={false}>
  <SiteNav slot="nav" />

  <div class="atmosphere atmosphere--mint" aria-hidden="true"></div>
  <div class="atmosphere atmosphere--coral" aria-hidden="true"></div>
  <div class="atmosphere atmosphere--butter" aria-hidden="true"></div>

  <!-- ─────── Variation C: Career timeline ─────── -->
  <div class="variation">
    <section class="cc__hero">
      <div class="hero__blob hero__blob--lilac" aria-hidden="true" style="top: -140px; right: -100px; opacity: 0.35;"></div>
      <div class="hero__blob hero__blob--coral" aria-hidden="true" style="bottom: -100px; left: -60px; opacity: 0.28;"></div>
      <div class="hero__blob hero__blob--butter" aria-hidden="true" style="top: 40%; right: 20%; width: 220px; height: 220px; opacity: 0.28;"></div>
      <div class="container hero-stage">
        <span class="cc__hero-eyebrow" style="--i:0">For clinicians · the IMS process</span>
        <h1 class="cc__hero-title" style="--i:1">From CV to <span>first shift</span> in four clear steps.</h1>
        <p class="cc__hero-sub" style="--i:2">No "we'll get back to you when we get to it." A real recruiter, on the phone, within one business day. Here's exactly what happens at each step.</p>
      </div>
    </section>

    <section class="cc__timeline">
      <div class="container">
        <div class="cc__timeline-track scroll-reveal">
          <div class="cc__timeline-line"></div>

          <div class="cc__step cc__step--01 scroll-reveal" style="--i:0">
            <div class="cc__step-node">01</div>
            <div class="cc__step-card">
              <span class="cc__step-label">Day 1 · First call</span>
              <h3 class="cc__step-title">Submit your <span>CV</span>.</h3>
              <p class="cc__step-body">One real recruiter reads it, usually the same day. They'll call you back within one business day to talk specialty, geography, schedule, and what you're looking for.</p>
              <ul class="cc__step-bullets">
                <li>Direct call from your future recruiter, not a coordinator</li>
                <li>20–30 minute conversation, no scripted screening</li>
                <li>We listen first, pitch second</li>
              </ul>
            </div>
          </div>

          <div class="cc__step cc__step--02 scroll-reveal" style="--i:1">
            <div class="cc__step-node">02</div>
            <div class="cc__step-card">
              <span class="cc__step-label">Step 2 · onboarding</span>
              <h3 class="cc__step-title">Credentialing support and <span>onboarding</span>.</h3>
              <p class="cc__step-body">Credentialing typically lands in under 60 days, and when a start can't wait, we can push emergency credentialing through in a few weeks. You stay focused on practicing.</p>
              <ul class="cc__step-bullets">
                <li>Typically under 60 days</li>
                <li>Emergency credentialing when timing is tight</li>
                <li>Malpractice covered</li>
              </ul>
            </div>
          </div>

          <div class="cc__step cc__step--03 scroll-reveal" style="--i:2">
            <div class="cc__step-node">03</div>
            <div class="cc__step-card">
              <span class="cc__step-label">Step 3 · scheduling</span>
              <h3 class="cc__step-title">Schedule your <span>assignments</span>.</h3>
              <p class="cc__step-body">Work with your recruiter to tailor assignments to your life, not the other way around. Coverage, long-stay, call-only, all options on the table.</p>
              <ul class="cc__step-bullets">
                <li>Transparent rates before you accept</li>
                <li>Assignments matched to your specialty and schedule</li>
                <li>One recruiter sees the whole picture</li>
              </ul>
            </div>
          </div>

          <div class="cc__step cc__step--04 scroll-reveal" style="--i:3">
            <div class="cc__step-node">04</div>
            <div class="cc__step-card">
              <span class="cc__step-label">Step 4 · start working</span>
              <h3 class="cc__step-title">Start your <span>first shift</span>.</h3>
              <p class="cc__step-body">You walk into a facility with a team that's expecting you, and a recruiter who stays in your corner. Friday is payday, direct deposit, every Friday.</p>
              <ul class="cc__step-bullets">
                <li>Direct-deposit payroll every Friday</li>
                <li>Real humans answer the phone</li>
                <li>Your recruiter, still one phone call away</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cc__why-section">
      <div class="container">
        <div class="section-anchor reveal-group">
          <div reveal style="--i:0">
            <span class="eyebrow"><span class="eyebrow__dot"></span>§ 05 · Why clinicians stay</span>
            <h2 class="section-anchor__heading">Four things we <span class="em">always</span> include.</h2>
          </div>
          <p class="section-anchor__sub" reveal style="--i:1">Country-club-level concierge support: one dedicated recruiter, transparent rates, and the steady details most agencies promise but don't deliver. We treat you like family and make sure you're happy, always.</p>
        </div>
        <div class="cc__why-grid reveal-group">
          <article class="cc__why-card cc__why-card--coral reveal" style="--i:0">
            <div class="cc__why-num">$</div>
            <h3 class="cc__why-title">Transparent rates</h3>
            <p class="cc__why-body">You see the rate before you accept. No surprises buried in the contract.</p>
          </article>
          <article class="cc__why-card cc__why-card--butter reveal" style="--i:1">
            <div class="cc__why-num">☎</div>
            <h3 class="cc__why-title">Friday pay</h3>
            <p class="cc__why-body">Direct-deposit payroll every Friday. A small thing, until you've worked with an agency that can't manage it.</p>
          </article>
          <article class="cc__why-card cc__why-card--rose reveal" style="--i:2">
            <div class="cc__why-num">♥</div>
            <h3 class="cc__why-title">One recruiter, your career</h3>
            <p class="cc__why-body">No rotating queue. The person who places you the first time is the person who calls you the fifteenth.</p>
          </article>
          <article class="cc__why-card cc__why-card--lilac reveal" style="--i:3">
            <div class="cc__why-num">🛡</div>
            <h3 class="cc__why-title">Malpractice covered</h3>
            <p class="cc__why-body">Malpractice covered on every assignment, plus licensing support along the way.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="cc__quotes-section">
      <div class="container">
        <div class="section-anchor reveal-group">
          <div reveal style="--i:0">
            <span class="eyebrow"><span class="eyebrow__dot" style="background: var(--pop-coral);"></span>§ 06 · From the roster</span>
            <h2 class="section-anchor__heading">Don't take our <span class="em">word for it</span>.</h2>
          </div>
          <p class="section-anchor__sub" reveal style="--i:1">Three quick reads from clinicians currently on the IMS roster.</p>
        </div>
        <div class="cc__quotes-grid reveal-group">
          <article class="cc__quote cc__quote--rose reveal" style="--i:0">
            <p class="cc__quote-text">"At other agencies I'd be talking to a salesperson. With IMS, the person setting up my assignments has <em>actually worked anesthesia</em>, so when they say a site's a good fit, they're right. Straight with me from day one."</p>
            <div class="cc__quote-attr">
              <div class="cc__quote-avatar" style="background: var(--pop-magenta);">MR</div>
              <div>
                <b>Maya Reyes, CRNA</b>
                <small>Mountain West · 14 placements</small>
              </div>
            </div>
          </article>
          <article class="cc__quote cc__quote--butter reveal" style="--i:1">
            <p class="cc__quote-text">"Three years in, what's kept me here is the people. The other clinicians IMS places alongside me are <em>genuinely good</em> to work with, and that's the part you can't fake."</p>
            <div class="cc__quote-attr">
              <div class="cc__quote-avatar" style="background: var(--pop-coral);">JK</div>
              <div>
                <b>Dr. Jamie Kang</b>
                <small>Anesthesiology · 3 years with IMS</small>
              </div>
            </div>
          </article>
          <article class="cc__quote cc__quote--mint reveal" style="--i:2">
            <p class="cc__quote-text">"They walked me through getting privileged without the runaround and have been honest with me start to finish. After a few assignments, I <em>stopped looking</em> anywhere else."</p>
            <div class="cc__quote-attr">
              <div class="cc__quote-avatar" style="background: var(--pop-butter); color: var(--ink);">RP</div>
              <div>
                <b>Dr. Rae Patel</b>
                <small>Emergency medicine · with IMS since 2023</small>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="cc__cta">
      <div class="container">
        <div class="cc__cta-card scroll-reveal">
          <div class="cc__cta-card__blob" aria-hidden="true"></div>
          <span class="cc__cta-card__eyebrow">Submit your CV</span>
          <h2 class="cc__cta-card__title">Start the <span>conversation</span>.</h2>
          <p class="cc__cta-card__sub">Send your CV and we'll be in touch within one business day. Or browse open jobs first, both work.</p>
          <div class="cc__cta-card__row">
            <a class="pill pill--swing pill--swing--mint" href="/contact"><span>Submit your CV</span><span class="pill__puck">→</span></a>
            <a class="pill pill--secondary" href="/jobs" style="border-color: var(--cream-soft); color: var(--cream-soft);">See open jobs <span class="pill__arrow">→</span></a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  /* ============================================================
   * Seamless flow, cream throughout, color via cards, atmospheric blobs.
   * Page-wide body bg + overflow-x:clip come from kit.css; no scoped body{}
   * rule here (Astro mangles the `body` selector so it never matches).
   * (Marquee CSS dropped — clinicians has no marquee section.)
   * ============================================================ */

  /* Variation A · mint hero: mint card on cream */
  .ca__hero { background: transparent !important; padding: var(--space-7) 0 !important; }
  .ca__hero .container {
    background: var(--soft-mint);
    border-radius: 28px;
    padding: var(--space-8) var(--space-7);
    max-width: 1280px;
    position: relative;
    overflow: hidden;
  }
  .ca__why { background: transparent !important; padding: var(--space-7) 0 !important; }

  /* Variation B · stories: each becomes a colored card on cream */
  .cb__hero { background: transparent !important; padding: var(--space-9) 0 var(--space-6) !important; }
  .cb__story {
    background: transparent !important;
    padding: var(--space-6) 0 !important;
  }
  .cb__story .container {
    border-radius: 28px;
    padding: var(--space-8) var(--space-7);
    max-width: 1180px;
    background: var(--soft-butter);
    position: relative;
    overflow: hidden;
  }
  .cb__story--mint .container { background: var(--soft-mint); }
  .cb__story--lilac .container { background: var(--soft-lilac); }
  .cb__cta { background: transparent !important; padding: var(--space-6) 0 var(--space-8) !important; }

  /* Variation C · lilac hero: lilac card on cream */
  .cc__hero { background: transparent !important; padding: var(--space-7) 0 !important; }
  .cc__hero .container {
    background: var(--soft-lilac);
    border-radius: 28px;
    padding: var(--space-7) var(--space-6);
    max-width: 1080px;
    position: relative;
    overflow: hidden;
  }
  .cc__timeline { background: transparent !important; padding: var(--space-7) 0 !important; }
  .cc__cta { background: transparent !important; padding: var(--space-6) 0 var(--space-8) !important; }

  /* Persistent atmospheric blobs, drift across the whole document */
  .atmosphere {
    position: fixed;
    pointer-events: none;
    z-index: 0;
    border-radius: 50%;
    filter: blur(120px);
  }
  .atmosphere--mint {
    width: 600px; height: 600px;
    background: var(--pop-mint);
    opacity: 0.14;
    top: 20vh; right: -200px;
    animation: blobFloatA 28s ease-in-out infinite;
  }
  .atmosphere--coral {
    width: 500px; height: 500px;
    background: var(--pop-coral);
    opacity: 0.10;
    top: 60vh; left: -180px;
    animation: blobFloatB 32s ease-in-out infinite;
  }
  .atmosphere--butter {
    width: 400px; height: 400px;
    background: var(--pop-butter);
    opacity: 0.18;
    bottom: -100px; right: 30%;
    animation: blobFloatC 24s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) { .atmosphere { animation: none; } }
  .variation, .variation-label, .variation-rule { position: relative; z-index: 1; }

  .variation-rule { height: 1px; background: var(--rule-strong); margin: 0; }

  /* ───── Variation A, Job-listing hero (Aya-inspired but original) ───── */
  .ca__hero {
    padding: var(--space-9) 0 var(--space-7);
    background: var(--soft-mint);
    position: relative; overflow: hidden;
  }
  .ca__hero .container {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: var(--space-7); align-items: center;
  }
  @media (max-width: 900px) { .ca__hero .container { grid-template-columns: 1fr; } }
  .ca__hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink);
  }
  .ca__hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(48px, 6.5vw, 104px); line-height: 0.93;
    letter-spacing: -0.04em; color: var(--ink);
    margin: var(--space-3) 0 var(--space-4); max-width: 14ch;
  }
  .ca__hero-title span { color: var(--ink-emphasis); }
  .ca__hero-sub {
    font-family: var(--font-body); font-size: 19px; line-height: 1.55;
    color: var(--ink); margin: 0 0 var(--space-5); max-width: 48ch;
  }
  .ca__hero-cta { display: flex; gap: var(--space-3); flex-wrap: wrap; }

  .ca__jobs-card {
    background: var(--cream-soft);
    border-radius: 22px; padding: var(--space-4);
    box-shadow: 0 18px 48px rgba(31,26,35,0.12);
    display: flex; flex-direction: column; gap: var(--space-2);
  }
  .ca__jobs-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 10px var(--space-3);
    border-bottom: 1px solid var(--rule);
  }
  .ca__jobs-head-label {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute);
  }
  .ca__jobs-head-count {
    font-family: var(--font-display); font-weight: 900; font-size: 22px;
    color: var(--ink); letter-spacing: -0.02em;
  }
  .ca__job {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 14px; align-items: center;
    padding: 12px 12px;
    border-radius: 14px;
    cursor: pointer;
    transition: background 200ms, transform 200ms;
  }
  .ca__job:hover { background: var(--bone); transform: translateX(4px); }
  .ca__job-main { min-width: 0; }
  .ca__job-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: 16px; line-height: 1.15; letter-spacing: -0.012em;
    color: var(--ink); margin: 0 0 2px;
  }
  .ca__job-meta {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-mute); letter-spacing: 0.04em;
  }
  .ca__job-pay {
    font-family: var(--font-display); font-weight: 900;
    font-size: 18px; color: var(--ink-emphasis);
    letter-spacing: -0.015em; white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .ca__job-arrow {
    width: 28px; height: 28px; border-radius: 999px;
    background: var(--ink); color: var(--cream-soft);
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px;
    transition: transform 220ms;
    flex-shrink: 0;
  }
  .ca__job:hover .ca__job-arrow { transform: rotate(-45deg); }

  .ca__why { padding: var(--space-9) 0; background: var(--cream); }
  .ca__why-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 900px) { .ca__why-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .ca__why-grid { grid-template-columns: 1fr; } }
  .ca__why-card {
    padding: var(--space-5);
    border-radius: 18px;
    display: flex; flex-direction: column; gap: 10px;
    min-height: 200px;
  }
  .ca__why-card--coral { background: var(--soft-coral); }
  .ca__why-card--butter { background: var(--soft-butter); }
  .ca__why-card--rose { background: var(--soft-rose); }
  .ca__why-card--lilac { background: var(--soft-lilac); }
  .ca__why-num {
    font-family: var(--font-display); font-weight: 900;
    font-size: 48px; line-height: 0.85; letter-spacing: -0.04em;
    color: var(--ink);
  }
  .ca__why-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: 20px; line-height: 1.05; letter-spacing: -0.018em;
    color: var(--ink); margin: 0;
  }
  .ca__why-body {
    font-family: var(--font-body); font-size: 13px; line-height: 1.5;
    color: var(--ink); margin: 0;
  }

  /* ───── Variation B, Story-driven testimonials ───── */
  .cb__hero {
    padding: var(--space-10) 0 var(--space-7);
    background: var(--cream);
    text-align: center; position: relative;
  }
  .cb__hero .container { display: flex; flex-direction: column; align-items: center; gap: var(--space-5); position: relative; z-index: 1; }
  .cb__hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute);
  }
  .cb__hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(52px, 8vw, 128px); line-height: 0.92;
    letter-spacing: -0.04em; color: var(--ink); margin: 0;
    max-width: 18ch;
  }
  .cb__hero-title span { color: var(--ink-emphasis); }
  .cb__hero-sub {
    font-family: var(--font-body); font-size: 20px; line-height: 1.55;
    color: var(--ink-soft); max-width: 56ch; margin: 0;
  }

  .cb__story {
    padding: var(--space-9) 0;
    background: var(--soft-butter);
  }
  .cb__story-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: var(--space-7); align-items: center;
    max-width: 1100px; margin: 0 auto;
  }
  @media (max-width: 900px) { .cb__story-grid { grid-template-columns: 1fr; } }
  .cb__story--reverse .cb__story-grid > div:first-child { order: 2; }
  @media (max-width: 900px) { .cb__story--reverse .cb__story-grid > div:first-child { order: 0; } }
  .cb__story-quote {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(28px, 4vw, 52px); line-height: 1.12;
    letter-spacing: -0.025em; color: var(--ink);
    margin: 0 0 var(--space-4);
  }
  .cb__story-quote em { font-style: normal; color: var(--ink-emphasis); }
  .cb__story-attr {
    display: flex; align-items: center; gap: 14px;
    padding-top: var(--space-4); border-top: 1px solid rgba(31, 26, 35, 0.18);
  }
  .cb__story-avatar {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--ink); color: var(--cream-soft);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 900;
    font-size: 22px; letter-spacing: -0.02em;
  }
  .cb__story-attr b {
    font-family: var(--font-body); font-weight: 700; font-size: 17px;
    color: var(--ink); line-height: 1.1; display: block;
  }
  .cb__story-attr small {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-mute); letter-spacing: 0.04em;
  }
  .cb__story-stats {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  .cb__story-stat {
    background: var(--cream-soft);
    border-radius: 16px; padding: var(--space-4);
  }
  .cb__story-stat-num {
    font-family: var(--font-display); font-weight: 900;
    font-size: 48px; line-height: 0.9; letter-spacing: -0.04em;
    color: var(--ink-emphasis); font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
  }
  .cb__story-stat-label {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700;
    color: var(--ink);
  }
  .cb__story--mint { background: var(--soft-mint); }
  .cb__story--lilac { background: var(--soft-lilac); }

  .cb__cta { padding: var(--space-9) 0; }

  /* ───── Variation C, Career timeline ───── */
  .cc__hero {
    padding: var(--space-9) 0 var(--space-7);
    background: var(--soft-lilac);
    position: relative;
    /* No overflow clip, blobs bleed up past the section edge into
       the nav area, matching the main site hero. */
  }
  .cc__hero .container { display: flex; flex-direction: column; align-items: center; gap: var(--space-5); text-align: center; }
  .cc__hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink);
  }
  .cc__hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(48px, 7vw, 104px); line-height: 0.94;
    letter-spacing: -0.04em; color: var(--ink); margin: 0;
    max-width: 18ch;
  }
  .cc__hero-title span { color: var(--ink-emphasis); }
  .cc__hero-sub {
    font-family: var(--font-body); font-size: 19px; line-height: 1.5;
    color: var(--ink); max-width: 56ch; margin: 0;
  }

  .cc__timeline { padding: var(--space-9) 0; background: var(--cream); }
  .cc__timeline-track {
    position: relative; max-width: 920px; margin: 0 auto;
    padding-left: 80px;
  }
  @media (max-width: 760px) { .cc__timeline-track { padding-left: 60px; } }
  .cc__timeline-line {
    position: absolute; left: 38px; top: 12px; bottom: 12px;
    width: 2px;
    background: linear-gradient(to bottom, var(--pop-coral), var(--pop-mint), var(--pop-lilac), var(--pop-magenta));
  }
  @media (max-width: 760px) { .cc__timeline-line { left: 28px; } }
  .cc__step {
    position: relative;
    padding-bottom: var(--space-7);
  }
