---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SiteNav from '../components/nav/SiteNav.astro';
import SiteFooter from '../components/footer/SiteFooter.astro';
---

<MarketingLayout title="About — Innovative Medical Staffing" description="A boutique locum firm built differently. Founded 2018 in Fort Worth, TX." inCard={false}>
  <SiteNav slot="nav" />

  <div class="atmosphere atmosphere--lilac" aria-hidden="true"></div>
  <div class="atmosphere atmosphere--butter" aria-hidden="true"></div>
  <div class="atmosphere atmosphere--coral" aria-hidden="true"></div>

  <div class="page-content">

    <section class="au__hero au-section">
      <div class="container hero-stage">
        <span class="au__hero-eyebrow" style="--i:0">About IMS · since 2018 · Fort Worth, TX</span>
        <h1 class="au__hero-title" style="--i:1">A boutique firm, <span>built differently</span>.</h1>
        <p class="au__hero-sub" style="--i:2">Founded by three industry leaders who watched the staffing model break from the inside, then built the one they wished existed.</p>
      </div>
    </section>

    <section class="au__mission au-section">
      <div class="container scroll-reveal">
        <div class="au__mission-eyebrow">Our mission</div>
        <p class="au__mission-text">To transform medical staffing through exceptional support and tailored placements, by creating a <span>family-oriented environment</span> that promotes growth, satisfaction, and the highest standard of patient care.</p>
      </div>
    </section>

    <section class="au__pillars au-section">
      <div class="container">
        <div class="section-anchor reveal-group">
          <div class="reveal" style="--i:0">
            <span class="eyebrow"><span class="eyebrow__dot"></span>§ 02 · What we stand for</span>
            <h2 class="section-anchor__heading">Three principles. <span class="em">Zero exceptions</span>.</h2>
          </div>
          <p class="section-anchor__sub reveal" style="--i:1">Everything we do is built on three commitments, to clinicians, to facilities, and to the way we run the firm.</p>
        </div>
        <div class="au__pillars-grid reveal-group">
          <article class="au__pillar au__pillar--01 reveal" style="--i:0">
            <div class="au__pillar-num">01</div>
            <h3 class="au__pillar-title">Dedicated support for clinicians.</h3>
            <p class="au__pillar-body">Personalized placements. One recruiter for the life of your career. A family-oriented environment that doesn't pretend to be one.</p>
            <ul class="au__pillar-list">
              <li>One recruiter, never rotated</li>
              <li>Concierge travel + lodging</li>
              <li>Friday direct deposit, always</li>
            </ul>
          </article>
          <article class="au__pillar au__pillar--02 reveal" style="--i:1">
            <div class="au__pillar-num">02</div>
            <h3 class="au__pillar-title">Exceptional service for facilities.</h3>
            <p class="au__pillar-body">Long-term partnerships, not transactional placements. Three vetted candidates. The kind your care team asks to book again.</p>
            <ul class="au__pillar-list">
              <li>Three real candidates, not thirty</li>
              <li>One account lead, same number</li>
              <li>Net-15 invoicing, line-itemized</li>
            </ul>
          </article>
          <article class="au__pillar au__pillar--03 reveal" style="--i:2">
            <div class="au__pillar-num">03</div>
            <h3 class="au__pillar-title">Streamlined onboarding & credentialing.</h3>
            <p class="au__pillar-body">Primary-source verification, licensing, and DEA inside 14 days, every time.</p>
            <ul class="au__pillar-list">
              <li>Primary-source verification</li>
              <li>14-day average turnaround</li>
              <li>$2M / $4M malpractice included</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="au__team au-section">
      <div class="container">
        <div class="section-anchor reveal-group">
          <div class="reveal" style="--i:0">
            <span class="eyebrow"><span class="eyebrow__dot"></span>§ 03 · The team</span>
            <h2 class="section-anchor__heading">The people behind <span class="em">every placement</span>.</h2>
          </div>
          <p class="section-anchor__sub reveal" style="--i:1">Founders, leadership, and the recruiting + credentialing teams who personally manage every assignment IMS sends.</p>
        </div>

        <div class="au__team-group">
          <div class="au__team-label">Founders</div>
          <div class="au__team-grid au__team-grid--3 reveal-group">
            <article class="au__member reveal" style="--i:0">
              <div class="au__member-portrait" style="background: var(--pop-coral);">MD</div>
              <h3 class="au__member-name">Matthew Draughon</h3>
              <span class="au__member-role">Founder</span>
              <span class="au__member-loc">Charlotte, NC · Baylor & Wake Forest</span>
            </article>
            <article class="au__member reveal" style="--i:1">
              <div class="au__member-portrait" style="background: var(--pop-butter); color: var(--ink);">BT</div>
              <h3 class="au__member-name">Brent Toland</h3>
              <span class="au__member-role">Founder</span>
              <span class="au__member-loc">Germantown, TN · Baylor & Drexel</span>
            </article>
            <article class="au__member reveal" style="--i:2">
              <div class="au__member-portrait" style="background: var(--pop-lilac);">JS</div>
              <h3 class="au__member-name">Jonathan Silva</h3>
              <span class="au__member-role">Founder</span>
              <span class="au__member-loc">Waxhaw, NC · Minnesota & Baylor</span>
            </article>
          </div>
        </div>

        <div class="au__team-group">
          <div class="au__team-label">Leadership</div>
          <div class="au__team-grid au__team-grid--3 reveal-group">
            <article class="au__member reveal" style="--i:0">
              <div class="au__member-portrait" style="background: var(--pop-lilac);">DK</div>
              <h3 class="au__member-name">Donovan Kading</h3>
              <span class="au__member-role">Practice Manager</span>
              <span class="au__member-loc">Greensboro, NC · Originally San Angelo, TX</span>
            </article>
            <article class="au__member reveal" style="--i:1">
              <div class="au__member-portrait" style="background: var(--pop-rose);">ZY</div>
              <h3 class="au__member-name">Zachary Young</h3>
              <span class="au__member-role">Marketing Director</span>
              <span class="au__member-loc">Greensboro, NC · High Point University</span>
            </article>
            <article class="au__member reveal" style="--i:2">
              <div class="au__member-portrait" style="background: var(--pop-sky); color: var(--ink);">CN</div>
              <h3 class="au__member-name">Chad Nachtigal</h3>
              <span class="au__member-role">Head of Recruiting</span>
              <span class="au__member-loc">Fort Worth, TX · Former US Army Major</span>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="au__stats au-section">
      <div class="container">
        <div class="au__stats-blob" aria-hidden="true"></div>
        <div class="au__stats-eyebrow">By the numbers</div>
        <h2 class="au__stats-title">Boutique <span>by design</span>.</h2>
        <p style="font-family: var(--font-body); font-size: 17px; line-height: 1.55; color: rgba(251,246,238,0.75); margin: calc(-1 * var(--space-4)) 0 var(--space-6); max-width: 56ch; position: relative; z-index: 1;">A small team in one office in Fort Worth, working with facilities in 47 states. The numbers stay small on purpose, the relationships are what matter.</p>
        <div class="au__stats-grid reveal-group">
          <div class="reveal" style="--i:0">
            <div class="au__stat-num au__stat-num--coral tabular">47</div>
            <div class="au__stat-label">States staffed</div>
          </div>
          <div class="reveal" style="--i:1">
            <div class="au__stat-num au__stat-num--butter tabular">2018</div>
            <div class="au__stat-label">Year founded</div>
          </div>
          <div class="reveal" style="--i:2">
            <div class="au__stat-num au__stat-num--mint tabular" style="font-size: clamp(40px, 5vw, 72px);">All</div>
            <div class="au__stat-label">Specialties staffed</div>
          </div>
          <div class="reveal" style="--i:3">
            <div class="au__stat-num au__stat-num--lilac tabular">94%</div>
            <div class="au__stat-label">Facility rebook rate</div>
          </div>
        </div>
      </div>
    </section>

  </div>

  <SiteFooter slot="footer" />
</MarketingLayout>

<style>
  /* Page-wide body bg + overflow-x:clip come from kit.css; no scoped body{}
   * rule here (Astro mangles the `body` selector so it never matches). */
  /* Atmospheric blobs */
  .atmosphere { position: fixed; pointer-events: none; z-index: 0; border-radius: 50%; filter: blur(120px); }
  .atmosphere--lilac { width: 600px; height: 600px; background: var(--pop-lilac); opacity: 0.14; top: 20vh; right: -200px; animation: blobFloatA 28s ease-in-out infinite; }
  .atmosphere--butter { width: 500px; height: 500px; background: var(--pop-butter); opacity: 0.16; top: 60vh; left: -180px; animation: blobFloatB 32s ease-in-out infinite; }
  .atmosphere--coral { width: 400px; height: 400px; background: var(--pop-coral); opacity: 0.12; bottom: -100px; right: 30%; animation: blobFloatC 24s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) { .atmosphere { animation: none; } }
  .page-content { position: relative; z-index: 1; }

  .au-section { padding: var(--space-7) 0; position: relative; }

  /* Hero */
  .au__hero { padding: var(--space-10) 0 var(--space-7); text-align: center; }
  .au__hero .container { display: flex; flex-direction: column; align-items: center; gap: var(--space-5); }
  .au__hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute);
  }
  .au__hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(56px, 8vw, 128px); line-height: 0.94;
    letter-spacing: -0.04em; color: var(--ink); margin: 0;
    max-width: 18ch;
  }
  .au__hero-title span { color: var(--ink-emphasis); }
  .au__hero-sub {
    font-family: var(--font-body); font-size: 20px; line-height: 1.55;
    color: var(--ink-soft); max-width: 60ch; margin: 0;
  }

  /* Mission line */
  .au__mission .container {
    max-width: 920px;
    background: var(--soft-butter);
    border-radius: 28px;
    padding: var(--space-7) var(--space-6);
    text-align: center;
  }
  .au__mission-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute); margin-bottom: var(--space-3);
  }
  .au__mission-text {
    font-family: var(--font-body); font-weight: 600;
    font-size: clamp(20px, 2.2vw, 28px); line-height: 1.45;
    letter-spacing: -0.005em; color: var(--ink); margin: 0;
  }
  .au__mission-text span { color: var(--ink-emphasis); }

  /* Pillars (from C) */
  .au__pillars .container { max-width: 1180px; }
  .au__pillars-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4);
  }
  @media (max-width: 900px) { .au__pillars-grid { grid-template-columns: 1fr; } }
  .au__pillar {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    border-radius: 24px;
    padding: var(--space-6) var(--space-5);
    display: flex; flex-direction: column; gap: var(--space-3);
    transition: transform 280ms var(--ease-out), box-shadow 280ms;
    min-height: 320px;
    border-top: 4px solid var(--pop-coral);
  }
  .au__pillar:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(31,26,35,0.08); }
  .au__pillar--01 { border-top-color: var(--pop-coral); }
  .au__pillar--02 { border-top-color: var(--pop-butter); }
  .au__pillar--03 { border-top-color: var(--pop-lilac); }
  .au__pillar-num {
    font-family: var(--font-display); font-weight: 900;
    font-size: 64px; line-height: 0.9; letter-spacing: -0.04em;
    color: var(--ink); margin-bottom: var(--space-2);
  }
  .au__pillar-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: 26px; line-height: 1.05; letter-spacing: -0.024em;
    color: var(--ink); margin: 0;
  }
  .au__pillar-body {
    font-family: var(--font-body); font-size: 15px; line-height: 1.55;
    color: var(--ink); margin: 0;
  }
  .au__pillar-list {
    list-style: none; padding: var(--space-3) 0 0; margin: 0;
    border-top: 1px solid rgba(31, 26, 35, 0.15);
    display: flex; flex-direction: column; gap: 6px;
  }
  .au__pillar-list li {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-body); font-size: 13px; color: var(--ink); font-weight: 500;
  }
  .au__pillar-list li::before {
    content: '✓';
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--ink); color: var(--cream-soft);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700; flex-shrink: 0;
  }

  /* Team grid (from B) */
  .au__team .container { max-width: 1280px; }
  .au__team-group { margin-bottom: var(--space-7); }
  .au__team-group:last-child { margin-bottom: 0; }
  .au__team-label {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-mute); margin-bottom: var(--space-4);
    display: flex; align-items: center; gap: 10px;
  }
  .au__team-label::after { content: ''; flex: 1; height: 1px; background: var(--rule); }
  .au__team-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4);
  }
  @media (max-width: 1024px) { .au__team-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px) { .au__team-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .au__team-grid { grid-template-columns: 1fr; } }
  .au__team-grid--3 { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 760px) { .au__team-grid--3 { grid-template-columns: 1fr; } }
  .au__member {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    border-radius: 20px;
    padding: var(--space-5);
    display: flex; flex-direction: column; gap: var(--space-3);
    transition: transform 280ms var(--ease-out), box-shadow 280ms;
  }
  .au__member:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(31,26,35,0.08); }
  .au__member-portrait {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--ink); color: var(--cream-soft);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 900;
    font-size: 22px; letter-spacing: -0.025em;
  }
  .au__member-name {
    font-family: var(--font-display); font-weight: 900;
    font-size: 18px; line-height: 1.1; letter-spacing: -0.02em;
    color: var(--ink); margin: 0;
  }
  .au__member-role {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700;
    color: var(--ink-emphasis);
  }
  .au__member-loc {
    font-family: var(--font-body); font-size: 12px;
    color: var(--ink-soft); margin-top: auto;
    padding-top: var(--space-3); border-top: 1px solid rgba(31,26,35,0.1);
  }

  /* By the numbers (from C) */
  .au__stats .container {
    background: var(--ink); color: var(--cream-soft);
    border-radius: 28px;
    padding: var(--space-8) var(--space-7);
    max-width: 1180px;
    position: relative; overflow: hidden;
  }
  .au__stats-blob {
    position: absolute; pointer-events: none;
    width: 380px; height: 380px; border-radius: 50%;
    background: var(--pop-coral); filter: blur(100px);
    opacity: 0.22; top: -120px; right: -100px;
  }
  .au__stats-eyebrow {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
    color: var(--pop-butter); margin-bottom: var(--space-4);
    position: relative; z-index: 1;
  }
  .au__stats-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(36px, 4.5vw, 64px); line-height: 1.0;
    letter-spacing: -0.025em; color: var(--cream-soft);
    margin: 0 0 var(--space-6); max-width: 20ch;
    position: relative; z-index: 1;
  }
  .au__stats-title span { color: var(--pop-coral); }
  .au__stats-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6);
    position: relative; z-index: 1;
  }
  @media (max-width: 760px) { .au__stats-grid { grid-template-columns: repeat(2, 1fr); } }
  .au__stat-num {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(48px, 6vw, 84px); line-height: 0.9;
    letter-spacing: -0.04em; font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
  }
  .au__stat-num--coral { color: var(--pop-coral); }
  .au__stat-num--butter { color: var(--pop-butter); }
  .au__stat-num--mint { color: var(--pop-mint); }
  .au__stat-num--lilac { color: var(--pop-lilac); }
  .au__stat-label {
    font-family: var(--font-body); font-weight: 600; font-size: 12px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(251,246,238,0.6);
  }
</style>
