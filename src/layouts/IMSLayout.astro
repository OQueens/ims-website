---
import "../styles/ims.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  route?: string;
  noindex?: boolean;
}

const {
  title = "Innovative Medical Staffing — locum tenens staffing, every specialty",
  description = "We place credentialed clinicians into locum tenens assignments across every specialty — one recruiter, their cell, a team that picks up the phone.",
  route = "/",
  noindex = true,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#F4EFEA" />
    <link rel="icon" href="/assets/ims-mark.png" />
    {/* synchronous parser-blocking inline switch: drops the no-js class BEFORE
       first paint so .reveal-onview applies its hidden initial state in the
       JS path. JS-disabled users keep the no-js class and content paints
       visible (per the .no-js override in ims.css). */}
    <script is:inline>document.documentElement.classList.remove("no-js");</script>
    <title>{title}</title>
  </head>
  <body>
    <Nav route={route} />
    <main class="page-fade">
      <slot />
    </main>
    <Footer />
    {/* sitewide scroll-reveal: one-shot, low threshold, unobserved on fire so
       there's no jitter when an element re-enters the viewport. Honors
       prefers-reduced-motion by stamping .is-in immediately (the transition
       is already zeroed in ims.css under that media query). */}
    <script is:inline>
      (function () {
        var els = document.querySelectorAll(".reveal-onview");
        if (!els.length) return;
        var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce || !("IntersectionObserver" in window)) {
          for (var i = 0; i < els.length; i++) els[i].classList.add("is-in");
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          for (var j = 0; j < entries.length; j++) {
            if (entries[j].isIntersecting) {
              entries[j].target.classList.add("is-in");
              io.unobserve(entries[j].target);
            }
          }
        }, { rootMargin: "0px 0px -8% 0px", threshold: 0.12 });
        for (var k = 0; k < els.length; k++) io.observe(els[k]);
      })();
    </script>
  </body>
</html>
