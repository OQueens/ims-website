---
/*
 * MarketingLayout — Chromia-Cream / Magenta-Noir chrome (IMS Design System V3,
 * Claude Design handoff 2026-05-28). Replaces the IMS Dark system.
 *
 * Warm cream page with the chromia dot-grid signature, Battlefin/Fraunces
 * display, Inter body, floating dark pill nav, dark-ink warm footer. The kit's
 * visual system is canonical (see docs/plans/2026-05-28-chromia-cream-port-*).
 *
 * Load-bearing scaffolding kept intact (canonical, OG, Plausible, Schema.org
 * JSON-LD) so verify-build's MarketingLayout source-template invariants stay
 * green. What changed from the dark system:
 *   - Body is cream + dot-grid (global body{} rule in colors_and_type.css)
 *   - Dark `<main class="card">` wrapper is now a no-op; pages own full-bleed
 *     sectioning (inCard retained as deprecated no-op for unported pages)
 *   - color-scheme + theme-color flipped to light/cream
 *   - Fonts self-hosted (CSP font-src 'self'); no Google Fonts
 */

// Self-hosted fonts (CSP font-src 'self' — no Google Fonts) + the ported
// design system. Cascade order is load-bearing: colors_and_type (tokens + base
// type) → kit (components) → palette-active (Magenta Noir overrides).
// V5 reskin (2026-06-12): GT America replaces Inter/Fraunces/JetBrains on
// marketing pages — the @fontsource imports are gone (all marketing styles
// resolve fonts via tokens; v5-reskin.css re-points every font token). The
// cascade order below is load-bearing; v5-reskin.css MUST stay last and MUST
// stay marketing-only (HubLayout never imports it — hub keeps Magenta Noir).
import '../styles/colors_and_type.css';
import '../styles/kit.css';
import '../styles/palette-active.css';
import '../styles/v5-reskin.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** When true (default), wrap page content in a dark elevated card so legacy
   * pages built against the old cream-card layout still have a contained
   * surface to render on. The new dark-system homepage opts out with
   * inCard={false} and owns its full-bleed sectioning. Codex r2 [high] fold:
   * restored to prevent legacy clinicians/facilities/about/etc from rendering
   * inner content directly on the dark page (broken layout). */
  inCard?: boolean;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Innovative Medical Staffing',
  description = 'Locum tenens, refined. Every specialty. One recruiter, their cell, and a team that picks up the phone.',
  noindex = false,
  inCard = true,
  canonical,
  ogImage = '/og-default.png',
} = Astro.props;

// Canonical: pathname only — strip query + hash so /?utm_source=x doesn't
// self-canonicalize. ADD a trailing slash for non-root, non-file paths so the
// canonical + og:url match the ONE form the site actually serves: Cloudflare
// Pages serves prerendered pages at /path/, the middleware 301s on-demand pages
// to /path/, and @astrojs/sitemap already emits /path/. One canonical per page.
let pathname = Astro.url.pathname;
if (pathname !== '/' && !pathname.endsWith('/') && !/\.[^/]+$/.test(pathname)) {
  pathname += '/';
}
const SITE = Astro.site ?? new URL(Astro.url.origin);
const defaultCanonical = new URL(pathname, SITE).toString();
const canonicalUrl = canonical ?? defaultCanonical;

const ogImageAbsolute = /^https?:\/\//.test(ogImage)
  ? ogImage
  : new URL(ogImage, SITE).toString();

// Plausible property key — kept as innovativemedicalstaffing.com so analytics
// stay in one continuous property across the 2026-06-11 imstaffing.ai canonical
// flip (no data gap). Switch to a new imstaffing.ai Plausible site only after
// it's created in the Plausible dashboard, or events are silently dropped.
const PLAUSIBLE_DOMAIN = 'innovativemedicalstaffing.com';
const ORG_JSON_LD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Innovative Medical Staffing',
  url: 'https://imstaffing.ai',
  logo: 'https://imstaffing.ai/ims-logo-mark.png',
  contactPoint: [
    {
      '@type': 'ContactPoint',
      email: 'recruiting@iastaffing.com',
      telephone: '+1-512-524-6686',
      contactType: 'customer service',
      areaServed: 'US',
      availableLanguage: ['English'],
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
      /* Never-invisible failsafe: the .js class above lets CSS hide
       * .scroll-reveal / .hero-stage content before JS reveals it. If the
       * reveal module never runs (chunk-load failure, CSP, flaky network) the
       * content would be stuck invisible. After load, if the module hasn't
       * signalled ready, force-reveal everything so content can never be lost. */
      addEventListener('load', function () {
        setTimeout(function () {
          if (window.__scrollRevealReady) return;
          document.querySelectorAll('.scroll-reveal, .reveal-group').forEach(function (el) { el.classList.add('is-revealed'); });
          document.querySelectorAll('.hero-stage').forEach(function (el) { el.classList.add('hero-go'); });
        }, 1500);
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Innovative Medical Staffing" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:alt" content={title} />
    {ogImage === '/og-default.png' && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#F6F1EA" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- Animated favicon: the blue "I" with flowing blue light. The only way an
         icon actually MOVES across modern browsers is to redraw frames to a
         canvas and swap the tab icon. Gated: skipped for prefers-reduced-motion,
         and PAUSED while the tab is hidden (no background battery cost). On no-JS
         / failure / reduced-motion the static favicon.svg above stays. CSP: inline
         script-src 'self' is allowed; the data: icon href is allowed by img-src data:. -->
    <script is:inline>
      (function () {
        try {
          if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          var c = document.createElement('canvas');
          c.width = c.height = 64;
          var ctx = c.getContext('2d');
          if (!ctx) return;
          // Offscreen layer: the flowing blue is built here, then masked to the I.
          var fl = document.createElement('canvas');
          fl.width = fl.height = 64;
          var flx = fl.getContext('2d');
          if (!flx) return;

          // The REAL IMS "I" art. Same-origin → canvas stays untainted → toDataURL OK.
          var iImg = new Image();
          var iReady = false;
          var ix = 0, iy = 0, iw = 0, ih = 0;
          iImg.onload = function () {
            var asp = iImg.width / iImg.height;
            ih = 0.78 * 64; // match the static favicon sizing
            iw = ih * asp;
            ix = (64 - iw) / 2;
            iy = (64 - ih) / 2;
            iReady = true;
            if (!document.hidden) start();
          };
          iImg.onerror = function () {}; // missing art → stay on the static favicon, no console noise
          iImg.src = '/ims-i.png';

          function tile() {
            var r = 14;
            ctx.beginPath();
            ctx.moveTo(r, 0);
            ctx.arcTo(64, 0, 64, 64, r);
            ctx.arcTo(64, 64, 0, 64, r);
            ctx.arcTo(0, 64, 0, 0, r);
            ctx.arcTo(0, 0, 64, 0, r);
            ctx.closePath();
          }
          function blob(g2, x, y, rad, col) {
            var grad = g2.createRadialGradient(x, y, 0, x, y, rad);
            grad.addColorStop(0, col);
            grad.addColorStop(1, 'rgba(0,0,0,0)');
            g2.fillStyle = grad;
            g2.beginPath();
            g2.arc(x, y, rad, 0, 6.2832);
            g2.fill();
          }

          var t = 0;
          function draw() {
            t += 0.05;
            // 1) build the blue flow field on the offscreen layer
            flx.globalCompositeOperation = 'source-over';
            flx.clearRect(0, 0, 64, 64);
            flx.fillStyle = '#256f95'; // deep-blue base so the I never reads black
            flx.fillRect(0, 0, 64, 64);
            flx.globalCompositeOperation = 'lighter';
            blob(flx, 32 + Math.sin(t) * 5, 22 + Math.cos(t * 0.7) * 15, 18, 'rgba(120,199,232,0.55)');
            blob(flx, 30 + Math.cos(t * 0.9) * 5, 40 + Math.sin(t * 1.2) * 13, 15, 'rgba(173,230,247,0.5)');
            blob(flx, 34 + Math.sin(t * 1.4) * 4, 32 + Math.cos(t * 0.5) * 16, 13, 'rgba(63,179,224,0.6)');
            // 2) clip the flow to the REAL I silhouette
            flx.globalCompositeOperation = 'destination-in';
            flx.drawImage(iImg, ix, iy, iw, ih);
            flx.globalCompositeOperation = 'source-over';
            // 3) main: dark tile + the I-shaped flow composited on top
            ctx.clearRect(0, 0, 64, 64);
            tile();
            ctx.fillStyle = '#0C1C30';
            ctx.fill();
            ctx.drawImage(fl, 0, 0);
          }

          var dyn = null;
          var staticCleared = false;
          var timer = null;
          function frame() {
            draw();
            try {
              var next = document.createElement('link');
              next.rel = 'icon';
              next.type = 'image/png';
              next.href = c.toDataURL('image/png');
              // Clear the static icon <link>s exactly once (not the apple-touch one).
              if (!staticCleared) {
                var olds = document.querySelectorAll('link[rel="icon"]');
                for (var i = 0; i < olds.length; i++) olds[i].parentNode.removeChild(olds[i]);
                staticCleared = true;
              }
              // Remove+append a FRESH <link> each frame (not just .href mutate) —
              // the only pattern Safari reliably re-reads, and it dodges Chrome/FF
              // data-URL caching. Cheap at 64x64 / ~14fps.
              if (dyn && dyn.parentNode) dyn.parentNode.removeChild(dyn);
              document.head.appendChild(next);
              dyn = next;
            } catch (e) {
              stop();
            }
          }
          function start() {
            if (timer || !iReady) return; // wait until the I art has loaded
            frame(); // draw + swap immediately, then keep going
            timer = setInterval(frame, 200); // ~5fps — plenty for the slow flow, ~3x less canvas/toDataURL CPU than 70ms
          }
          function stop() {
            if (timer) {
              clearInterval(timer);
              timer = null;
            }
          }
          document.addEventListener('visibilitychange', function () {
            document.hidden ? stop() : start();
          });
          // start() is kicked off by iImg.onload (and guarded by iReady), so a
          // not-yet-loaded image never tries to animate; static favicon shows first.
        } catch (e) {
          /* leave the static favicon.svg in place */
        }
      })();
    </script>
    <!-- Preload the faces used above the fold (GT America Black display +
         Regular body + Mono eyebrows). 🔴 TRIAL fonts — license before prod. -->
    <link rel="preload" href="/fonts/gt-america/GT-America-Standard-Black-Trial.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/gt-america/GT-America-Standard-Regular-Trial.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/gt-america/GT-America-Mono-Regular-Trial.otf" as="font" type="font/otf" crossorigin />
    <title>{title}</title>
    <!-- Plausible Cloud — privacy-friendly, no cookie banner per spec §0.5.8.
         LEGAL CONTRACT: this is the ONLY third-party telemetry permitted (cookieless,
         no ad/cross-site identifiers). Do NOT add Google Analytics/GTM, a Meta/Facebook
         pixel, or any ad/retargeting tag — /privacy and /cookies state we run no
         advertising or cross-site-tracking tags and do not sell/share data for ads;
         adding one makes those notices FALSE and could forfeit the TDPSA/CCPA no-sale
         posture. If analytics ever changes, update LegalPage.astro LEGAL_CONTENT first. -->
    <script
      is:inline
      defer
      data-domain={PLAUSIBLE_DOMAIN}
      src="https://plausible.io/js/script.tagged-events.js"
    ></script>
    <!-- Schema.org Organization — spec §6 -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(ORG_JSON_LD)}
    />
  </head>
  <body class="marketing">
    <!-- Cloaked staff-login entry: a faint top-left dot that reveals a "Staff
         log in" pill on hover/focus → /hub/login. Hidden on mobile (kit.css). -->
    <a class="cloak-login" href="/hub/login" aria-label="Staff log in">
      <span class="cloak-login__dot" aria-hidden="true"></span>
      <span class="cloak-login__pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
        Staff log in
      </span>
    </a>
    <slot name="nav" />
    {inCard ? (
      <main id="main" class="card">
        <slot />
      </main>
    ) : (
      <main id="main" class="full-bleed">
        <slot />
      </main>
    )}
    <slot name="footer" />
    <!-- Site-wide scroll-reveal observer + hero entrance. Inline (is:inline)
         so it can never fail to fetch independently of the html.js flag that
         hides .scroll-reveal — closing the never-invisible gap. -->
    <script is:inline>
      (function () {
        var prefersReduced =
          window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        // Signal the head failsafe that reveal logic is live.
        window.__scrollRevealReady = true;

        function revealAll() {
          document.querySelectorAll('.scroll-reveal, .reveal-group').forEach(function (el) {
            el.classList.add('is-revealed');
          });
        }

        if (!('IntersectionObserver' in window) || prefersReduced) {
          revealAll();
        } else {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                var el = entry.target;
                // For a reveal-group, the ANIMATED elements are the children, so
                // promote (and later tear down) the children, not just the container.
                var kids = el.classList.contains('reveal-group')
                  ? el.querySelectorAll(':scope > .reveal')
                  : [];
                el.style.willChange = 'opacity, transform';
                kids.forEach(function (k) { k.style.willChange = 'opacity, transform'; });
                var legacyDelay = Number(el.dataset.revealDelay || 0);
                var clearWillChange = function () {
                  el.style.willChange = '';
                  kids.forEach(function (k) { k.style.willChange = ''; });
                };
                var apply = function () { el.classList.add('is-revealed'); };
                legacyDelay > 0 ? setTimeout(apply, legacyDelay) : apply();
                if (kids.length) {
                  // Group cascade: a child's transitionend would fire on the FIRST
                  // child and clear prematurely. Clear via timeout after the whole
                  // capped cascade (reveal 620ms + max 5*80ms stagger ≈ 1020ms).
                  setTimeout(clearWillChange, 1600 + legacyDelay);
                } else {
                  el.addEventListener('transitionend', clearWillChange, { once: true });
                  // Failsafe: clear even if no transition fires (already-final state).
                  setTimeout(clearWillChange, 1200 + legacyDelay);
                }
                observer.unobserve(el);
              });
            },
            { rootMargin: '0px 0px -12% 0px', threshold: 0 },
          );
          document.querySelectorAll('.scroll-reveal, .reveal-group').forEach(function (el) {
            observer.observe(el);
          });
        }

        // Hero entrance: paint the offset first, then play one frame later.
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            document.querySelectorAll('.hero-stage').forEach(function (el) {
              el.classList.add('hero-go');
            });
          });
        });
      })();
    </script>
    <!-- Action-puck hover color-cycle (Palette A): pucks keep their NORMAL
         colors at rest; while you HOVER the button they cycle through random
         brights, and they ease back to normal when the mouse LEAVES (Zach
         2026-06-15). Bundled from 'self' → CSP-safe. Inline-!important so it
         beats the per-context puck rules. Reduced-motion = a single instant
         color on hover, no looping. Hub never renders these pucks. -->
    <script>
      const PUCK_SEL = '.pill__puck, .topnav__cta__puck, .gt-submit__puck, .jd-submit__puck';
      const PUCK_COLORS = ['#3FB3E0', '#F26A5B', '#7C84E8', '#3DBE85', '#D4569E', '#F2A03D'];
      const PUCK_INK = '#0C1C30';
      const puckReduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const pickPuck = (not) => {
        let c;
        do { c = PUCK_COLORS[(Math.random() * PUCK_COLORS.length) | 0]; } while (c === not);
        return c;
      };
      document.querySelectorAll('.pill, .topnav__cta, .gt-submit, .jd-submit').forEach((host) => {
        if (!host.querySelector(PUCK_SEL)) return;
        let cur = null;
        let timer = null;
        const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
        const paint = () => {
          // Stop if the pointer is no longer over the host even when no
          // mouseleave fired — e.g. the contact/apply form rebuilds the button's
          // puck subtree on a submit error, which can swallow the mouseleave and
          // leave the 700ms cycle flashing random brights on an unhovered button.
          if (!host.matches(':hover')) { stop(); return; }
          // Stop if the host left the DOM OR got hidden mid-hover (e.g. the
          // contact form's success path sets display:none with no mouseleave) —
          // else the timer would run forever. Zero client rects = not rendered.
          if (!host.isConnected || !host.getClientRects().length) { stop(); return; }
          // re-query: the contact + apply forms rebuild the button's puck on error (Codex)
          const live = host.querySelector(PUCK_SEL);
          if (!live) return;
          cur = pickPuck(cur);
          live.style.setProperty('color', PUCK_INK, 'important');
          live.style.setProperty('background-color', cur, 'important');
        };
        host.addEventListener('mouseenter', () => {
          stop();
          paint();
          if (!puckReduce) timer = window.setInterval(paint, 700);
        });
        host.addEventListener('mouseleave', () => {
          stop();
          cur = null;
          // ease back to the puck's normal color (the transition lingers from paint)
          const live = host.querySelector(PUCK_SEL);
          if (live) { live.style.removeProperty('background-color'); live.style.removeProperty('color'); }
        });
      });
    </script>
  </body>
</html>

<style>
  /* Cream bg, dot-grid, body font + color all come from the global body{}
   * rule in colors_and_type.css. No background override here. */
  body.marketing { margin: 0; }
  /* inCard is a deprecated no-op wrapper now — unported pages still pass it
   * but render full-bleed on cream until migrated. */
  main.card,
  main.full-bleed { display: block; }
</style>
