---
/*
 * MarketingLayout — dark IMS chrome (Claude Design handoff 2026-05-12).
 *
 * The Phase-1.A v1 cream-card chrome was retired after Zach reviewed the
 * preview and rejected the warm direction. The replacement is the IMS dark
 * design system from the ims-dark-website bundle: deep navy page, cyan
 * accent, saturated-card vocabulary, Inter throughout.
 *
 * The layout keeps the load-bearing scaffolding intact (canonical, OG,
 * Plausible, Schema.org JSON-LD) so verify-build's MarketingLayout
 * source-template invariants stay green. What changed:
 *   - Body is dark by default (var(--ims-navy-900) via tokens.css)
 *   - The cream `<main class="card">` wrapping is gone; pages now own their
 *     own section layout against a full-bleed dark page
 *   - `inCard` prop is retained as a deprecated no-op for backward compat
 *     until every page is migrated
 *   - theme-color flipped to the new navy
 */

import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** When true (default), wrap page content in a dark elevated card so legacy
   * pages built against the old cream-card layout still have a contained
   * surface to render on. The new dark-system homepage opts out with
   * inCard={false} and owns its full-bleed sectioning. Codex r2 [high] fold:
   * restored to prevent legacy clinicians/facilities/about/etc from rendering
   * inner content directly on the dark page (broken layout). */
  inCard?: boolean;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Innovative Medical Staffing',
  description = 'Locum tenens, refined. Every specialty. One recruiter, their cell — and a team that picks up the phone.',
  noindex = false,
  inCard = true,
  canonical,
  ogImage = '/og-default.png',
} = Astro.props;

// Canonical: pathname only — strip query + hash so /?utm_source=x doesn't
// self-canonicalize. Strip trailing slash for non-root paths to match
// Astro's static emit form.
let pathname = Astro.url.pathname;
if (pathname.length > 1 && pathname.endsWith('/')) {
  pathname = pathname.slice(0, -1);
}
const SITE = Astro.site ?? new URL(Astro.url.origin);
const defaultCanonical = new URL(pathname, SITE).toString();
const canonicalUrl = canonical ?? defaultCanonical;

const ogImageAbsolute = /^https?:\/\//.test(ogImage)
  ? ogImage
  : new URL(ogImage, SITE).toString();

const PLAUSIBLE_DOMAIN = 'innovativemedicalstaffing.com';
const ORG_JSON_LD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Innovative Medical Staffing',
  url: 'https://innovativemedicalstaffing.com',
  logo: 'https://innovativemedicalstaffing.com/ims-logo-mark.png',
  contactPoint: [
    {
      '@type': 'ContactPoint',
      email: 'recruiting@iastaffing.com',
      telephone: '+1-512-524-6686',
      contactType: 'customer service',
      areaServed: 'US',
      availableLanguage: ['English'],
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0B132A" />
    <link rel="icon" href="/ims-logo-mark.png" type="image/png" />
    <title>{title}</title>
    <!-- Plausible Cloud — privacy-friendly, no cookie banner per spec §0.5.8 -->
    <script
      is:inline
      defer
      data-domain={PLAUSIBLE_DOMAIN}
      src="https://plausible.io/js/script.tagged-events.js"
    ></script>
    <!-- Schema.org Organization — spec §6 -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(ORG_JSON_LD)}
    />
  </head>
  <body class="marketing">
    <slot name="nav" />
    {inCard ? (
      <main class="card">
        <slot />
      </main>
    ) : (
      <main class="full-bleed">
        <slot />
      </main>
    )}
    <slot name="footer" />
  </body>
</html>

<style>
  body.marketing {
    background: var(--ims-navy-900);
    color: var(--fg-1);
    font-family: var(--font);
    line-height: 1.6;
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  /* Legacy cream-card pages render their inner content inside a dark
   * elevated surface (not cream). This keeps the wrap visible against
   * the page bg without forcing per-page migration. */
  main.card {
    background: var(--ims-navy-800);
    border-radius: clamp(20px, 4vw, 40px);
    margin: clamp(20px, 4vw, 64px);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  main.full-bleed {
    background: transparent;
    display: block;
  }
</style>
