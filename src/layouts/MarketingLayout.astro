---
/*
 * MarketingLayout — Chromia-Cream / Magenta-Noir chrome (IMS Design System V3,
 * Claude Design handoff 2026-05-28). Replaces the IMS Dark system.
 *
 * Warm cream page with the chromia dot-grid signature, Battlefin/Fraunces
 * display, Inter body, floating dark pill nav, dark-ink warm footer. The kit's
 * visual system is canonical (see docs/plans/2026-05-28-chromia-cream-port-*).
 *
 * Load-bearing scaffolding kept intact (canonical, OG, Plausible, Schema.org
 * JSON-LD) so verify-build's MarketingLayout source-template invariants stay
 * green. What changed from the dark system:
 *   - Body is cream + dot-grid (global body{} rule in colors_and_type.css)
 *   - Dark `<main class="card">` wrapper is now a no-op; pages own full-bleed
 *     sectioning (inCard retained as deprecated no-op for unported pages)
 *   - color-scheme + theme-color flipped to light/cream
 *   - Fonts self-hosted (CSP font-src 'self'); no Google Fonts
 */

// Self-hosted fonts (CSP font-src 'self' — no Google Fonts) + the ported
// design system. Cascade order is load-bearing: colors_and_type (tokens + base
// type) → kit (components) → palette-active (Magenta Noir overrides).
import '@fontsource-variable/inter/index.css';
import '@fontsource-variable/fraunces/index.css';
import '@fontsource-variable/fraunces/standard-italic.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/colors_and_type.css';
import '../styles/kit.css';
import '../styles/palette-active.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** When true (default), wrap page content in a dark elevated card so legacy
   * pages built against the old cream-card layout still have a contained
   * surface to render on. The new dark-system homepage opts out with
   * inCard={false} and owns its full-bleed sectioning. Codex r2 [high] fold:
   * restored to prevent legacy clinicians/facilities/about/etc from rendering
   * inner content directly on the dark page (broken layout). */
  inCard?: boolean;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Innovative Medical Staffing',
  description = 'Locum tenens, refined. Every specialty. One recruiter, their cell — and a team that picks up the phone.',
  noindex = false,
  inCard = true,
  canonical,
  ogImage = '/og-default.png',
} = Astro.props;

// Canonical: pathname only — strip query + hash so /?utm_source=x doesn't
// self-canonicalize. Strip trailing slash for non-root paths to match
// Astro's static emit form.
let pathname = Astro.url.pathname;
if (pathname.length > 1 && pathname.endsWith('/')) {
  pathname = pathname.slice(0, -1);
}
const SITE = Astro.site ?? new URL(Astro.url.origin);
const defaultCanonical = new URL(pathname, SITE).toString();
const canonicalUrl = canonical ?? defaultCanonical;

const ogImageAbsolute = /^https?:\/\//.test(ogImage)
  ? ogImage
  : new URL(ogImage, SITE).toString();

const PLAUSIBLE_DOMAIN = 'innovativemedicalstaffing.com';
const ORG_JSON_LD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Innovative Medical Staffing',
  url: 'https://innovativemedicalstaffing.com',
  logo: 'https://innovativemedicalstaffing.com/ims-logo-mark.png',
  contactPoint: [
    {
      '@type': 'ContactPoint',
      email: 'recruiting@iastaffing.com',
      telephone: '+1-512-524-6686',
      contactType: 'customer service',
      areaServed: 'US',
      availableLanguage: ['English'],
    },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
      /* Never-invisible failsafe: the .js class above lets CSS hide
       * .scroll-reveal / .hero-stage content before JS reveals it. If the
       * reveal module never runs (chunk-load failure, CSP, flaky network) the
       * content would be stuck invisible. After load, if the module hasn't
       * signalled ready, force-reveal everything so content can never be lost. */
      addEventListener('load', function () {
        setTimeout(function () {
          if (window.__scrollRevealReady) return;
          document.querySelectorAll('.scroll-reveal, .reveal-group').forEach(function (el) { el.classList.add('is-revealed'); });
          document.querySelectorAll('.hero-stage').forEach(function (el) { el.classList.add('hero-go'); });
        }, 1500);
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#F4ECDF" />
    <link rel="icon" href="/ims-logo-mark.png" type="image/png" />
    <!-- Preload the display face used above the fold (Battlefin Black 900) -->
    <link rel="preload" href="/fonts/Battlefin-Black.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Battlefin-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <!-- Plausible Cloud — privacy-friendly, no cookie banner per spec §0.5.8 -->
    <script
      is:inline
      defer
      data-domain={PLAUSIBLE_DOMAIN}
      src="https://plausible.io/js/script.tagged-events.js"
    ></script>
    <!-- Schema.org Organization — spec §6 -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(ORG_JSON_LD)}
    />
  </head>
  <body class="marketing">
    <!-- Cloaked staff-login entry: a faint top-left dot that reveals a "Staff
         log in" pill on hover/focus → /hub/login. Hidden on mobile (kit.css). -->
    <a class="cloak-login" href="/hub/login" aria-label="Staff log in">
      <span class="cloak-login__dot" aria-hidden="true"></span>
      <span class="cloak-login__pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
        Staff log in
      </span>
    </a>
    <slot name="nav" />
    {inCard ? (
      <main id="main" class="card">
        <slot />
      </main>
    ) : (
      <main id="main" class="full-bleed">
        <slot />
      </main>
    )}
    <slot name="footer" />
    <!-- Site-wide scroll-reveal observer + hero entrance. Inline (is:inline)
         so it can never fail to fetch independently of the html.js flag that
         hides .scroll-reveal — closing the never-invisible gap. -->
    <script is:inline>
      (function () {
        var prefersReduced =
          window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        // Signal the head failsafe that reveal logic is live.
        window.__scrollRevealReady = true;

        function revealAll() {
          document.querySelectorAll('.scroll-reveal, .reveal-group').forEach(function (el) {
            el.classList.add('is-revealed');
          });
        }

        if (!('IntersectionObserver' in window) || prefersReduced) {
          revealAll();
        } else {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                var el = entry.target;
                // For a reveal-group, the ANIMATED elements are the children, so
                // promote (and later tear down) the children, not just the container.
                var kids = el.classList.contains('reveal-group')
                  ? el.querySelectorAll(':scope > .reveal')
                  : [];
                el.style.willChange = 'opacity, transform';
                kids.forEach(function (k) { k.style.willChange = 'opacity, transform'; });
                var legacyDelay = Number(el.dataset.revealDelay || 0);
                var clearWillChange = function () {
                  el.style.willChange = '';
                  kids.forEach(function (k) { k.style.willChange = ''; });
                };
                var apply = function () { el.classList.add('is-revealed'); };
                legacyDelay > 0 ? setTimeout(apply, legacyDelay) : apply();
                if (kids.length) {
                  // Group cascade: a child's transitionend would fire on the FIRST
                  // child and clear prematurely. Clear via timeout after the whole
                  // capped cascade (reveal 620ms + max 5*80ms stagger ≈ 1020ms).
                  setTimeout(clearWillChange, 1600 + legacyDelay);
                } else {
                  el.addEventListener('transitionend', clearWillChange, { once: true });
                  // Failsafe: clear even if no transition fires (already-final state).
                  setTimeout(clearWillChange, 1200 + legacyDelay);
                }
                observer.unobserve(el);
              });
            },
            { rootMargin: '0px 0px -12% 0px', threshold: 0 },
          );
          document.querySelectorAll('.scroll-reveal, .reveal-group').forEach(function (el) {
            observer.observe(el);
          });
        }

        // Hero entrance: paint the offset first, then play one frame later.
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            document.querySelectorAll('.hero-stage').forEach(function (el) {
              el.classList.add('hero-go');
            });
          });
        });
      })();
    </script>
  </body>
</html>

<style>
  /* Cream bg, dot-grid, body font + color all come from the global body{}
   * rule in colors_and_type.css. No background override here. */
  body.marketing { margin: 0; }
  /* inCard is a deprecated no-op wrapper now — unported pages still pass it
   * but render full-bleed on cream until migrated. */
  main.card,
  main.full-bleed { display: block; }
</style>
