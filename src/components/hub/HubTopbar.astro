---
/* Hub sticky top bar — server-rendered eyebrow date (no client clock), a live
   search (filters the Overview activity feed + pipeline, wired in hub-client.ts)
   and a theme toggle (sun/moon). #top-title is swapped by hub-client.ts on view
   change. Ported from design_handoff_hub. */
interface Props { eyebrow: string; title?: string; }
const { eyebrow, title = 'Overview' } = Astro.props;
---
<header class="hub-top">
  <div class="hub-top__titles">
    <div class="hub-top__eyebrow" id="top-eyebrow">{eyebrow}</div>
    <h1 class="hub-top__title" id="top-title">{title}</h1>
  </div>
  <div class="hub-top__search">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
    <input type="search" id="hub-search" aria-label="Search reqs and clinicians" placeholder="Search reqs, clinicians…" />
  </div>
  <button class="hub-theme-toggle" id="hub-theme-toggle" aria-label="Toggle light/dark theme">
    <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
    <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
  </button>
</header>
