---
/* Hub sidebar — true-black rail, brand + nav + sign out. Nav buttons carry
   data-view; hub-client.ts swaps the active view. Sign out → /hub/auth/logout
   (clears the session cookie). Ported from design_handoff_hub/src/dashboard.html. */
---
<aside class="hub-side">
  <div class="hub-side__brand">
    <img src="/ims-logo-light.png" alt="IMS" />
    <span class="hub-side__brand-tag">Hub</span>
  </div>

  <nav class="hub-nav">
    <span class="hub-nav__label">Desk</span>
    <button class="hub-nav__item is-active" data-view="overview">
      <svg class="hub-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
      Overview
    </button>
    <button class="hub-nav__item" data-view="simulator">
      <svg class="hub-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20V10M10 20V4M16 20v-6M22 20H2"/></svg>
      Rate Simulator
    </button>
    <button class="hub-nav__item" data-view="analytics">
      <svg class="hub-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-6"/></svg>
      Analytics
    </button>
    <button class="hub-nav__item" data-view="sync">
      <svg class="hub-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      Weekly Sync
      <span class="hub-nav__badge">Mon</span>
    </button>
    <button class="hub-nav__item" data-view="costs">
      <svg class="hub-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5h3.5a1.5 1.5 0 0 1 0 3h-2a1.5 1.5 0 0 0 0 3H14"/></svg>
      Costs
    </button>
  </nav>

  <div class="hub-side__foot">
    <a class="hub-signout" href="/hub/auth/logout">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      Sign out
    </a>
  </div>
</aside>
