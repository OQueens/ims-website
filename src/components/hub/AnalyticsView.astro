---
/*
 * Analytics view. REAL data from aggregateAnalytics(ims_jobs + ls_events):
 *   • Active reqs KPI + 3-month trend          (real)
 *   • Reqs opened · 12 mo                        (real)
 *   • Avg days to close                          (LABELED PROXY — first archive
 *     − first receive per assignment; a cancel also archives, so it is NOT a
 *     true time-to-fill)
 *   • Fill rate                                  ("—" — a true fill rate needs
 *     an LS Bids + Agreements feed we don't receive yet)
 *
 * Charts read a JSON data-island (#hub-analytics) the client draws on first
 * open; if the island is empty (DB unconfigured / no history) the client renders
 * an honest empty state, never fabricated seed numbers.
 */
import type { HubAnalytics } from '../../lib/hub/hub-analytics';
import type { LsKpis } from '../../lib/hub/ls-analytics';
interface Props { analytics: HubAnalytics; lsAnalytics?: LsKpis | null; }
const { analytics, lsAnalytics = null } = Astro.props;

const t = analytics.reqsTrend;
const trendChip =
  t.direction === 'up' ? { cls: 'kpi__delta--up', txt: `▲ ${t.pct}% · 3 mo` }
  : t.direction === 'down' ? { cls: 'kpi__delta--down', txt: `▼ ${Math.abs(t.pct)}% · 3 mo` }
  : { cls: 'kpi__delta--flat', txt: '· flat · 3 mo' };

const dtc = analytics.daysToClose;

// ── LocumSmart Sisense KPIs (real, surfaced verbatim) ────────────────────────
// Each headline = the most recent month's value (labeled with its month); shows
// "—" when no snapshot has synced (table empty / pre-migration).
const ls = lsAnalytics;
const MONTH_ABBR = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const monthLabel = (m: string | null) => {
  if (!m) return '';
  const [y, mm] = m.split('-');
  const i = Number(mm) - 1;
  return i >= 0 && i < 12 ? `${MONTH_ABBR[i]} ${y}` : y;
};
const pctF = (x: number | null | undefined) => (x == null ? '—' : (x * 100).toFixed(1) + '%');
const hrsF = (x: number | null | undefined) => (x == null ? '—' : Math.round(x) + 'h');
const moneyF = (x: number | null | undefined) => {
  if (x == null) return '—';
  const a = Math.abs(x);
  if (a >= 1e6) return '$' + (x / 1e6).toFixed(2) + 'M';
  if (a >= 1e3) return '$' + Math.round(x / 1e3) + 'K';
  return '$' + Math.round(x);
};
const lsAsOf = ls?.capturedAt
  ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(new Date(ls.capturedAt))
  : null;

// JSON island for the SVG charts. Escape '<' so a DB-derived org/specialty name
// can never break out of the <script> or inject markup (the script is parsed as
// data, not executed). The client HTML-escapes names again before any innerHTML.
const island = {
  activeReqs: analytics.activeReqs,
  monthly: analytics.monthly,
  specialtyDonut: analytics.specialtyDonut,
  topFacilities: analytics.topFacilities,
  daysToCloseBySpecialty: analytics.daysToCloseBySpecialty,
};
const analyticsJson = JSON.stringify(island).replace(/</g, '\\u003c');
---
<section class="hub-view" data-view="analytics">
  <script id="hub-analytics" type="application/json" is:inline set:html={analyticsJson}></script>
  <div class="grid grid--kpi">
    <div class="kpi"><div class="kpi__accent kpi__accent--magenta"></div>
      <div class="kpi__label">Active reqs</div>
      <div class="kpi__val">{analytics.activeReqs}</div>
      <span class={`kpi__delta ${trendChip.cls}`}>{trendChip.txt}</span>
    </div>
    <div class="kpi"><div class="kpi__accent kpi__accent--cyan"></div>
      <div class="kpi__label">Avg days to close</div>
      <div class="kpi__val">{dtc.avg === null ? '—' : <Fragment>{dtc.avg}<small>d</small></Fragment>}</div>
      <div class="kpi__foot">{dtc.avg === null ? 'Awaiting close-time history' : `proxy · n=${dtc.sample}`}</div>
    </div>
    <div class="kpi"><div class="kpi__accent kpi__accent--butter"></div>
      <div class="kpi__label">Reqs opened</div>
      <div class="kpi__val">{analytics.reqsOpened12mo}</div>
      <div class="kpi__foot">Trailing 12 months</div>
    </div>
    <div class="kpi"><div class="kpi__accent kpi__accent--rose"></div>
      <div class="kpi__label">Fill rate</div>
      <div class="kpi__val">{ls?.fillRate.latest == null ? '—' : pctF(ls.fillRate.latest)}</div>
      <div class="kpi__foot">{ls?.fillRate.latest == null ? 'Awaiting LocumSmart sync' : `LocumSmart · ${monthLabel(ls.fillRate.latestMonth)}`}</div>
    </div>
  </div>

  {ls && (
    <div class="card mt-5">
      <div class="card__head">
        <h2 class="card__title">LocumSmart analytics</h2>
        <span class="subtle">live from your Sisense{lsAsOf ? ` · as of ${lsAsOf}` : ''}</span>
      </div>
      <div class="grid grid--kpi">
        <div class="kpi"><div class="kpi__accent kpi__accent--magenta"></div>
          <div class="kpi__label">Bid acceptance</div>
          <div class="kpi__val">{pctF(ls.bidAcceptance.latest)}</div>
          <div class="kpi__foot">{ls.bidAcceptance.latestMonth ? monthLabel(ls.bidAcceptance.latestMonth) : '—'}</div>
        </div>
        <div class="kpi"><div class="kpi__accent kpi__accent--butter"></div>
          <div class="kpi__label">Speed to bid</div>
          <div class="kpi__val">{hrsF(ls.speedToBidHrs.latest)}</div>
          <div class="kpi__foot">{ls.speedToBidHrs.latestMonth ? `avg · ${monthLabel(ls.speedToBidHrs.latestMonth)}` : '—'}</div>
        </div>
        <div class="kpi"><div class="kpi__accent kpi__accent--cyan"></div>
          <div class="kpi__label">Market share</div>
          <div class="kpi__val">{pctF(ls.marketShare.latest)}</div>
          <div class="kpi__foot">{ls.marketShare.latestMonth ? monthLabel(ls.marketShare.latestMonth) : '—'}</div>
        </div>
        <div class="kpi"><div class="kpi__accent kpi__accent--rose"></div>
          <div class="kpi__label">Invoiced · YTD</div>
          <div class="kpi__val">{moneyF(ls.invoicedThisYear)}</div>
          <div class="kpi__foot">{ls.invoicedYoY == null ? 'this year' : `${ls.invoicedYoY >= 0 ? '▲' : '▼'} ${Math.abs(ls.invoicedYoY * 100).toFixed(0)}% vs prior yr`}</div>
        </div>
      </div>
    </div>
  )}

  <div class="grid grid--2 mt-5">
    <div class="chart-card">
      <div class="card__head"><h2 class="card__title">Reqs opened &amp; days to close</h2><span class="chip"><span class="chip__dot" style="background:var(--pop-magenta,#C44569);"></span>Trailing 12 mo</span></div>
      <svg class="linechart" id="line-chart" viewBox="0 0 600 240" preserveAspectRatio="none"></svg>
      <div style="display:flex; gap:20px; margin-top:12px;">
        <span class="legend__row" style="flex:0;"><span class="legend__sw" style="background:var(--pop-magenta,#C44569);"></span><span class="legend__name">Reqs opened</span></span>
        <span class="legend__row" style="flex:0;"><span class="legend__sw" style="background:var(--mn-cyan,#59BFE7);"></span><span class="legend__name">Avg days to close</span></span>
      </div>
    </div>
    <div class="chart-card">
      <div class="card__head"><h2 class="card__title">Active reqs by specialty</h2></div>
      <div class="donut-wrap">
        <svg class="donut" id="donut" viewBox="0 0 42 42"></svg>
        <div class="legend" id="donut-legend"></div>
      </div>
    </div>
  </div>

  <div class="grid grid--2 mt-5">
    <div class="card">
      <div class="card__head"><h2 class="card__title">Avg days to close by specialty</h2><span class="subtle">proxy</span></div>
      <div class="bars" id="an-filltime"></div>
    </div>
    <div class="card">
      <div class="card__head"><h2 class="card__title">Top facilities by volume</h2></div>
      <div class="bars" id="an-facilities"></div>
    </div>
  </div>
</section>
