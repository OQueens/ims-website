---
/*
 * SiteNav — IMS dark sticky nav. Translated from the ims-dark-website
 * Claude Design handoff (components/Nav.jsx). Three-column grid:
 * logo + wordmark on the left, pill-tabs centered, phone + Apply CTA right.
 *
 * The scroll-hide behavior the cream-card nav had is dropped — the dark
 * blur nav is meant to be visible at all scroll positions per the source
 * design. Pages.dev preview rendering is preserved (sticky + backdrop-filter).
 */
const route = Astro.url.pathname.replace(/\/$/, '') || '/';
const items: { href: string; label: string }[] = [
  { href: '/clinicians',  label: 'Clinicians' },
  { href: '/facilities',  label: 'Facilities' },
  { href: '/jobs',        label: 'Job board' },
  { href: '/about',       label: 'Our story' },
  { href: '/contact',     label: 'Get in touch' },
];
function isActive(href: string) {
  if (href === '/') return route === '/';
  return route === href;
}
---
<header class="nav">
  <div class="inner">
    <a href="/" class="brand" aria-label="Innovative Medical Staffing — home">
      <img src="/ims-logo-light.png" alt="" class="mark" width="120" height="28" />
      <span class="wordmark">
        <span class="wordmark__name">Innovative</span>
        <span class="wordmark__sub">Medical Staffing</span>
      </span>
    </a>

    <nav class="tabs" aria-label="Primary">
      {items.map((it) => (
        <a
          href={it.href}
          class={`tab ${isActive(it.href) ? 'tab--active' : ''}`}
          aria-current={isActive(it.href) ? 'page' : undefined}
        >
          {it.label}
        </a>
      ))}
    </nav>

    <div class="right">
      <a href="tel:+15125246686" class="phone lnk" aria-label="Call IMS">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#7FD0EE" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>
        </svg>
        <span>(512) 524-6686</span>
      </a>
      <a href="/contact" class="cta">
        Apply now
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    background: rgba(11, 19, 42, 0.78);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .inner {
    max-width: 1368px;
    margin: 0 auto;
    padding: 16px 36px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }
  .brand { display: flex; align-items: center; gap: 12px; color: inherit; text-decoration: none; }
  .mark { height: 28px; width: auto; display: block; }
  .wordmark { display: flex; flex-direction: column; line-height: 1; }
  .wordmark__name {
    font: 800 16px/1 var(--font);
    letter-spacing: -0.01em;
    color: var(--fg-1);
  }
  .wordmark__sub {
    font: 500 9px/1 var(--font);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ims-cyan-400);
    margin-top: 5px;
  }
  .tabs {
    display: flex;
    gap: 4px;
    align-items: center;
    background: rgba(255, 255, 255, 0.025);
    border-radius: 999px;
    padding: 4px;
    border: 1px solid rgba(255, 255, 255, 0.04);
  }
  .tab {
    font: 500 14px/1 var(--font);
    letter-spacing: -0.2px;
    color: var(--fg-2);
    text-decoration: none;
    padding: 9px 16px;
    border-radius: 999px;
    transition: color 120ms var(--ease-out), background 200ms var(--ease-out);
  }
  .tab:hover { color: var(--fg-1); }
  .tab--active {
    background: rgba(91, 192, 232, 0.12);
    color: var(--ims-cyan-300);
  }
  .right { display: flex; gap: 12px; align-items: center; justify-content: flex-end; }
  .phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font: 500 13px/1 var(--font);
    color: var(--fg-2);
    padding: 8px 12px;
    border-radius: 999px;
    text-decoration: none;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font: 600 14px/1 var(--font);
    color: var(--ims-navy-900);
    background: var(--ims-cyan-500);
    padding: 10px 18px;
    border-radius: 999px;
    text-decoration: none;
    transition: filter 120ms var(--ease-out);
  }
  .cta:hover { filter: brightness(1.05); color: var(--ims-navy-900); }

  /* Mobile: don't hide primary destinations. Stack brand+CTA on top row,
   * wrap the tab pills underneath. Codex r1 [high] fold — the prior
   * `display: none` rule hid Clinicians / Facilities / Job board /
   * Our story / Get in touch behind no replacement menu, leaving only
   * the logo + Apply CTA reachable. */
  @media (max-width: 980px) {
    .inner {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      grid-template-areas:
        "brand cta"
        "tabs tabs";
      gap: 12px;
      padding: 14px 20px;
    }
    .brand { grid-area: brand; }
    .right { grid-area: cta; gap: 8px; }
    .phone { display: none; }
    .tabs {
      grid-area: tabs;
      flex-wrap: wrap;
      justify-content: flex-start;
      background: transparent;
      padding: 0;
      border: 0;
      gap: 4px 6px;
    }
    .tab { font-size: 13px; padding: 7px 12px; }
  }
  /* Tight phone viewports (375px / iPhone, 320px / older Android): drop the
   * full wordmark to keep the brand+CTA top row from overflowing into
   * horizontal scroll. Logo mark + CTA only on the top row; tabs wrap below.
   * Codex r2 [medium] fold. */
  @media (max-width: 480px) {
    .wordmark { display: none; }
    .mark { height: 24px; }
    .cta { padding: 9px 14px; font-size: 13px; }
    .inner { padding: 12px 16px; gap: 10px; }
  }
</style>
