---
/*
 * SiteFooter — dark-ink footer-b (IMS Design System V3 / Chromia-Cream).
 * Ported from the kit's Footer.jsx; all styling lives in src/styles/kit.css
 * (.footer-b*). Content replicated from the kit per the exact-replication
 * directive (sign-off "The place to be is right here.", the kit's Fort Worth
 * (817) 555-0140) — the content pass reconciles real contact details.
 *
 * Exceptions kept as REAL data (not fabricated): the LinkedIn URL Zach
 * provided 2026-05-07. Instagram has no real handle yet (placeholder).
 * The newsletter form has no backend yet → graceful GET to /contact (flagged).
 */
const LINKEDIN_URL = 'https://www.linkedin.com/company/innovative-medical-staffing/';
---
<footer class="footer-b">
  <div class="footer-b__blob footer-b__blob--coral" aria-hidden="true"></div>
  <div class="footer-b__blob footer-b__blob--butter" aria-hidden="true"></div>
  <div class="container" style="position: relative; z-index: 1;">
    <span class="eyebrow footer-b__eyebrow"><span class="eyebrow__dot"></span>Get in touch</span>
    <h2 class="footer-b__signoff">The place to be <span>is right here</span>.</h2>

    <form class="footer-b__nl" method="get" action="/contact">
      <input class="input" type="email" name="email" placeholder="your@email.com" aria-label="Email for newsletter" />
      <button class="pill pill--swing" type="submit">
        Subscribe
        <span class="pill__puck" aria-hidden="true">→</span>
      </button>
    </form>

    <nav class="footer-b__sitemap" aria-label="Footer">
      <div class="footer-b__col">
        <span class="label">For you</span>
        <a href="/facilities">Facilities</a>
        <a href="/clinicians">Clinicians</a>
        <a href="/jobs">Open jobs</a>
      </div>
      <div class="footer-b__col">
        <span class="label">Company</span>
        <a href="/about">About</a>
        <a href="/how-it-works">How it works</a>
        <a href="/specialties">Specialties</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-b__col">
        <span class="label">Legal</span>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/cookies">Cookies</a>
      </div>
      <div class="footer-b__col" style="align-items: flex-end;">
        <span class="label">Find us</span>
        <a href="#">Fort Worth, TX</a>
        <a href="tel:+18175550140">(817) 555-0140</a>
      </div>
    </nav>

    <div class="footer-b__bottom">
      <div style="display: flex; align-items: center; gap: 14px;">
        <img src="/ims-logo-light.png" alt="Innovative Medical Staffing" style="height: 28px; width: auto;" />
        <small>© Innovative Medical Staffing &nbsp;·&nbsp; Fort Worth, TX &nbsp;·&nbsp; NALTO member &nbsp;·&nbsp; Joint Commission certified</small>
      </div>
      <div class="footer-b__socials">
        <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" aria-label="IMS on LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 2a2 2 0 100 4 2 2 0 000-4z"/>
          </svg>
        </a>
        <a href="#" aria-label="Instagram">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zM12 8a4 4 0 100 8 4 4 0 000-8zM17.5 6.5a.5.5 0 100 1 .5.5 0 000-1z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
