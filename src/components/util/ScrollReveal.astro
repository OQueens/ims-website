---
/*
 * ScrollReveal — thin convenience wrapper that tags an element with the global
 * `scroll-reveal` class so the site-wide reveal observer (inline in
 * MarketingLayout) animates it on scroll-in.
 *
 * The reveal CSS lives GLOBALLY in src/styles/kit.css and the observer is a
 * single inline script in MarketingLayout — NOT scoped here — so the same
 * effect is available to elements that just add class="scroll-reveal" directly
 * in page markup (with optional style="--i:N" for stagger). This component is
 * kept for back-compat with how-it-works.astro / specialties.astro and as an
 * ergonomic wrapper; it intentionally has no <style> or <script> of its own.
 *
 * Never-invisible contract is enforced by the global CSS (visible by default,
 * hidden only under html.js) + the layout's inline observer + load failsafe.
 */
interface Props {
  as?: string;
  /** legacy single-element delay in ms (kept for about/facilities back-compat) */
  delay?: number;
  class?: string;
  [key: string]: unknown;
}
const { as: As = 'section', delay = 0, class: className = '', ...rest } = Astro.props;
---
<As class:list={['scroll-reveal', className]} data-reveal-delay={delay} {...rest}>
  <slot />
</As>
