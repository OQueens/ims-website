---
/*
 * GetInTouch — the dark "Get in touch" contact page. The design north-star.
 *
 * Faithful transcription of the IMS Design System handoff
 * (design_handoff_contact_page/contact-reference.html, decoded reference kept at
 * docs/superpowers/research/contact-reference-decoded.txt) with these
 * spec-mandated adaptations:
 *  1. Scoped color vars on .gt-page (the reference's :root) using its exact hex.
 *     Fonts map to the site's global tokens: Fraunces→--font-display (and
 *     --font-display-italic for the italic signoff), Inter→--font-body,
 *     JetBrains Mono→--font-mono (all imported by MarketingLayout).
 *  2. Real IMS contact info (recruiting@iastaffing.com / (512) 524-6686 /
 *     Fort Worth, TX) — NOT the handoff's hello@imsstaffing.com / (817) 555-0140
 *     placeholders. The 3 meta lines are kept (unverified; behind the staging gate).
 *  3. The reference's demo .topbar/.nav-pill is dropped — the page uses the
 *     site's <SiteNav> (supplied by contact.astro via the layout nav slot).
 *  4. Glow drift kept as the reference's own gtDrift animation on the two glows
 *     (NOT the global .ambient-glow class — that would double-declare animation).
 *  5. Never-invisible (hard project rule): the entrance keyframes are
 *     TRANSFORM-ONLY (gtPop=scale, gtRise=translateY). The reference's gtRise
 *     animated opacity too; we drop that so a frozen/disabled animation can never
 *     leave the success text invisible. .gt-thanks is display:none until JS adds
 *     .is-active — a deliberate state swap; the form is the visible primary
 *     content and would native-POST if JS never runs.
 *  6. Reduced-motion: fireConfetti() early-returns in JS; glows + entrance
 *     animations are disabled via a scoped @media (prefers-reduced-motion).
 *  7. Success actions point at the real routes (/ and /jobs). validateContact
 *     (src/lib/contact-validation.ts) is the single source of truth for the
 *     client-side check, shared with any future backend.
 *
 * Backend wired (this plan): the form fetch-POSTs to /api/contact (Turnstile +
 * Resend). Progressive enhancement — JS flips to success in place; no-JS native
 * POST round-trips and the server re-renders this component with sent=true.
 */
import TurnstileWidget from '../forms/TurnstileWidget.astro';

interface Props {
  /** Server-rendered success state (no-JS POST → /contact?sent=1). */
  sent?: boolean;
  /** Server-rendered error banner code (no-JS POST → /contact?error=…). */
  errorCode?: string | null;
}

const { sent = false, errorCode = null } = Astro.props;

const ERROR_MESSAGES: Record<string, string> = {
  verify: "We couldn't confirm you're human. Please reload and try again.",
  send: 'Something went wrong sending your message. Please email recruiting@iastaffing.com directly.',
  validation: 'Please fill in your name, a valid email, and select who you are.',
};
const errorMessage = errorCode ? (ERROR_MESSAGES[errorCode] ?? ERROR_MESSAGES.send) : null;
---

<div class="gt-page">
  <div class="gt-glow gt-glow--magenta" aria-hidden="true"></div>
  <div class="gt-glow gt-glow--rose" aria-hidden="true"></div>
  <canvas class="gt-confetti" id="gtConfetti" aria-hidden="true"></canvas>

  <div class="gt-wrap">
    <div class="gt-shell" id="gtShell" class:list={[{ 'gt-shell--done': sent }]}>
      <!-- LEFT RAIL -->
      <div class="gt-left">
        <div class="gt-eyebrow"><span class="gt-eyebrow__dot"></span>Get in touch</div>
        <h1 class="gt-headline">Let's <em>talk</em>.</h1>
        <p class="gt-sub">A real conversation goes farther than a form. Tell us a little about you and we'll take it from there, within one business day.</p>

        <div class="gt-info">
          <div class="gt-info__row">
            <span class="gt-info__k">Email</span>
            <span class="gt-info__v"><a href="mailto:recruiting@iastaffing.com">recruiting@iastaffing.com</a><span class="gt-info__meta">Replies within one business day</span></span>
          </div>
          <div class="gt-info__row">
            <span class="gt-info__k">Phone</span>
            <span class="gt-info__v"><a href="tel:+15125246686">(512) 524-6686</a><span class="gt-info__meta">Mon to Fri, 8a to 6p Central</span></span>
          </div>
          <div class="gt-info__row">
            <span class="gt-info__k">Office</span>
            <span class="gt-info__v">Fort Worth, TX<span class="gt-info__meta">One floor, about 40 people</span></span>
          </div>
        </div>
      </div>

      <!-- FORM CARD -->
      <div class="gt-card">
        <div class="gt-card__head">
          <span class="gt-card__title">Send us a note</span>
          <span class="gt-card__note">We read every one</span>
        </div>
        <form class="gt-form" id="gtForm" method="post" action="/api/contact" novalidate>
          <div class="gt-field">
            <label for="gtName">Your name</label>
            <input id="gtName" name="name" type="text" placeholder="Jordan Rivers" required />
          </div>
          <div class="gt-field">
            <label for="gtEmail">Email</label>
            <input id="gtEmail" name="email" type="email" placeholder="you@example.com" required />
          </div>

          <div class="gt-seg">
            <span class="gt-seg__label">I am a…</span>
            <div class="gt-seg__options" role="radiogroup" aria-label="I am a…">
              <label class="gt-seg__opt">
                <input type="radio" name="audience" value="facility" />
                <span class="gt-seg__btn">Facility</span>
              </label>
              <label class="gt-seg__opt">
                <input type="radio" name="audience" value="clinician" />
                <span class="gt-seg__btn">Clinician</span>
              </label>
              <label class="gt-seg__opt">
                <input type="radio" name="audience" value="other" />
                <span class="gt-seg__btn">Something else</span>
              </label>
            </div>
          </div>

          <div class="gt-field gt-field--full">
            <label for="gtRole">Role or specialty <span class="gt-label__hint">(optional)</span></label>
            <input id="gtRole" name="role" type="text" placeholder="e.g. Hospitalist, CRNA, Cardiology" />
          </div>
          <div class="gt-field gt-field--full">
            <label for="gtMessage">Message</label>
            <textarea id="gtMessage" name="message" placeholder="What can we help with?"></textarea>
          </div>

          <!-- Honeypot: visually hidden, off-tab, ignored by humans. A filled
               value = bot → server drops silently before any Resend send. Not
               display:none (some bots skip those). -->
          <div class="gt-hp" aria-hidden="true">
            <label for="gtCompany">Company</label>
            <input id="gtCompany" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="gt-field gt-field--full">
            <TurnstileWidget form=".gt-form" />
          </div>

          <p class="gt-error" id="gtError" role="alert" hidden={!errorMessage}>{errorMessage}</p>

          <button class="gt-submit" type="submit">
            Send it <span class="gt-submit__puck" aria-hidden="true">→</span>
          </button>
        </form>
      </div>
    </div>

    <!-- SUCCESS STATE -->
    <div class="gt-thanks" id="gtThanks" class:list={['gt-thanks', { 'is-active': sent }]} role="status" aria-live="polite" tabindex="-1">
      <div class="gt-thanks__check" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#FBF6EE" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>
      </div>
      <div class="gt-thanks__eyebrow">Message received</div>
      <h2 class="gt-thanks__title">Thank you for <em>reaching out</em>.</h2>
      <p class="gt-thanks__body">We believe that every great opportunity starts with a conversation, and we're thrilled to have started one with you. We're already working on what's next, and we'll be in touch soon. Until then, know that we appreciate you and are excited for what's ahead.</p>
      <p class="gt-thanks__signoff">With gratitude, <strong>the IMS team</strong></p>
      <div class="gt-thanks__actions">
        <a class="gt-pill gt-pill--primary" href="/">Back to home →</a>
        <a class="gt-pill gt-pill--ghost" href="/jobs">Browse open jobs</a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Scoped color vars (the reference's :root) — exact handoff hex. The dark page
     is an intentional dark island within the otherwise cream site. */
  .gt-page {
    --magenta: #C44569;   /* primary accent */
    --butter:  #E8C465;   /* eyebrow / labels */
    --rose:    #D88B9F;   /* secondary glow + confetti */
    --cyan:    #59BFE7;   /* confetti only */
    --black:   #0A0A0F;   /* page ground */
    --ink:     #1F1A23;   /* checked segment, puck */
    --cream:   #FBF6EE;   /* text on dark, form card */
    --hair-dark:  rgba(251, 246, 238, 0.12);
    --hair-cream: #E7DFD3;

    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(900px 600px at 85% -8%, rgba(196, 69, 105, 0.38), transparent 60%),
      radial-gradient(700px 520px at -8% 108%, rgba(216, 139, 159, 0.30), transparent 60%),
      #0A0A0F;
    color: var(--cream);
    overflow-x: hidden;
  }
  .gt-wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 96px 32px 64px;
    position: relative;
    z-index: 2;
  }

  /* Shell */
  .gt-shell {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: 64px;
    align-items: center;
    min-height: 60vh;
  }
  @media (max-width: 920px) {
    .gt-shell { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; }
  }

  /* Left rail */
  .gt-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgba(251, 246, 238, 0.6);
    font-weight: 700; margin-bottom: 24px;
  }
  .gt-eyebrow__dot { width: 9px; height: 9px; border-radius: 50%; background: var(--butter); }
  .gt-headline {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(64px, 8vw, 116px); line-height: 0.9;
    letter-spacing: -0.04em; margin-bottom: 28px; color: var(--cream);
  }
  .gt-headline em { font-style: normal; color: var(--magenta); }
  .gt-sub {
    font-family: var(--font-body); font-size: 19px; line-height: 1.55;
    color: rgba(251, 246, 238, 0.78); max-width: 40ch; margin-bottom: 40px;
  }
  .gt-info { display: flex; flex-direction: column; gap: 0; }
  .gt-info__row {
    display: grid; grid-template-columns: 90px 1fr; gap: 16px;
    align-items: baseline; padding: 12px 0; border-bottom: 1px solid var(--hair-dark);
  }
  .gt-info__row:first-child { border-top: 1px solid var(--hair-dark); }
  .gt-info__k {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--butter); font-weight: 700;
  }
  .gt-info__v { font-family: var(--font-display); font-weight: 800; font-size: 20px; color: var(--cream); }
  .gt-info__v a { color: var(--cream); text-decoration: none; }
  .gt-info__v a:hover { color: var(--magenta); }
  .gt-info__meta {
    display: block; font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.04em; color: rgba(251, 246, 238, 0.55);
    margin-top: 4px; text-transform: none;
  }

  /* Card */
  .gt-card {
    background: var(--cream); border-radius: 24px; padding: 32px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45); color: var(--ink);
  }
  .gt-card__head {
    display: flex; align-items: center; justify-content: space-between;
    padding-bottom: 16px; margin-bottom: 8px; border-bottom: 1px solid var(--hair-cream);
  }
  .gt-card__title {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.16em; font-weight: 700; color: var(--magenta);
  }
  .gt-card__note {
    font-family: var(--font-mono); font-size: 10px; text-transform: uppercase;
    letter-spacing: 0.08em; color: #9a9088;
  }
  .gt-form { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }
  .gt-field { display: flex; flex-direction: column; gap: 7px; }
  .gt-field--full { grid-column: 1 / -1; }
  .gt-field label {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.1em; color: #6f655c; font-weight: 600;
  }
  .gt-label__hint { color: #b3a99d; text-transform: none; letter-spacing: 0; }
  .gt-field input, .gt-field textarea {
    font-family: var(--font-body); font-size: 15px; padding: 13px 15px;
    border: 1px solid #E0D7CA; border-radius: 12px; background: #fff;
    color: var(--ink); transition: border-color 0.15s, box-shadow 0.15s;
  }
  .gt-field textarea { min-height: 112px; resize: vertical; }
  .gt-field input:focus, .gt-field textarea:focus {
    outline: none; border-color: var(--magenta);
    box-shadow: 0 0 0 3px rgba(196, 69, 105, 0.26);
  }
  .gt-field input::placeholder, .gt-field textarea::placeholder { color: #b3a99d; }

  /* Segmented control */
  .gt-seg { grid-column: 1 / -1; display: flex; flex-direction: column; gap: 8px; }
  .gt-seg__label {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.1em; color: #6f655c; font-weight: 600;
  }
  .gt-seg__options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .gt-seg__opt { position: relative; }
  .gt-seg__opt input { position: absolute; opacity: 0; inset: 0; cursor: pointer; margin: 0; }
  .gt-seg__btn {
    display: block; text-align: center; padding: 12px 8px; border: 1.5px solid #E0D7CA;
    border-radius: 12px; font-family: var(--font-body); font-weight: 600; font-size: 14px;
    color: var(--ink); background: #fff; cursor: pointer; transition: all 0.15s;
  }
  .gt-seg__opt input:checked + .gt-seg__btn { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .gt-seg__opt input:focus-visible + .gt-seg__btn { box-shadow: 0 0 0 3px rgba(196, 69, 105, 0.3); }

  /* Submit */
  .gt-submit {
    grid-column: 1 / -1; display: flex; align-items: center; justify-content: center;
    gap: 12px; background: var(--magenta); color: var(--cream); border: none;
    border-radius: 999px; padding: 16px 24px; font-family: var(--font-body);
    font-weight: 700; font-size: 16px; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;
  }
  .gt-submit:hover { transform: translateY(-2px); box-shadow: 0 14px 36px rgba(196, 69, 105, 0.4); }
  .gt-submit:focus-visible { outline: 3px solid var(--cream); outline-offset: 3px; }
  .gt-submit__puck {
    width: 28px; height: 28px; border-radius: 50%; background: var(--ink);
    display: grid; place-items: center; font-size: 14px; transition: transform 0.15s;
  }
  .gt-submit:hover .gt-submit__puck { transform: translateX(4px); }

  /* Honeypot — off-screen, never display:none. */
  .gt-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* Server-rendered error banner (no-JS POST round-trip) + JS error reuse. */
  .gt-error {
    grid-column: 1 / -1;
    margin: 0;
    padding: 12px 14px;
    border-radius: 12px;
    background: rgba(196, 69, 105, 0.10);
    border: 1px solid rgba(196, 69, 105, 0.35);
    color: #8f2f48;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.45;
  }
  .gt-error[hidden] { display: none; }

  /* Server-rendered success (?sent=1): hide the shell entirely. */
  .gt-shell--done { display: none; }

  /* Success */
  .gt-thanks { display: none; text-align: center; padding: 40px 0; max-width: 680px; margin: 0 auto; }
  .gt-thanks:focus { outline: none; }
  .gt-thanks.is-active { display: block; }
  .gt-thanks__check {
    width: 96px; height: 96px; border-radius: 50%; background: var(--magenta);
    display: grid; place-items: center; margin: 0 auto 32px;
    box-shadow: 0 18px 50px rgba(196, 69, 105, 0.5);
  }
  .gt-thanks__check svg { width: 48px; height: 48px; }
  .gt-thanks__eyebrow {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--butter); font-weight: 700; margin-bottom: 20px;
  }
  .gt-thanks__title {
    font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 7vw, 96px);
    line-height: 0.92; letter-spacing: -0.04em; margin-bottom: 28px; color: var(--cream);
  }
  .gt-thanks__title em { font-style: normal; color: var(--magenta); }
  .gt-thanks__body {
    font-family: var(--font-body); font-size: clamp(18px, 2vw, 21px); line-height: 1.65;
    color: rgba(251, 246, 238, 0.82); max-width: 56ch; margin: 0 auto 40px;
  }
  .gt-thanks__signoff {
    font-family: var(--font-display-italic); font-style: italic; font-size: 22px;
    color: var(--cream); margin-bottom: 44px;
  }
  .gt-thanks__signoff strong { font-weight: 800; font-style: normal; color: var(--butter); }
  .gt-thanks__actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .gt-pill {
    display: inline-flex; align-items: center; gap: 8px; padding: 15px 28px;
    border-radius: 999px; font-family: var(--font-body); font-weight: 700; font-size: 15px;
    text-decoration: none; transition: transform 0.15s;
  }
  .gt-pill--primary { background: var(--cream); color: var(--ink); }
  .gt-pill--ghost { background: transparent; color: var(--cream); border: 1.5px solid rgba(251, 246, 238, 0.3); }
  .gt-pill:hover { transform: translateY(-2px); }

  /* Glows — the reference's own ambient drift (NOT the global .ambient-glow). */
  .gt-glow { position: fixed; border-radius: 50%; filter: blur(60px); pointer-events: none; z-index: 1; }
  .gt-glow--magenta {
    width: 560px; height: 560px; background: rgba(196, 69, 105, 0.30);
    top: -160px; right: -120px; animation: gtDrift 26s ease-in-out infinite;
  }
  .gt-glow--rose {
    width: 420px; height: 420px; background: rgba(216, 139, 159, 0.22);
    bottom: -140px; left: -100px; animation: gtDrift 30s ease-in-out infinite reverse;
  }
  @keyframes gtDrift { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(40px, 30px); } }

  /* Confetti canvas */
  .gt-confetti { position: fixed; inset: 0; pointer-events: none; z-index: 60; }

  /* Entrance — TRANSFORM-ONLY (never opacity:0) so a frozen animation can never
     hide the success text. Staggered via backwards fill (holds the translateY
     from-state during the delay; opacity always stays 1). */
  @keyframes gtPop { 0% { transform: scale(0.4); } 55% { transform: scale(1.12); } 100% { transform: scale(1); } }
  @keyframes gtRise { from { transform: translateY(18px); } to { transform: translateY(0); } }
  .gt-thanks.is-active .gt-thanks__check   { animation: gtPop 0.6s cubic-bezier(0.32, 0.72, 0, 1) backwards; }
  .gt-thanks.is-active .gt-thanks__eyebrow { animation: gtRise 0.6s ease 40ms backwards; }
  .gt-thanks.is-active .gt-thanks__title   { animation: gtRise 0.6s ease 100ms backwards; }
  .gt-thanks.is-active .gt-thanks__body    { animation: gtRise 0.6s ease 180ms backwards; }
  .gt-thanks.is-active .gt-thanks__signoff { animation: gtRise 0.6s ease 260ms backwards; }
  .gt-thanks.is-active .gt-thanks__actions { animation: gtRise 0.6s ease 320ms backwards; }

  /* Reduced motion — scoped (the site already has a global switch in
     colors_and_type.css; this disables this page's drift + entrance explicitly). */
  @media (prefers-reduced-motion: reduce) {
    .gt-glow,
    .gt-thanks.is-active .gt-thanks__check,
    .gt-thanks.is-active .gt-thanks__eyebrow,
    .gt-thanks.is-active .gt-thanks__title,
    .gt-thanks.is-active .gt-thanks__body,
    .gt-thanks.is-active .gt-thanks__signoff,
    .gt-thanks.is-active .gt-thanks__actions { animation: none; }
  }

  @media (max-width: 560px) {
    .gt-form { grid-template-columns: 1fr; }
    .gt-wrap { padding: 80px 20px 48px; }
  }
</style>

<script>
  // Component module script — Astro bundles this from 'self' (CSP-ok); it only
  // runs client-side. validateContact is the single source of truth for the
  // form's name/email/audience check (shared with any future backend).
  import { validateContact } from '../../lib/contact-validation';

  const form = document.getElementById('gtForm') as HTMLFormElement | null;
  const shell = document.getElementById('gtShell');
  const thanks = document.getElementById('gtThanks');
  const canvas = document.getElementById('gtConfetti') as HTMLCanvasElement | null;

  let confettiRaf: number | null = null;

  function shake(el: Element) {
    el.animate(
      [
        { transform: 'translateX(0)' },
        { transform: 'translateX(-6px)' },
        { transform: 'translateX(6px)' },
        { transform: 'translateX(0)' },
      ],
      { duration: 320, easing: 'ease-in-out' },
    );
  }

  if (form && shell && thanks) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const name = ((fd.get('name') as string) ?? '').toString();
      const email = ((fd.get('email') as string) ?? '').toString();
      const audience = ((fd.get('audience') as string) ?? '').toString();

      const result = validateContact({ name, email, audience });
      if (!result.ok) {
        if (result.field === 'name') {
          const el = form.querySelector('[name="name"]') as HTMLElement | null;
          if (el) { el.focus(); shake(el); }
        } else if (result.field === 'email') {
          const el = form.querySelector('[name="email"]') as HTMLElement | null;
          if (el) { el.focus(); shake(el); }
        } else {
          const seg = form.querySelector('.gt-seg') as HTMLElement | null;
          if (seg) shake(seg);
          const firstRadio = form.querySelector('[name="audience"]') as HTMLElement | null;
          if (firstRadio) firstRadio.focus();
        }
        return;
      }

      // Backend wired: POST the form to /api/contact and only flip to success
      // on a 200. Accept: application/json selects the JSON (no-redirect) path.
      const submitBtn = form.querySelector('.gt-submit') as HTMLButtonElement | null;
      const errorEl = document.getElementById('gtError');
      if (errorEl) errorEl.setAttribute('hidden', '');

      const showError = (msg: string) => {
        if (errorEl) {
          errorEl.textContent = msg;
          errorEl.removeAttribute('hidden');
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send it →';
        }
      };

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      })
        .then((res) => {
          if (!res.ok) {
            if (res.status === 403) {
              showError("We couldn't confirm you're human. Please reload and try again.");
            } else {
              showError('Something went wrong sending your message. Please email recruiting@iastaffing.com directly.');
            }
            return;
          }
          shell.style.display = 'none';
          thanks.classList.add('is-active');
          window.scrollTo(0, 0);
          // Move focus to the success region so SR + keyboard users are told it
          // succeeded (focus was on the now-hidden submit button).
          (thanks as HTMLElement).focus();
          fireConfetti();
        })
        .catch(() => {
          showError('We could not reach the server. Please email recruiting@iastaffing.com directly.');
        });
    });
  }

  function fireConfetti() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvasEl = canvas;
    if (!canvasEl) return;
    const ctx = canvasEl.getContext('2d');
    if (!ctx) return;
    // Cancel any in-flight burst so a re-fire can't run two loops on one canvas.
    if (confettiRaf !== null) cancelAnimationFrame(confettiRaf);

    let W = (canvasEl.width = window.innerWidth);
    let H = (canvasEl.height = window.innerHeight);
    const onResize = () => {
      W = canvasEl.width = window.innerWidth;
      H = canvasEl.height = window.innerHeight;
    };
    window.addEventListener('resize', onResize);

    const colors = ['#C44569', '#E8C465', '#D88B9F', '#59BFE7', '#F4ECDF'];
    const N = 160;
    const pieces = Array.from({ length: N }, () => ({
      x: W / 2 + (Math.random() - 0.5) * 120,
      y: H / 2 + (Math.random() - 0.5) * 40,
      r: 4 + Math.random() * 7,
      c: colors[(Math.random() * colors.length) | 0],
      vx: (Math.random() - 0.5) * 14,
      vy: -6 - Math.random() * 12,
      rot: Math.random() * 6.28,
      vr: (Math.random() - 0.5) * 0.5,
      shape: Math.random() > 0.5 ? 'rect' : 'circle',
      life: 0,
    }));

    let t = 0;
    const frame = () => {
      ctx.clearRect(0, 0, W, H);
      t++;
      let alive = false;
      for (const p of pieces) {
        p.life++;
        p.vy += 0.35; // gravity
        p.vx *= 0.99;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.vr;
        if (p.y < H + 40) alive = true;
        const fade = Math.max(0, 1 - p.life / 170);
        ctx.globalAlpha = fade;
        ctx.fillStyle = p.c;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        if (p.shape === 'rect') ctx.fillRect(-p.r, -p.r, p.r * 2, p.r * 2);
        else { ctx.beginPath(); ctx.arc(0, 0, p.r, 0, 6.28); ctx.fill(); }
        ctx.restore();
      }
      ctx.globalAlpha = 1;
      if (t < 240 && alive) {
        confettiRaf = requestAnimationFrame(frame);
      } else {
        ctx.clearRect(0, 0, W, H);
        window.removeEventListener('resize', onResize);
        confettiRaf = null;
      }
    };
    confettiRaf = requestAnimationFrame(frame);
  }
</script>
