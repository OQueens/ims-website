---
/*
 * LegalPage — cream legal-content layout (kit Legal.jsx design) carrying the
 * REAL IMS legal notices. Renders Privacy, Terms, or Cookies by `kind`.
 * Layout/typography from kit.css (.legal-page*); the rich-body styles (lists,
 * inline links, <code>, the draft callout) live in the <style is:global> block
 * below because section bodies are injected with set:html and therefore never
 * receive Astro's scoped cid attribute.
 *
 * Content note: these are the real, fact-grounded notices, researched against
 * the laws that actually bind a small Texas boutique locum-staffing firm
 * (2026-06-02 legal pass): state consumer-privacy laws scoped to what truly
 * applies + the Texas TDPSA small-business exemption, GDPR scoped down (IMS does
 * not target the EU/UK), HIPAA clarified (IMS is neither a covered entity nor a
 * business associate), retention framed as IMS's own policy that meets/exceeds
 * the real federal (IRS 4yr / FLSA 3yr / I-9) + Texas (4-yr contract SOL) floors
 * (the 7yr window is conservative practice, NOT a 7-yr statute), and the venue set
 * to a State-of-Texas forum-selection clause. IMS's registered office address
 * (12650 N Beach St, Fort Worth, TX 76244 — in Tarrant County, verified) is shown
 * in the legal contact block for service, but the clause does NOT pin a binding
 * Tarrant County venue: under Tex. CPRC 15.020 a contractual county venue is
 * unenforceable absent a $1M+ "major transaction" (a free site visitor never
 * qualifies), and a registered-agent mailbox is not a "principal office"
 * (CPRC 15.001) — so forum-level State of Texas is the enforceable, accurate
 * choice. IMS is fully remote; the address is for legal service, NOT a staffed
 * office. The notices were hardened on 2026-06-03 after Zach's independent
 * attorney-style deep review (ChatGPT deep-research run on our prompt). Folded:
 * DRAFT banner REMOVED (a draft banner on live terms undermines assent); liability
 * cap -> ALL-CAPS, reaches IMS's OWN ordinary negligence, non-zero $100 floor;
 * sale/share reframed (monetary-sale vs service-facilitation); retention ->
 * category-based (~4yr base, NOT a 7yr statute); HIPAA "generally does not apply" +
 * do-not-submit-PHI; GDPR softened to US-intent (+ Switzerland). ADDED: IP +
 * anti-scraping + acceptable-use, suspension/termination, third-party-links, a
 * 2-YEAR limitations period (NOT 1yr — void per Tex. CPRC 16.070), a narrow
 * misuse-indemnity, children's/COPPA, breach-notice, accessibility, Do-Not-Track,
 * and general boilerplate (entire-agreement/no-waiver/assignment/e-communications).
 * Remaining licensed-counsel judgment calls (keep arbitration OFF the public site;
 * exact cap floor $100 vs $250; placed-clinician retention 4/6/7 yr; whether any
 * future workflow makes IMS a HIPAA business associate) are catalogued in
 * docs/legal/2026-06-03-residual-legal-research.md.
 */
interface Props { kind: 'privacy' | 'terms' | 'cookies'; }
const { kind } = Astro.props;

// A section body is a list of blocks: a paragraph or an unordered list.
// Strings may carry trusted inline HTML (<a>, <strong>, <em>, <code>) — this is
// author-controlled copy, not user input, so set:html is safe here.
const SUPPORT_EMAIL = 'recruiting@iastaffing.com';
const UPDATED = 'June 3, 2026';
// Registered legal address (Texas LLC). This is a commercial registered-agent /
// mailbox address in Fort Worth (Tarrant County) used for legal notices and
// service — IMS is fully remote, so it is NOT a staffed office. Used in the
// legal contact blocks and as the basis for the Tarrant County dispute venue.
const LEGAL_ENTITY = 'Innovative Medical Staffing · 12650 N Beach St, Ste 114 #7022, Fort Worth, TX 76244';

const LEGAL_CONTENT = {
  privacy: {
    eyebrow: `Last updated · ${UPDATED}`,
    title: { lead: 'Your information,', em: 'handled with care', trail: '.' },
    intro: "This notice describes what Innovative Medical Staffing (IMS) collects through this site and our staffing service, what we do with it, where it lives, and how to ask us to delete it.",
    sections: [
      { h: 'What we collect', body: [
        { p: 'We collect only what the staffing relationship needs:' },
        { ul: [
          `<strong>Application data</strong> — name, contact details, CV, license states, certifications, references, work history, and availability submitted through the site or by email.`,
          `<strong>Contact-form data</strong> — your name, email address, who you are (facility, clinician, or general inquiry), an optional role or specialty, and the message you send us.`,
          `<strong>Usage telemetry</strong> — anonymous, aggregated visit data via Plausible Cloud (no cookies, no cross-site identifiers, no stored IP). See the <a href="/cookies/">Cookies notice</a>.`,
          `<strong>Operational records</strong> — the credentialing paperwork, references, and assignment history we gather and hold for the clinicians and facility partners we work with, in coordination with each facility's medical staff office.`,
        ]},
      ]},
      { h: 'How we use it', body: [
        { ul: [
          `To match clinicians to assignments and facilities to qualified clinicians.`,
          `To facilitate credentialing, onboarding, and assignment logistics.`,
          `To respond to inquiries and stay in touch with the clinicians and facility partners we work with.`,
          `To meet the legal, regulatory, and contractual obligations specific to healthcare staffing.`,
        ]},
      ]},
      { h: 'Where it lives', body: [
        { ul: [
          `Application + contact data — Supabase (US-hosted Postgres, encrypted at rest).`,
          `Outbound transactional email — Resend (US-based email delivery).`,
          `Anonymous site analytics — Plausible Cloud (cookieless, no stored IP; EU-hosted, data never leaves the EU).`,
          `Site hosting — Cloudflare (global edge network).`,
        ]},
      ]},
      { h: 'How long we keep it', body: [
        { p: `We keep personal information only as long as reasonably necessary for the purposes described here — to operate our recruiting and staffing business, keep appropriate business records, meet tax, payroll, recordkeeping, and legal obligations, resolve disputes, and enforce agreements. Retention varies by category, and a litigation hold always overrides routine deletion:` },
        { ul: [
          `<strong>Website analytics and security logs</strong> — typically up to 18 months.`,
          `<strong>Routine website inquiries with no relationship formed</strong> — up to 24 months.`,
          `<strong>Job-application data</strong> — up to 18 months from last contact, then deleted unless an active engagement extends the relationship.`,
          `<strong>Placement, billing, and related business records</strong> — about 4 years after the last placement activity, payment, or relationship event, or longer where tax, accounting, contractual, insurance, or litigation-hold reasons apply.`,
          `<strong>Form I-9 and similar mandated records</strong> — kept on their own statutory schedule.`,
        ]},
        { p: `The legal floors that drive these windows are shorter than people often assume — federal payroll-tax records run four years, FLSA wage records three, Form I-9s the later of three years after hire or one year after the assignment ends, and Texas's longest relevant deadline is the four-year limit on contract claims. Where we keep records longer, that is our own conservative policy, not a legal requirement.` },
      ]},
      { h: 'A note on HIPAA', body: [
        { p: `IMS is a staffing agency — not a healthcare provider or health plan. The information we collect about you (contact details, licenses, certifications, references, and work history) is professional credentialing information about you as a clinician, so HIPAA generally does not apply to what we collect, and we do not collect patient health records ("protected health information") through this site. Please do not submit patient health information through our web forms or by email. When you are placed at a facility, any patient information you handle on that assignment is governed by that facility's own HIPAA policies, because on assignment you work under the facility's direction — not ours.` },
      ]},
      { h: 'Your rights and how to exercise them', body: [
        { p: `You can ask us at any time to confirm what we hold about you, correct it, or delete it. Email <a href="mailto:${SUPPORT_EMAIL}?subject=Data%20deletion%20request">${SUPPORT_EMAIL}</a> with the subject <em>Data deletion request</em>. We aim to respond within 30 days.` },
        { p: `We do not sell personal data for monetary consideration, we do not share personal information for cross-context behavioral advertising, and we do not process personal data for targeted advertising. If a clinician asks us to present them for a staffing opportunity, we may disclose the information reasonably necessary to evaluate and facilitate that requested opportunity with a healthcare facility or other business counterparty — we treat those disclosures as part of providing the staffing services you have asked for, not as advertising. We also disclose data to the sub-processors listed above, who act on our behalf. We do not sell sensitive personal data.` },
      ]},
      { h: 'Privacy laws and where you live', body: [
        { p: `Innovative Medical Staffing is a small Texas-based business. The comprehensive US state consumer-privacy laws now in effect — including California (CCPA/CPRA) and the roughly twenty other states, Texas among them, with similar laws as of 2026 — generally apply only to larger companies that cross specific revenue or data-volume thresholds, or that sell personal data. We do not meet those thresholds, and we do not sell personal data. Most of these laws also do not cover the information you give us as a job applicant or a business contact, and even the newest and broadest of them — such as Connecticut's 2026 amendments, which can reach a business that handles the sensitive data of a single resident — apply only to individuals acting as consumers, not to the job applicants and business contacts whose information we handle.` },
        { p: `Texas's own law — the Texas Data Privacy and Security Act — exempts businesses that qualify as a "small business" under US Small Business Administration standards, which we do. The one rule that still applies to every business, large or small, is that sensitive personal data may not be sold without your consent; we satisfy it by not selling data at all.` },
        { p: `None of that changes how we treat you. Whatever the law requires, you can ask us to confirm, correct, or delete what we hold — use the deletion-request flow above, and we will honor reasonable requests.` },
      ]},
      { h: 'Where we operate', body: [
        { p: `Our services are intended for people in the United States, and we do not currently market our services to individuals in the EEA, UK, or Switzerland. If you are outside the United States and have a question or request about your information, email <a href="mailto:${SUPPORT_EMAIL}">${SUPPORT_EMAIL}</a> and we will do our best to help.` },
      ]},
      { h: 'If there is a data breach', body: [
        { p: `If we determine that a security incident requires notice under applicable law, we will provide those notices as the law requires. For Texas residents, that may include notice to the affected individuals and, where required, a report to the Texas Attorney General.` },
      ]},
      { h: "Children's privacy", body: [
        { p: `This site is not directed to children under 13, and IMS does not knowingly collect personal information online from children under 13. If you believe a child under 13 has given us personal information through the site, email <a href="mailto:${SUPPORT_EMAIL}">${SUPPORT_EMAIL}</a> and we will take appropriate action.` },
      ]},
      { h: 'Accessibility', body: [
        { p: `IMS is committed to improving website accessibility for all users. If you have trouble accessing any content on this site, email <a href="mailto:${SUPPORT_EMAIL}">${SUPPORT_EMAIL}</a> with the page and the issue, and we will work to provide the information in an accessible format.` },
      ]},
      { h: 'Changes to this notice', body: [
        { p: `We update this notice when our practices change or when the law requires it. The date at the top reflects the most recent change.` },
      ]},
    ],
    contact: { lead: 'Questions or data requests:', address: SUPPORT_EMAIL, mail: LEGAL_ENTITY },
  },

  terms: {
    eyebrow: `Last updated · ${UPDATED}`,
    title: { lead: 'The rules of the road,', em: 'in plain English', trail: '.' },
    intro: "These terms govern your use of this site and your relationship with Innovative Medical Staffing. A separate signed agreement — a clinician contract or a facility staffing agreement — controls if anything here conflicts with it.",
    sections: [
      { h: 'The service', body: [
        { p: `Innovative Medical Staffing (IMS) provides healthcare-staffing services connecting qualified clinicians with healthcare facilities for locum tenens and similar engagements. This site describes the service, lists open opportunities, and offers ways to get in touch. Information on this site is general unless captured in a signed agreement between IMS and a clinician or facility.` },
      ]},
      { h: 'No fees charged to clinicians', body: [
        { p: `IMS does not charge clinicians a fee for placement or representation. Compensation to IMS is paid by the facility partner under a separate staffing agreement. Clinicians retain the right to engage directly with any facility outside the IMS relationship.` },
      ]},
      { h: 'Recruiter relationship', body: [
        { p: `Submitting a CV, contact form, or inquiry creates a non-exclusive, no-obligation working relationship with an IMS recruiter for the purpose of evaluating fit. It is not employment, an offer of employment, or a guarantee of placement. Either party may end the relationship at any time before a signed engagement.` },
      ]},
      { h: 'Information accuracy', body: [
        { p: `Clinicians and facilities must provide accurate, complete information. IMS facilitates credentialing and reference checks together with the facility's medical staff office and relies on the materials and references provided; reliance on materially false information may end the working relationship.` },
      ]},
      { h: 'Site use', body: [
        { p: `You agree not to access this site through automated means beyond ordinary search-engine crawling, interfere with the site infrastructure, or use the site to send unsolicited commercial messages to addresses harvested from it.` },
      ]},
      { h: 'Intellectual property and acceptable use', body: [
        { p: `Site content (copy, marks, illustrations, compilations, and software) is owned by IMS or its licensors and protected by intellectual-property law. Subject to these terms, IMS grants you a limited, revocable, non-exclusive, non-transferable license to use the site to learn about IMS and its services. You may share links to public pages and quote short excerpts with attribution. You may not copy, scrape, reproduce, republish, distribute, frame, reverse-engineer, or create derivative works from the site or its content except as expressly permitted in writing, and you may not submit false, inaccurate, or misleading information, including inaccurate credentialing or licensure information.` },
      ]},
      { h: 'Disclaimer', body: [
        { p: `Site content is provided on an as-is basis. IMS does not warrant the site will be uninterrupted or error-free. To the extent permitted by law, IMS disclaims implied warranties of merchantability, fitness for a particular purpose, and non-infringement.` },
      ]},
      { h: 'Limitation of liability', body: [
        { p: `<strong>TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, IMS'S TOTAL AGGREGATE LIABILITY ARISING OUT OF OR RELATING TO THE SITE, THESE TERMS, OR ANY CONTENT OR MATERIALS PROVIDED THROUGH THE SITE — INCLUDING ANY CLAIM BASED ON IMS'S OWN ORDINARY NEGLIGENCE — WILL NOT EXCEED THE GREATER OF (A) US$100, OR (B) THE AMOUNT YOU PAID IMS, IF ANY, FOR USE OF THE SITE OR THE SPECIFIC SERVICE GIVING RISE TO THE CLAIM IN THE 12 MONTHS BEFORE THE EVENT FIRST GIVING RISE TO THE CLAIM. THIS LIMITATION DOES NOT APPLY TO LIABILITY FOR FRAUD, WILLFUL MISCONDUCT, GROSS NEGLIGENCE, PERSONAL INJURY OR DEATH CAUSED BY NEGLIGENCE, OR ANY LIABILITY THAT CANNOT BE EXCLUDED OR LIMITED UNDER APPLICABLE LAW.</strong> This limit applies to your use of this site only — IMS's liability under any signed clinician or facility staffing agreement is governed solely by the limitation-of-liability provision in that agreement.` },
      ]},
      { h: 'Your responsibility for misuse', body: [
        { p: `To the extent permitted by law, you agree to cover IMS's reasonable losses arising from your unlawful use of the site, your submission of false or misleading information (including inaccurate credentials), your scraping or other unauthorized access, or your infringement of someone else's rights. This is limited to misuse by you; it does not ask ordinary visitors to insure IMS against its own conduct.` },
      ]},
      { h: 'Suspension and termination', body: [
        { p: `IMS may suspend, restrict, or end your access to the site at any time, with or without notice, if we reasonably believe you have violated these terms, provided false information, interfered with the site, or used it unlawfully.` },
      ]},
      { h: 'Third-party links', body: [
        { p: `The site may link to third-party websites or services for convenience. IMS does not control and is not responsible for their content, policies, or practices; your use of any third-party site is at your own risk and subject to that third party's terms.` },
      ]},
      { h: 'Governing law and disputes', body: [
        { p: `These terms are governed by the laws of the State of Texas, without regard to its conflict-of-laws rules. The parties agree to attempt good-faith resolution before filing a claim. Any unresolved dispute will be brought exclusively in the state or federal courts located in the State of Texas, and you consent to personal jurisdiction there, unless applicable consumer-protection law in your jurisdiction gives you a non-waivable right to a different venue.` },
      ]},
      { h: 'Time limit for claims', body: [
        { p: `Any claim arising out of or relating to the site or these terms must be brought within two years after it arises, to the extent applicable law allows a shortened period.` },
      ]},
      { h: 'Severability and modification', body: [
        { p: `If any provision of these terms is found unenforceable, the remainder stays in effect. We may update these terms when our practices change or when the law requires it; the date at the top reflects the most recent change. Material changes apply going forward, and continued use of the site after a change constitutes acceptance of the updated terms.` },
      ]},
      { h: 'General', body: [
        { p: `These terms, together with any signed agreement that applies to you, are the entire agreement between you and IMS about the site. Our failure to enforce a provision is not a waiver of it. You may not assign your rights under these terms; IMS may assign its rights to an affiliate or successor. You agree that IMS may communicate with you electronically and that electronic records and communications satisfy any requirement that such communications be in writing.` },
      ]},
    ],
    contact: { lead: 'Questions about these terms:', address: SUPPORT_EMAIL, mail: LEGAL_ENTITY },
  },

  cookies: {
    eyebrow: `Last updated · ${UPDATED}`,
    title: { lead: 'We use cookies for', em: 'the boring necessary things', trail: '.' },
    intro: "We don't use tracking cookies, cross-site identifiers, or third-party advertising tags. Site usage telemetry runs through Plausible Cloud, which is cookieless by design.",
    sections: [
      { h: 'What cookies are set', body: [
        { p: `One cookie is set when you visit this site: <code>__cf_bm</code>. Cloudflare sets it for bot-management and security; it lasts 30 minutes from your most recent request and stores no personal data in the cookie body. Cloudflare classifies it as strictly necessary, and it does not track you across sites.` },
        { p: `US state privacy laws — such as the Texas Data Privacy and Security Act — tie consent and opt-out obligations to selling personal data and to targeted advertising, not to a strictly-necessary security cookie. We do neither, and we run no advertising or cross-site-tracking tags. Even under the stricter EU/UK ePrivacy rules, security and anti-abuse cookies fall within the "strictly necessary" exemption from consent.` },
      ]},
      { h: 'Why there is no consent banner', body: [
        { p: `Consent banners are required when a site sets non-essential cookies or uses cross-site tracking. We do neither. Site analytics run on Plausible Cloud, which uses no cookies and no persistent identifiers — visit counts are aggregated at the request level using a daily-rotating salted hash that cannot identify a returning visitor.` },
      ]},
      { h: 'Do Not Track', body: [
        { p: `This site uses only the strictly-necessary Cloudflare security cookie described above, and our analytics avoid non-essential cookies. Because we use no advertising cookies or cross-context behavioral-advertising tools, the site does not currently respond differently to browser "Do Not Track" signals.` },
      ]},
      { h: 'Where to learn more', body: [
        { p: `Our broader handling of personal data — what we collect through forms, retention, the deletion-request flow, and sub-processors — is documented in the <a href="/privacy/">Privacy notice</a>. The Plausible Cloud approach is documented at <a href="https://plausible.io/data-policy" rel="external noopener">plausible.io/data-policy</a>.` },
      ]},
    ],
    contact: { lead: 'Privacy questions:', address: SUPPORT_EMAIL, mail: LEGAL_ENTITY },
  },
} as const;

const c = LEGAL_CONTENT[kind] ?? LEGAL_CONTENT.privacy;
const pad = (i: number) => String(i + 1).padStart(2, '0');
---
<div class="legal-page">
  <div class="container">
    <a class="legal-page__back" href="/">
      <span aria-hidden="true">←</span> Back to home
    </a>

    <header class="legal-page__head">
      <span class="eyebrow legal-page__eyebrow">
        <span class="eyebrow__dot"></span>{c.eyebrow}
      </span>
      <h1 class="legal-page__title">
        {c.title.lead} <span class="em">{c.title.em}</span>{c.title.trail}
      </h1>
      <p class="legal-page__intro">{c.intro}</p>
    </header>

    <div class="legal-page__body">
      {c.sections.map((s, i) => (
        <section class="legal-section">
          <div class="legal-section__num"><span>{pad(i)}</span></div>
          <div class="legal-section__content">
            <h2 class="legal-section__h">{s.h}</h2>
            {s.body.map((block) => (
              'p' in block
                ? <p class="legal-section__body" set:html={block.p} />
                : <ul class="legal-section__list">{block.ul.map((li) => <li set:html={li} />)}</ul>
            ))}
          </div>
        </section>
      ))}
    </div>

    <aside class="legal-page__contact">
      <span class="eyebrow"><span class="eyebrow__dot"></span>{c.contact.lead}</span>
      <a class="legal-page__contact-email" href={`mailto:${c.contact.address}`}>{c.contact.address}</a>
      <p class="legal-page__contact-mail">{c.contact.mail}</p>
    </aside>
  </div>
</div>

<style is:global>
  /* Rich-body styles for the legal notices. Scoped under .legal-section /
   * .legal-page so they stay namespaced even though the block is global
   * (section bodies are injected with set:html and miss Astro's cid). */
  .legal-section__content { display: flex; flex-direction: column; gap: var(--space-3); }
  .legal-section__content .legal-section__h { margin-bottom: 0; }

  .legal-section__list {
    margin: 0; padding-left: 1.25em;
    display: flex; flex-direction: column; gap: 10px;
  }
  .legal-section__list li {
    font-family: var(--font-body); font-size: 16px; line-height: 1.65;
    color: var(--ink-soft); max-width: 64ch;
  }
  .legal-section__list li::marker { color: var(--ink-mute); }

  .legal-section__body strong,
  .legal-section__list strong { color: var(--ink); font-weight: 700; }
  .legal-section__body em,
  .legal-section__list em { color: var(--ink); font-style: italic; }

  .legal-section__body a,
  .legal-section__list a {
    color: var(--ink); text-decoration: underline;
    text-decoration-thickness: 1px; text-underline-offset: 2px;
    transition: color 180ms var(--ease-out);
  }
  .legal-section__body a:hover,
  .legal-section__list a:hover { color: var(--ink-emphasis); }
  .legal-section__body a:focus-visible,
  .legal-section__list a:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }

  .legal-section__body code,
  .legal-section__list code {
    font-family: var(--font-mono); font-size: 0.88em;
    background: var(--cream-soft); border: 1px solid var(--rule);
    border-radius: 6px; padding: 1px 6px;
  }

  .legal-page__note {
    margin: var(--space-4) 0 0;
    padding: var(--space-3) var(--space-4);
    background: var(--soft-butter);
    border-radius: 14px;
    font-family: var(--font-body); font-size: 15px; line-height: 1.55;
    color: var(--ink); max-width: 60ch;
  }
  .legal-page__note strong { font-weight: 700; }
</style>
