---
// HomeSpecialties — homepage §2.7 (spec L281-289).
// 4×3 grid (1-col mobile / 2-col ≥600px / 4-col ≥1000px). Each card: TAY Basal
// 24px specialty name, TAY Amaya 15px one-line framing, navy live count
// "{N} open opportunities" with navy underline on hover, hairline border that
// darkens to navy on hover. Each card links to /jobs?specialty={slug}.
//
// Top-12 set from spec L189 (Zach hasn't confirmed yet — spec §10 item 4
// pending). Counts come from parent via the `counts` prop. T28 wire-up reads
// build-time counts from the Content Collection (Path B) or runtime KV
// (Path A) and passes the resolved record. Missing slugs default to 0.
//
// Framing copy: CRNA quoted verbatim from spec L285. Other 11 entries written
// in voice (TAY Amaya register — concrete-noun-led, 9-12 words).
import ScrollReveal from '../util/ScrollReveal.astro';

interface Props {
  counts?: Record<string, number>;
}
const { counts = {} } = Astro.props;

const specialties: { slug: string; name: string; framing: string }[] = [
  { slug: 'anesthesiology', name: 'Anesthesiology', framing: 'Operative coverage across community, academic, and surgicenter settings.' },
  { slug: 'crna', name: 'CRNA', framing: 'Independent and supervised practice across surgical settings.' },
  { slug: 'hospitalist', name: 'Hospitalist', framing: 'Inpatient rounding for community and tertiary hospitals.' },
  { slug: 'emergency-medicine', name: 'Emergency Medicine', framing: 'Single- and double-coverage shifts across volume tiers.' },
  { slug: 'family-medicine', name: 'Family Medicine', framing: 'Outpatient and urgent-care coverage with broad scope.' },
  { slug: 'psychiatry', name: 'Psychiatry', framing: 'Inpatient, consult-liaison, and outpatient assignments.' },
  { slug: 'ob-gyn', name: 'OB/GYN', framing: 'Labor-and-delivery and clinic coverage at variable acuity.' },
  { slug: 'general-surgery', name: 'General Surgery', framing: 'Call coverage and elective scheduling for community hospitals.' },
  { slug: 'radiology', name: 'Radiology', framing: 'Diagnostic and teleradiology coverage with mixed modalities.' },
  { slug: 'pediatrics', name: 'Pediatrics', framing: 'Inpatient pediatrics, newborn nursery, and clinic settings.' },
  { slug: 'cardiology', name: 'Cardiology', framing: 'Non-invasive consult coverage with reading-room support.' },
  { slug: 'neurology', name: 'Neurology', framing: 'Inpatient consult, stroke coverage, and outpatient clinic.' },
];

function countFor(slug: string): number {
  const n = counts[slug];
  return typeof n === 'number' && Number.isFinite(n) && n >= 0 ? Math.floor(n) : 0;
}
---
<ScrollReveal as="section" id="specialties" class="specialties" aria-labelledby="specialties-heading">
  <div class="inner">
    <h2 id="specialties-heading" class="visually-hidden">Specialties we staff</h2>
    <ul class="grid">
      {specialties.map((s) => (
        <li>
          <a class="card" href={`/jobs?specialty=${s.slug}`}>
            <span class="name">{s.name}</span>
            <span class="framing">{s.framing}</span>
            <span class="count">{countFor(s.slug)} open opportunities</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="sub-cta">
      <a href="/specialties">
        View all specialties
        <span aria-hidden="true">&nbsp;→</span>
      </a>
    </p>
  </div>
</ScrollReveal>

<style>
  .specialties {
    padding: clamp(64px, 10vh, 128px) clamp(24px, 5vw, 80px);
  }
  .inner { max-width: 1200px; margin: 0 auto; }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 600px) { .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 1000px) { .grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    border: 1px solid var(--border-hairline);
    border-radius: var(--r-section);
    text-decoration: none;
    background: transparent;
    height: 100%;
    transition: border-color 200ms var(--ease-out);
  }
  .card:hover { border-color: var(--brand-navy); }
  .card:focus-visible {
    outline: 2px solid var(--brand-navy);
    outline-offset: 2px;
  }
  .name {
    font-family: var(--font-display);
    font-size: 24px;
    line-height: 1.2;
    color: var(--ink-on-cream);
    letter-spacing: -0.005em;
  }
  .framing {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-on-cream-3);
    flex: 1;
  }
  .count {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--brand-navy);
    margin-top: 4px;
  }
  .card:hover .count {
    text-decoration: underline;
    text-decoration-color: var(--brand-navy);
    text-underline-offset: 3px;
  }
  .sub-cta {
    margin: clamp(40px, 5vw, 64px) 0 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: 17px;
  }
  .sub-cta a {
    color: var(--brand-navy);
    text-decoration: none;
    border-bottom: 1px solid var(--brand-navy);
    padding-bottom: 2px;
    transition: color 200ms var(--ease-out), border-color 200ms var(--ease-out);
  }
  .sub-cta a:hover {
    color: var(--brand-blue-deep);
    border-color: var(--brand-blue-deep);
  }
  .sub-cta a:focus-visible {
    outline: 2px solid var(--brand-navy);
    outline-offset: 4px;
    border-color: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    .card, .sub-cta a { transition: none; }
  }
</style>
