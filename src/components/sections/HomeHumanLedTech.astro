---
// HomeHumanLedTech — homepage §2.6 (spec L272-279).
// Two-half split panel: left cream (--surface-card) + right warm-taupe
// (--surface-warm). Single body paragraph runs the full width below the split.
// Single thin horizontal hand-drawn rule below body — the only graphic.
// Brief §3 / spec §2.6 imagery restrictions apply (see spec for the full list).
import ScrollReveal from '../util/ScrollReveal.astro';
---
<ScrollReveal as="section" id="human-led-tech" class="hltech" aria-labelledby="hltech-heading">
  <h2 id="hltech-heading" class="visually-hidden">Human-led, technology-supported</h2>

  <div class="split">
    <div class="half half--cream">
      <p class="title">Technology where it helps.</p>
    </div>
    <div class="half half--taupe">
      <p class="title">People where it matters.</p>
    </div>
  </div>

  <div class="body-wrap">
    <p class="body">
      Modern systems help us move faster, stay organized, and communicate clearly.
      Technology helps us reduce friction. Human judgment helps us make better matches.
    </p>
    <svg class="rule" viewBox="0 0 320 6" preserveAspectRatio="none" aria-hidden="true" focusable="false">
      <path d="M2 4 Q 80 1 160 4 T 318 3" fill="none" stroke="var(--ink-on-cream)" stroke-width="1.4" stroke-linecap="round" />
    </svg>
  </div>
</ScrollReveal>

<style>
  .hltech {
    padding: clamp(64px, 10vh, 128px) 0 clamp(80px, 12vh, 160px);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .split {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .split { grid-template-columns: 1fr 1fr; }
  }
  .half {
    padding: clamp(64px, 10vh, 144px) clamp(24px, 5vw, 80px);
    display: flex;
    align-items: center;
  }
  .half--cream {
    background: var(--surface-card);
    color: var(--ink-on-cream);
    justify-content: flex-start;
  }
  .half--taupe {
    background: var(--surface-warm);
    color: var(--ink-on-cream);
    justify-content: flex-end;
  }
  .half--taupe .title { text-align: right; }
  .title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 40px);
    line-height: 1.15;
    margin: 0;
    max-width: 18ch;
    letter-spacing: -0.005em;
  }
  .body-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(48px, 6vw, 80px) clamp(24px, 5vw, 80px) 0;
  }
  .body {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-on-cream);
    max-width: 64ch;
    margin: 0 auto 32px;
    text-align: center;
  }
  .rule {
    display: block;
    margin: 0 auto;
    width: min(320px, 60%);
    height: 6px;
    opacity: 0.6;
  }
</style>
