---
// HomePhilosophy — homepage §2.3 (spec L235-240).
// Single-column editorial pull-quote with generous vertical padding.
import ScrollReveal from '../util/ScrollReveal.astro';
---
<ScrollReveal as="section" id="philosophy" class="philosophy" aria-labelledby="philosophy-quote">
  <blockquote class="pull-quote">
    <p id="philosophy-quote">
      Staffing is more than filling a schedule. It is trust, timing, communication, and fit.
    </p>
    <footer class="signature">— The IMS Team</footer>
  </blockquote>
</ScrollReveal>

<style>
  .philosophy {
    padding: clamp(96px, 14vh, 200px) clamp(24px, 5vw, 80px);
  }
  .pull-quote {
    margin: 0 auto;
    max-width: 64ch;
    text-align: center;
  }
  .pull-quote p {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 56px);
    line-height: 1.2;
    color: var(--ink-on-cream);
    margin: 0 0 32px;
    letter-spacing: -0.01em;
  }
  .signature {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-on-cream-2);
    font-style: normal;
  }
</style>
