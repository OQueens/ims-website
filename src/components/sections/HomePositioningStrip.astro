---
// HomePositioningStrip — homepage §2.2 (spec L227-233).
// Narrow magazine-masthead band: hairline rules top + bottom, 4-column equal grid,
// TAY Basal 13px uppercase labels. Charcoal-on-cream. No icons.
import ScrollReveal from '../util/ScrollReveal.astro';
const labels = [
  'Locum Tenens Coverage',
  'Multi-Specialty Staffing',
  'Clinician Support',
  'Facility Partnerships',
];
---
<ScrollReveal as="section" id="positioning" class="positioning-strip" aria-label="What we do">
  <ul class="cols">
    {labels.map((label) => <li class="col">{label}</li>)}
  </ul>
</ScrollReveal>

<style>
  .positioning-strip {
    border-top: 1px solid var(--border-hairline);
    border-bottom: 1px solid var(--border-hairline);
    padding: 32px clamp(24px, 5vw, 80px);
  }
  .cols {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 1200px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px 32px;
    text-align: center;
  }
  @media (min-width: 720px) {
    .cols {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  .col {
    font-family: var(--font-display);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-on-cream);
    line-height: 1.4;
  }
</style>
