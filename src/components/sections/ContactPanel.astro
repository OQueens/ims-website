---
/*
 * ContactPanel — dark-ink contact-b panel + form (kit ContactForm.jsx).
 * Reused on home (inline) + /contact. Styling from kit.css (.contact-b*).
 *
 * Zero-JS: the kit's client "sent" toggle is dropped; the form does a native
 * POST to /api/contact. Contact details are now REAL (content pass 2026-05-28):
 * recruiting@iastaffing.com / (512) 524-6686. IMS is fully remote — founded in
 * Fort Worth, TX (2022), no office/HQ — so the location row reads "Founded in".
 *
 * Availability copy matches the homepage canonical claim (a real person
 * answers every day of the week, weekends included; replies within one
 * business day). The
 * /api/contact endpoint + Cloudflare Turnstile + success-state UX are wired
 * separately.
 */
interface Props {
  /** Heading tag for the panel title. Home renders it as a sub-section (h2);
   *  /contact renders it as the page title (h1). Default h2. */
  as?: 'h1' | 'h2';
}
const { as: Heading = 'h2' } = Astro.props;
---
<section class="section section--cream contact-b-section" id="contact" aria-labelledby="contact-anchor">
  <div class="container">
    <div class="contact-b__panel">
      <div class="contact-b__glow contact-b__glow--magenta" aria-hidden="true"></div>
      <div class="contact-b__glow contact-b__glow--rose" aria-hidden="true"></div>

      <div class="contact-b__left">
        <span class="eyebrow contact-b__eyebrow">
          <span class="eyebrow__dot"></span>Get in touch
        </span>
        <Heading class="contact-b__headline" id="contact-anchor">
          Let's <span class="em">talk</span>.
        </Heading>
        <p class="contact-b__sub">
          A real conversation goes farther than a form. Pick whichever way is fastest, we'll be ready.
        </p>

        <dl class="contact-b__info">
          <div class="contact-b__info-row">
            <dt class="contact-b__info-label">Email</dt>
            <dd class="contact-b__info-value">
              <a href="mailto:recruiting@iastaffing.com">recruiting@iastaffing.com</a>
              <span class="contact-b__info-meta">Replies within one business day</span>
            </dd>
          </div>
          <div class="contact-b__info-row">
            <dt class="contact-b__info-label">Phone</dt>
            <dd class="contact-b__info-value">
              <a href="tel:+15125246686">(512) 524-6686</a>
              <span class="contact-b__info-meta">A real person answers, every day — weekends included</span>
            </dd>
          </div>
          <div class="contact-b__info-row">
            <dt class="contact-b__info-label">Founded in</dt>
            <dd class="contact-b__info-value">
              Fort Worth, TX
              <span class="contact-b__info-meta">est. 2022</span>
            </dd>
          </div>
        </dl>
      </div>

      <form class="contact-b__form" method="post" action="/api/contact">
        <div class="contact-b__form-head">
          <span class="contact-b__form-tag">Or send a note</span>
          <span class="contact-b__form-meta">We read every one.</span>
        </div>
        <input class="input" name="name" placeholder="Your name" required aria-label="Your name" />
        <input class="input" type="email" name="email" placeholder="Email" required aria-label="Email" />
        <select class="input full" name="audience" required aria-label="I am a...">
          <option value="" disabled selected>I am a…</option>
          <option value="facility">Facility</option>
          <option value="clinician">Clinician</option>
          <option value="other">Something else</option>
        </select>
        <input class="input full" name="role" placeholder="Role or specialty (optional)" aria-label="Role or specialty" />
        <textarea class="input full" name="message" rows="4" placeholder="What can we help with?" aria-label="What can we help with?"></textarea>
        <div class="full">
          <button class="pill pill--swing pill--swing--magenta" type="submit">
            Send it
            <span class="pill__puck" aria-hidden="true">→</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  /* Custom select chevron (kit inlined this as a style prop; moved to scoped
   * CSS). Single-quoted SVG + %23 for the # so it survives the attribute. */
  .contact-b__form select.input {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' stroke='%231F1A23' stroke-width='1.5' fill='none'/></svg>");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }
</style>
