---
/*
 * MarqueeStrip — scrolling "trusted at" facility strip (kit MarqueeStrip.jsx).
 * Reused on home + facilities. The CSS marquee animation lives in kit.css
 * (.marquee, .marquee__track). Pure CSS, no JS.
 *
 * NOTE (content pass): facility names are REAL IMS clients sourced from
 * LocumSmart confirmation agreements (Confirmation Agreement List Export) —
 * organizations + facility brands IMS actually holds active/past placements with.
 * The eyebrow avoids a specific facility/state count — the real footprint is ~9
 * organizations across ~12 states, far below the old "200+/47" kit demo copy.
 */
const facilities = [
  'Community Health Systems',
  'Advocate Health',
  'Atrium Health · NC',
  'Tenet Healthcare',
  'Ochsner Health',
  'Northwest Medical Center · AZ',
  'MountainView Regional · NM',
  'LifePoint Health',
  'Providence',
  'United Surgical Partners',
];
const items = [...facilities, ...facilities]; // double for a seamless loop
---
<section class="section section--sm marquee-section" aria-label="Facilities we've staffed">
  <div class="marquee-eyebrow">
    <span class="eyebrow"><span class="eyebrow__dot"></span>Trusted by leading U.S. health systems</span>
  </div>
  <div class="marquee">
    <div class="marquee__track">
      {items.map((f) => (
        <span class="marquee__item">
          <span class="marquee__dot" aria-hidden="true">✦</span>
          {f}
        </span>
      ))}
    </div>
  </div>
</section>
