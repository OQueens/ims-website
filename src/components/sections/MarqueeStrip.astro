---
/*
 * MarqueeStrip — scrolling "trusted at" health-system LOGO wall (v5 reskin).
 * Reused on home + facilities. The CSS marquee animation lives in kit.css
 * (.marquee, .marquee__track); v5-reskin.css restyles the band + the logos
 * (uniform-white treatment on the dark navy ink — see "Marquee" section there).
 *
 * NOTE (content pass): these are REAL IMS client health systems, sourced from
 * LocumSmart confirmation agreements — organizations IMS holds active/past
 * placements with. Zach supplied 7 brand logos to showcase, so this is a clean
 * logo-only wall of exactly those 7. Client names IMS works with but for which
 * no logo was supplied are intentionally dropped here rather than shown as bare
 * text — the wall stays a uniform set of real, supplied marks. All seven PNGs
 * are 720×245 (~2.94:1); width/height attrs preserve that ratio (no CLS).
 */
const facilities = [
  { name: 'Community Health Systems', logo: '/logos/chs.png' },
  { name: 'Atrium Health', logo: '/logos/atrium.png' },
  { name: 'Tenet Healthcare', logo: '/logos/tenet.png' },
  { name: 'Ochsner Health', logo: '/logos/ochsner.png' },
  { name: 'MountainView Regional', logo: '/logos/mountain-view.png' },
  { name: 'MUSC', logo: '/logos/musc.png' },
  { name: 'Providence', logo: '/logos/providence.png' },
];
// Seamless loop = two identical halves animated translateX(-50%). Each HALF must
// be wider than the viewport or the loop shows a blank gap before it resets (one
// 7-logo copy is only ~1400px, narrower than a wide screen — runtime-confirmed).
// Repeat the set so each half comfortably exceeds ultrawide, then double it.
const REPEAT = 3;
const half = Array.from({ length: REPEAT }, () => facilities).flat();
const items = [...half, ...half];
// Keep the scroll PACE constant: the loop now travels REPEAT× the distance, so the
// duration scales with it (48s was Zach's calm drift for a single copy).
const marqueeDuration = `${48 * REPEAT}s`;
---
<section class="section section--sm marquee-section marquee-section--logos" aria-label="Health systems we've staffed">
  <div class="marquee-eyebrow">
    <span class="eyebrow"><span class="eyebrow__dot"></span>Trusted by leading U.S. health systems</span>
  </div>
  <div class="marquee">
    <div class="marquee__track" style={`--marquee-duration:${marqueeDuration}`}>
      {items.map((f, i) => (
        // Announce each unique logo once; hide the repeated copies (whole item
        // subtree) from assistive tech so the wall isn't read out 6×.
        <span class="marquee__item" aria-hidden={i >= facilities.length ? 'true' : undefined}>
          <img
            src={f.logo}
            alt={f.name}
            class="marquee__logo"
            width="720"
            height="245"
            loading="lazy"
            decoding="async"
          />
        </span>
      ))}
    </div>
  </div>
</section>
