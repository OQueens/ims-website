---
// HomeProcess — homepage §2.8 (spec L291-298).
// 4 numbered steps (01→04) with thin hand-drawn connecting rules. Tabbed by
// audience: Clinicians (Submit CV → Onboarding → Schedule → Start) vs.
// Facilities (Request → Match → Coordinate → Support). Default tab Clinicians.
// Tab switching = vanilla JS with ARIA-correct attributes per WAI-ARIA APG
// tablist pattern: role=tablist / role=tab / role=tabpanel + aria-selected,
// aria-controls, aria-labelledby, tabindex management, arrow-key navigation.
import ScrollReveal from '../util/ScrollReveal.astro';

const tabs = [
  {
    id: 'clinicians',
    label: 'For Clinicians',
    steps: [
      { num: '01', title: 'Submit CV',  body: 'Share your background, license states, and availability — we read every one.' },
      { num: '02', title: 'Onboarding', body: 'Credentialing, paperwork, and travel logistics handled with you, not at you.' },
      { num: '03', title: 'Schedule',   body: 'A schedule that fits your life and the assignment — confirmed before you arrive.' },
      { num: '04', title: 'Start',      body: 'First-day support and a real human on call when something needs adjusting.' },
    ],
  },
  {
    id: 'facilities',
    label: 'For Facilities',
    steps: [
      { num: '01', title: 'Request',    body: 'Tell us what coverage you need, when, and any context that shapes a good fit.' },
      { num: '02', title: 'Match',      body: 'Curated clinician shortlist with credentials reviewed and references in hand.' },
      { num: '03', title: 'Coordinate', body: 'Credentialing, travel, and onboarding coordination handled end-to-end.' },
      { num: '04', title: 'Support',    body: 'Ongoing check-ins through the assignment so issues surface early, not late.' },
    ],
  },
] as const;
---
<ScrollReveal as="section" id="process" class="process" aria-labelledby="process-heading">
  <div class="inner">
    <h2 id="process-heading" class="visually-hidden">How it works</h2>

    <div class="tabs" role="tablist" aria-label="Audience">
      {tabs.map((t, i) => (
        <button
          type="button"
          role="tab"
          id={`process-tab-${t.id}`}
          class:list={['tab', { 'is-active': i === 0 }]}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`process-panel-${t.id}`}
          tabindex={i === 0 ? 0 : -1}
          data-tab={t.id}
        >
          {t.label}
        </button>
      ))}
    </div>

    {tabs.map((t, i) => (
      <div
        role="tabpanel"
        id={`process-panel-${t.id}`}
        aria-labelledby={`process-tab-${t.id}`}
        class:list={['panel', { 'is-active': i === 0 }]}
        hidden={i !== 0}
      >
        <ol class="steps">
          {t.steps.map((step, idx) => (
            <li class="step">
              <span class="num">{step.num}</span>
              <h3 class="title">{step.title}</h3>
              <p class="body">{step.body}</p>
              {idx < t.steps.length - 1 && (
                <svg class="rule" viewBox="0 0 80 6" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                  <path d="M2 4 Q 20 1 40 4 T 78 3" fill="none" stroke="var(--ink-on-cream-2)" stroke-width="1.4" stroke-linecap="round" />
                </svg>
              )}
            </li>
          ))}
        </ol>
      </div>
    ))}
  </div>
</ScrollReveal>

<style>
  .process {
    padding: clamp(64px, 10vh, 128px) clamp(24px, 5vw, 80px);
  }
  .inner { max-width: 1200px; margin: 0 auto; }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tabs {
    display: inline-flex;
    gap: 8px;
    margin: 0 auto clamp(40px, 6vw, 64px);
    padding: 4px;
    background: color-mix(in srgb, var(--ink-on-cream) 4%, transparent);
    border-radius: var(--r-pill-mkt);
    width: fit-content;
  }
  .tab {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 10px 20px;
    border-radius: var(--r-pill-mkt);
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink-on-cream-3);
    cursor: pointer;
    transition: background-color 200ms var(--ease-out), color 200ms var(--ease-out);
  }
  .tab:hover { color: var(--ink-on-cream); }
  .tab.is-active {
    background: var(--brand-navy);
    color: var(--ink-on-dark);
  }
  .tab:focus-visible {
    outline: 2px solid var(--brand-navy);
    outline-offset: 2px;
  }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(40px, 5vw, 64px);
  }
  @media (min-width: 900px) {
    .steps { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
  }
  .step {
    position: relative;
    text-align: left;
  }
  .num {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(48px, 5vw, 56px);
    line-height: 1;
    color: var(--ink-on-cream-2);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }
  .title {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.2;
    color: var(--ink-on-cream);
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }
  .body {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-on-cream-3);
    margin: 0;
    max-width: 36ch;
  }
  .rule {
    display: none;
  }
  @media (min-width: 900px) {
    .rule {
      display: block;
      position: absolute;
      top: 28px;
      right: -8px;
      width: 16px;
      height: 6px;
      opacity: 0.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tab { transition: none; }
  }
</style>

<script>
  // Vanilla JS tab toggle per WAI-ARIA APG tablist pattern.
  // - aria-selected on tabs reflects active state
  // - tabindex management: active tab = 0, others = -1 (one-stop tabbing)
  // - ArrowLeft / ArrowRight cycle within the tablist
  // - Home / End jump to first / last
  // - hidden attribute on inactive panels (matches initial SSR state)
  function init() {
    const tablists = document.querySelectorAll<HTMLElement>('.process [role="tablist"]');
    tablists.forEach((tablist) => {
      const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
      if (tabs.length === 0) return;

      function activate(index: number, focus = false) {
        tabs.forEach((tab, i) => {
          const isActive = i === index;
          tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          tab.setAttribute('tabindex', isActive ? '0' : '-1');
          tab.classList.toggle('is-active', isActive);
          const panelId = tab.getAttribute('aria-controls');
          if (panelId) {
            const panel = document.getElementById(panelId);
            if (panel) {
              panel.hidden = !isActive;
              panel.classList.toggle('is-active', isActive);
            }
          }
        });
        if (focus) tabs[index]?.focus();
      }

      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => activate(i));
        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          let next = -1;
          switch (e.key) {
            case 'ArrowRight': next = (i + 1) % tabs.length; break;
            case 'ArrowLeft':  next = (i - 1 + tabs.length) % tabs.length; break;
            case 'Home':       next = 0; break;
            case 'End':        next = tabs.length - 1; break;
            default: return;
          }
          e.preventDefault();
          activate(next, true);
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
