---
// ConciergeCard.astro — "your concierge desk" card (ports the source
// Concierge.jsx ConciergeCard). Reskinned from the dark navy original into
// Belleval quiet-luxury: paper card, brass hairlines, the Medallion seal
// instead of a stock headshot, sage/brass field chips. Used by Clinicians.
import Medallion from "./Medallion.astro";
import Icon from "./Icon.astro";
import Button from "./Button.astro";

interface Props {
  initials?: string;
  name?: string;
  role?: string;
  rating?: string;
  city?: string;
  phone?: string;
  email?: string;
  cadence?: string;
  showActions?: boolean;
}
const {
  initials = "AP",
  name = "Allison Park",
  role = "Your dedicated recruiter · 9 yrs at IMS",
  rating = "4.97 member rating",
  city = "Charleston, SC",
  phone = "(843) 555-0193",
  email = "allison@imstaffing.com",
  cadence = "Thursdays · 8:00 AM ET",
  showActions = true,
} = Astro.props;

const fields = [
  { icon: "phone", l: "Direct cell — yours, 24/7", v: phone },
  { icon: "mail",  l: "Email — replied within an hour", v: email },
  { icon: "cal",   l: "Standing weekly call", v: cadence },
];
---
<div class="cgc">
  <div class="cgc__bar">
    <span class="cgc__lbl">Your concierge desk</span>
    <span class="cgc__live"><span class="cgc__dot" aria-hidden="true"></span>On duty</span>
  </div>

  <div class="cgc__hero">
    <Medallion initials={initials} size={96} />
    <div>
      <h3 class="cgc__name">{name}</h3>
      <div class="cgc__role">{role}</div>
      <div class="cgc__meta">
        <span class="cgc__mi"><Icon name="star" size={13} color="var(--sage-2)" />{rating}</span>
        <span class="cgc__mi"><Icon name="pin" size={13} color="var(--sage-2)" />{city}</span>
      </div>
    </div>
  </div>

  <div class="cgc__hr" aria-hidden="true"></div>

  {fields.map((f) => (
    <div class="cgc__field">
      <span class="cgc__ic"><Icon name={f.icon} size={16} color="var(--pine)" /></span>
      <div>
        <div class="cgc__fl">{f.l}</div>
        <div class="cgc__fv">{f.v}</div>
      </div>
    </div>
  ))}

  {showActions && (
    <div class="cgc__act">
      <Button href="/contact" variant="primary" class="cgc__btn">
        <Icon name="phone" size={14} color="var(--on-pine)" /> Call {name.split(" ")[0]}
      </Button>
      <Button href="/contact" variant="ghost" class="cgc__btn">
        <Icon name="cal" size={14} color="var(--ink)" /> Schedule
      </Button>
    </div>
  )}
</div>

<style>
  .cgc {
    background: var(--paper); border: 1px solid var(--brass-line);
    border-radius: var(--r-2xl); padding: 26px;
    box-shadow: var(--elev-2);
    display: flex; flex-direction: column; gap: 18px;
  }
  .cgc__bar { display: flex; justify-content: space-between; align-items: center; }
  .cgc__lbl {
    font: var(--t-ceremonial); letter-spacing: var(--tracking-cer);
    text-transform: uppercase; color: var(--sage-2); font-feature-settings: "smcp" 1;
  }
  .cgc__live {
    display: inline-flex; align-items: center; gap: 8px;
    font: 600 10px/1 var(--sans); letter-spacing: .12em; text-transform: uppercase;
    color: var(--sage-2);
  }
  .cgc__dot {
    width: 7px; height: 7px; border-radius: 999px; background: var(--sage-2);
    box-shadow: 0 0 0 4px var(--sage-wash); /* sage dot + sage halo — coherent */
  }
  .cgc__hero {
    display: grid; grid-template-columns: 96px 1fr; gap: 18px;
    align-items: center; padding: 4px 2px;
  }
  .cgc__name {
    font: 400 22px/1.1 var(--display); letter-spacing: var(--tracking-display);
    text-transform: uppercase; color: var(--ink); margin: 0;
  }
  .cgc__role { font: 500 13px/1.4 var(--sans); color: var(--ink-3); margin-top: 7px; }
  .cgc__meta { display: flex; gap: 16px; margin-top: 12px; flex-wrap: wrap; }
  .cgc__mi {
    display: inline-flex; align-items: center; gap: 6px;
    font: 500 12px/1 var(--sans); color: var(--ink-2);
  }
  .cgc__hr { height: 1px; background: var(--brass-line); }
  .cgc__field {
    display: grid; grid-template-columns: auto 1fr; align-items: center; gap: 14px;
    padding: 13px 15px; border-radius: var(--r-md); background: var(--bone);
  }
  .cgc__ic {
    width: 36px; height: 36px; border-radius: 10px; flex: none;
    display: flex; align-items: center; justify-content: center;
    background: var(--sage-wash);
  }
  .cgc__fl {
    font: var(--t-ceremonial); letter-spacing: var(--tracking-cer);
    text-transform: uppercase; color: var(--sage-2); font-feature-settings: "smcp" 1;
  }
  .cgc__fv { font: 600 14px/1.3 var(--sans); color: var(--ink); margin-top: 4px; }
  .cgc__act { display: flex; gap: 10px; margin-top: 4px; }
  /* Button.astro is a child component (its scope id, not this card's), so a
   * bare scoped `.cgc__btn` never matches. Reach it via the scoped parent
   * + :global(); also outranks Button's own .btn so flex:1 actually lands. */
  .cgc__act :global(.cgc__btn) { flex: 1; justify-content: center; padding: 13px 18px; }
</style>
